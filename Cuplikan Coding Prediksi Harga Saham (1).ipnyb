 ============================================================\n","\n","smape_threshold2 = 10\n","\n","passed_stocks2 = eval_lstm_test2.loc[\n","    eval_lstm_test2[\"sMAPE\"] < smape_threshold2,\n","    \"Kode_Saham\"\n","].tolist()\n","\n","print(\"=== LOOP 2 - KODE SAHAM DENGAN sMAPE < 10 ===\")\n","print(passed_stocks2)\n","print(\"Jumlah saham lolos loop 2:\", len(passed_stocks2))"],"metadata":{"id":"0aa80nAezwri","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1777778004809,"user_tz":-420,"elapsed":24,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"ed2d08d5-1671-4530-d316-ec2c16d34e7a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["=== LOOP 2 - KODE SAHAM DENGAN sMAPE < 10 ===\n","['KLBF', 'MNCN', 'SMGR']\n","Jumlah saham lolos loop 2: 3\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# 19. LOOP 2 - PLOT GABUNGAN TRAINING 2010-2023 + TESTING 2024\n","#     HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","for col in passed_stocks2:\n","    if col not in train_plot_dict2:\n","        print(f\"{col} tidak ada di train_plot_dict2, dilewati.\")\n","        continue\n","\n","    if col not in test_plot_dict2:\n","        print(f\"{col} tidak ada di test_plot_dict2, dilewati.\")\n","        continue\n","\n","    train_df2 = train_plot_dict2[col].copy()\n","    test_df2 = test_plot_dict2[col].copy()\n","\n","    plot_df2 = pd.concat([train_df2, test_df2], axis=0).reset_index(drop=True)\n","\n","    split_date2 = test_df2[\"Tanggal\"].iloc[0]\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    plt.plot(\n","        plot_df2[\"Tanggal\"],\n","        plot_df2[\"Aktual\"],\n","        label=\"Aktual\"\n","    )\n","\n","    plt.plot(\n","        plot_df2[\"Tanggal\"],\n","        plot_df2[\"Prediksi\"],\n","        label=\"Prediksi\"\n","    )\n","\n","    plt.axvline(\n","        x=split_date2,\n","        linestyle=\":\",\n","        color=\"black\",\n","        linewidth=2,\n","        label=\"Batas Training-Testing\"\n","    )\n","\n","    plt.title(f\"Aktual vs Prediksi - {col} (Loop 2)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()"],"metadata":{"id":"OOHHHAXtE1wA","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1777778298749,"user_tz":-420,"elapsed":7967,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"8e25d78b-3930-408c-ab52-bbeb5f7b794c"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# ============================================================\n","# 20. LOOP 2 - HASIL FORECAST 2025 UNTUK SAHAM YANG LOLOS\n","# ============================================================\n","\n","forecast_2025_passed2 = pd.DataFrame({\"Tanggal\": future_dates2})\n","\n","for col in passed_stocks2:\n","    if col in forecast_dict2:\n","        forecast_2025_passed2[col] = forecast_dict2[col]\n","\n","print(\"=== LOOP 2 - FORECAST 2025 UNTUK SAHAM DENGAN sMAPE < 10 ===\")\n","print(forecast_2025_passed2.head())\n","print(forecast_2025_passed2.shape)"],"metadata":{"id":"15Fq43gczx2p","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1777722272961,"user_tz":-420,"elapsed":8,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"00f19f6f-0c7a-4975-e820-dbce25bf6ef4"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["=== LOOP 2 - FORECAST 2025 UNTUK SAHAM DENGAN sMAPE < 10 ===\n","     Tanggal         KLBF        MNCN         SMGR\n","0 2025-01-01  1297.010010  250.719894  2829.233398\n","1 2025-02-01  1281.693970  226.487305  2497.559814\n","2 2025-03-01  1312.793457  174.154068  2238.883545\n","3 2025-04-01  1367.694336  105.676231  2063.462891\n","4 2025-05-01  1425.990845   22.212824  2115.728027\n","(12, 4)\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# 21. LOOP 2 - PLOT AKTUAL VS PREDIKSI (TRAINING FINAL 2010-2024)\n","#     HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","for col in passed_stocks2:\n","    if col not in final_train_plot_dict2:\n","        continue\n","\n","    plot_df2 = final_train_plot_dict2[col].copy()\n","\n","    plt.figure(figsize=(10, 5))\n","\n","    plt.plot(\n","        plot_df2[\"Tanggal\"],\n","        plot_df2[\"Aktual\"],\n","        label=\"Aktual\"\n","    )\n","\n","    plt.plot(\n","        plot_df2[\"Tanggal\"],\n","        plot_df2[\"Prediksi\"],\n","        label=\"Prediksi\"\n","    )\n","\n","    plt.title(f\"Aktual vs Prediksi - {col} (Model Final 2010-2024, Loop 2)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()"],"metadata":{"id":"yT_4Pre4E6Wt","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1777722273784,"user_tz":-420,"elapsed":822,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"194a5d07-432d-4558-fd42-308da1b84a42"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# ============================================================\n","# 22. LOOP 2 - PLOT FORECAST 2025 UNTUK SAHAM YANG LOLOS\n","# ============================================================\n","\n","for col in passed_stocks2:\n","    if col not in forecast_2025_passed2.columns:\n","        continue\n","\n","    plt.figure(figsize=(10, 5))\n","\n","    plt.plot(\n","        forecast_2025_passed2[\"Tanggal\"],\n","        forecast_2025_passed2[col],\n","        marker=\"o\",\n","        label=\"Prediksi 2025\"\n","    )\n","\n","    plt.title(f\"Prediksi Harga Saham 2025 - {col} (Loop 2)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()"],"metadata":{"id":"10DzZMcDzy9R","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1777722274490,"user_tz":-420,"elapsed":704,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"1a25e4d6-73c0-459d-9a59-6af58537b259"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# ============================================================\n","# 23. LOOP 2 - PLOT DATA HISTORIS + DATA PREDIKSI 2025\n","#     HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","#     GARIS HISTORIS DAN PREDIKSI DISAMBUNG\n","# ============================================================\n","\n","for col in passed_stocks2:\n","\n","    if col not in df_all2.columns:\n","        print(f\"{col} tidak ada di df_all2, dilewati.\")\n","        continue\n","\n","    if col not in forecast_dict2:\n","        print(f\"{col} tidak ada di forecast_dict2, dilewati.\")\n","        continue\n","\n","    # data historis saham 2010-2024\n","    hist_plot_df2 = df_all2[\n","        df_all2[\"Tanggal\"] < \"2025-01-01\"\n","    ][[\"Tanggal\", col]].copy()\n","\n","    hist_plot_df2 = hist_plot_df2.dropna().reset_index(drop=True)\n","\n","    # data prediksi saham 2025\n","    forecast_plot_df2 = pd.DataFrame({\n","        \"Tanggal\": future_dates2,\n","        col: forecast_dict2[col]\n","    })\n","\n","    # ambil titik terakhir historis untuk menyambung garis\n","    last_hist2 = hist_plot_df2.iloc[[-1]].copy()\n","\n","    # gabungkan titik terakhir historis + forecast\n","    forecast_connected2 = pd.concat(\n","        [last_hist2, forecast_plot_df2],\n","        ignore_index=True\n","    )\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    # plot historis\n","    plt.plot(\n","        hist_plot_df2[\"Tanggal\"],\n","        hist_plot_df2[col],\n","        label=\"Data Historis 2010-2024\"\n","    )\n","\n","    # plot prediksi 2025\n","    plt.plot(\n","        forecast_connected2[\"Tanggal\"],\n","        forecast_connected2[col],\n","        label=\"Prediksi 2025\"\n","    )\n","\n","    # garis batas\n","    plt.axvline(\n","        x=pd.to_datetime(\"2024-12-01\"),\n","        linestyle=\":\",\n","        color=\"black\",\n","        linewidth=2,\n","        label=\"Batas Historis-Prediksi\"\n","    )\n","\n","    plt.title(f\"{col} (Loop 2)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()"],"metadata":{"id":"5jNryhC2z0F7","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1777722275439,"user_tz":-420,"elapsed":947,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"2f37f113-6fb0-4315-c4fd-c0dd25458073"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# ============================================================\n","# 24. LOOP 2 - BUAT DATASET BARU: BUANG SAHAM YANG LOLOS LOOP 2\n","# ============================================================\n","\n","remaining_stocks2 = [\n","    col for col in harga_2010_2024_sisa.columns\n","    if col not in passed_stocks2 + [\"Tanggal\"]\n","]\n","\n","harga_2010_2024_sisa2 = harga_2010_2024_sisa[\n","    [\"Tanggal\"] + remaining_stocks2\n","].copy()\n","\n","print(\"=== DATASET SISA LOOP 2 ===\")\n","print(harga_2010_2024_sisa2.head())\n","print(harga_2010_2024_sisa2.shape)\n","print(\"Jumlah saham sisa setelah loop 2:\", len(remaining_stocks2))"],"metadata":{"id":"_50Tlc8jz1Q8","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1777722275447,"user_tz":-420,"elapsed":6,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"95a774fb-584f-449c-94d4-d47a2c6ece57"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["=== DATASET SISA LOOP 2 ===\n","     Tanggal        ADHI        ASRI        BBKP        BHIT        BKSL  \\\n","0 2010-01-01  244.556000  100.410294  181.536499   57.060532  432.978058   \n","1 2010-02-01