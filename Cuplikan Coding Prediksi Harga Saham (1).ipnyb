ntent/drive/My Drive/hasil_loop2\"\n","\n","excel_folder2 = os.path.join(base_folder2, \"Excel\")\n","plot_train_test_folder2 = os.path.join(base_folder2, \"Plot_Training_Testing_2010_2024\")\n","plot_final_training_folder2 = os.path.join(base_folder2, \"Plot_Training_Final_2010_2024\")\n","plot_forecast_folder2 = os.path.join(base_folder2, \"Plot_Forecast_2025\")\n","plot_hist_forecast_folder2 = os.path.join(base_folder2, \"Plot_Historis_dan_Forecast_2025\")\n","\n","os.makedirs(excel_folder2, exist_ok=True)\n","os.makedirs(plot_train_test_folder2, exist_ok=True)\n","os.makedirs(plot_final_training_folder2, exist_ok=True)\n","os.makedirs(plot_forecast_folder2, exist_ok=True)\n","os.makedirs(plot_hist_forecast_folder2, exist_ok=True)\n","\n","print(\"Semua folder hasil loop 2 berhasil dibuat.\")\n","print(\"Folder utama:\", base_folder2)\n","\n","# ============================================================\n","# 25.2 BUAT DATAFRAME SAHAM LOLOS\n","# ============================================================\n","\n","passed_stocks_df2 = pd.DataFrame({\n","    \"Kode_Saham\": passed_stocks2\n","})\n","\n","print(\"\\nJumlah saham lolos loop 2:\", len(passed_stocks2))\n","print(passed_stocks_df2)\n","\n","# ============================================================\n","# 25.3 SIMPAN EXCEL HASIL LOOP 2\n","# ============================================================\n","\n","excel_path2 = os.path.join(excel_folder2, \"hasil_loop2.xlsx\")\n","\n","with pd.ExcelWriter(excel_path2, engine=\"openpyxl\") as writer:\n","    eval_lstm_train2.to_excel(\n","        writer,\n","        sheet_name=\"eval_train_2010_2023\",\n","        index=False\n","    )\n","\n","    eval_lstm_test2.to_excel(\n","        writer,\n","        sheet_name=\"eval_test_2024\",\n","        index=False\n","    )\n","\n","    eval_lstm_final_train2.to_excel(\n","        writer,\n","        sheet_name=\"eval_final_2010_2024\",\n","        index=False\n","    )\n","\n","    passed_stocks_df2.to_excel(\n","        writer,\n","        sheet_name=\"saham_lolos\",\n","        index=False\n","    )\n","\n","    forecast_2025_passed2.to_excel(\n","        writer,\n","        sheet_name=\"forecast_2025_lolos\",\n","        index=False\n","    )\n","\n","    harga_2010_2024_sisa2.to_excel(\n","        writer,\n","        sheet_name=\"data_sisa\",\n","        index=False\n","    )\n","\n","print(\"\\nFile Excel hasil loop 2 berhasil disimpan di:\")\n","print(excel_path2)\n","\n","# ============================================================\n","# 25.4 FUNGSI NAMA FILE AMAN\n","# ============================================================\n","\n","def make_safe_filename(name):\n","    return (\n","        str(name)\n","        .replace(\"/\", \"_\")\n","        .replace(\"\\\\\", \"_\")\n","        .replace(\" \", \"_\")\n","        .replace(\":\", \"_\")\n","        .replace(\"*\", \"_\")\n","        .replace(\"?\", \"_\")\n","        .replace('\"', \"_\")\n","        .replace(\"<\", \"_\")\n","        .replace(\">\", \"_\")\n","        .replace(\"|\", \"_\")\n","    )\n","\n","# ============================================================\n","# 25.5 SIMPAN PLOT GABUNGAN TRAINING 2010-2023 + TESTING 2024\n","# ============================================================\n","\n","for col in passed_stocks2:\n","\n","    if col not in train_plot_dict2:\n","        print(f\"{col} tidak ada di train_plot_dict2, dilewati.\")\n","        continue\n","\n","    if col not in test_plot_dict2:\n","        print(f\"{col} tidak ada di test_plot_dict2, dilewati.\")\n","        continue\n","\n","    train_df2 = train_plot_dict2[col].copy()\n","    test_df2 = test_plot_dict2[col].copy()\n","\n","    plot_df2 = pd.concat([train_df2, test_df2], axis=0).reset_index(drop=True)\n","\n","    split_date2 = test_df2[\"Tanggal\"].iloc[0]\n","\n","    safe_col2 = make_safe_filename(col)\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    plt.plot(\n","        plot_df2[\"Tanggal\"],\n","        plot_df2[\"Aktual\"],\n","        label=\"Aktual\"\n","    )\n","\n","    plt.plot(\n","        plot_df2[\"Tanggal\"],\n","        plot_df2[\"Prediksi\"],\n","        label=\"Prediksi\"\n","    )\n","\n","    plt.axvline(\n","        x=split_date2,\n","        linestyle=\":\",\n","        color=\"black\",\n","        linewidth=2,\n","        label=\"Batas Training-Testing\"\n","    )\n","\n","    plt.title(f\"Aktual vs Prediksi - {col} (Loop 2)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","\n","    save_path2 = os.path.join(\n","        plot_train_test_folder2,\n","        f\"training_testing_2010_2024_{safe_col2}.png\"\n","    )\n","\n","    plt.savefig(save_path2, dpi=300, bbox_inches=\"tight\")\n","    plt.close()\n","\n","print(\"\\nPlot gabungan training-testing loop 2 berhasil disimpan.\")\n","\n","# ============================================================\n","# 25.6 SIMPAN PLOT AKTUAL VS PREDIKSI MODEL FINAL 2010-2024\n","# ============================================================\n","\n","for col in passed_stocks2:\n","\n","    if col not in final_train_plot_dict2:\n","        print(f\"{col} tidak ada di final_train_plot_dict2, dilewati.\")\n","        continue\n","\n","    plot_df2 = final_train_plot_dict2[col].copy()\n","\n","    safe_col2 = make_safe_filename(col)\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    plt.plot(\n","        plot_df2[\"Tanggal\"],\n","        plot_df2[\"Aktual\"],\n","        label=\"Aktual\"\n","    )\n","\n","    plt.plot(\n","        plot_df2[\"Tanggal\"],\n","        plot_df2[\"Prediksi\"],\n","        label=\"Prediksi\"\n","    )\n","\n","    plt.title(f\"Aktual vs Prediksi - {col} (Model Final 2010-2024, Loop 2)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","\n","    save_path2 = os.path.join(\n","        plot_final_training_folder2,\n","        f\"final_training_2010_2024_{safe_col2}.png\"\n","    )\n","\n","    plt.savefig(save_path2, dpi=300, bbox_inches=\"tight\")\n","    plt.close()\n","\n","print(\"Plot training final loop 2 berhasil disimpan.\")\n","\n","# ============================================================\n","# 25.7 SIMPAN PLOT FORECAST 2025\n","# ============================================================\n","\n","for col in passed_stocks2:\n","\n","    if col not in forecast_2025_passed2.columns:\n","        print(f\"{col} tidak ada di forecast_2025_passed2, dilewati.\")\n","        continue\n","\n","    safe_col2 = make_safe_filename(col)\n","\n","    plt.figure(figsize=(10, 5))\n","\n","    plt.plot(\n","        forecast_2025_passed2[\"Tanggal\"],\n","        forecast_2025_passed2[col],\n","        marker=\"o\",\n","        label=\"Prediksi 2025\"\n","    )\n","\n","    plt.title(f\"Prediksi Harga Saham 2025 - {col} (Loop 2)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","\n","    save_path2 = os.path.join(\n","        plot_forecast_folder2,\n","        f\"forecast_2025_{safe_col2}.png\"\n","    )\n","\n","    plt.savefig(save_path2, dpi=300, bbox_inches=\"tight\")\n","    plt.close()\n","\n","print(\"Plot forecast 2025 loop 2 berhasil disimpan.\")\n","\n","# ============================================================\n","# 25.8 SIMPAN PLOT HISTORIS 2010-2024 + FORECAST 2025\n","# ============================================================\n","\n","for col in passed_stocks2:\n","\n","    if col not in df_all2.columns:\n","        print(f\"{col} tidak ada di df_all2, dilewati.\")\n","        continue\n","\n","    if col not in forecast_dict2:\n","        print(f\"{col} tidak ada di forecast_dict2, dilewati.\")\n","        continue\n","\n","    safe_col2 = make_safe_filename(col)\n","\n","    hist_plot_df2 = df_all2[\n","        df_all2[\"Tanggal\"] < \"2025-01-01\"\n","    ][[\"Tanggal\", col]].copy()\n","\n","    hist_plot_df2 = hist_plot_df2.dropna().reset_index(drop=True)\n","\n","    forecast_plot_df2 = pd.DataFrame({\n","        \"Tanggal\": future_dates2,\n","        col: forecast_dict2[col]\n","    })\n","\n","    last_hist2 = hist_plot_df2.iloc[[-1]].copy()\n","\n","    forecast_connected2 = pd.concat(\n","        [last_hist2, forecast_plot_df2],\n","        ignore_index=True\n","    )\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    plt.plot(\n","        hist_plot_df2[\"Tanggal\"],\n","        hist_plot_df2[col],\n","        label=\"Data Historis 2010-2024\"\n","    )\n","\n","    plt.plot(\n","        forecast_connected2[\"Tanggal\"],\n","        forecast_connected2[col],\n","        label=\"Prediksi 2025\"\n","    )\n","\n","    plt.axvline(\n","        x=pd.to_datetime(\"2024-12-01\"),\n","        linestyle=\":\",\n","        color=\"black\",\n","        linewidth=2,\n","        label=\"Batas Historis-Prediksi\"\n","    )\n","\n","    plt.title(f\"{col} (Loop 2)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","\n","    save_path2 = os.path.join(\n","        plot_hist_forecast_folder2,\n","        f\"historis_forecast_2025_{safe_col2}.png\"\n","    )\n","\n","    plt.savefig(save_path2, dpi=300, bbox_inches=\"tight\")\n","    plt.close()\n","\n","print(\"Plot historis + forecast 2025 loop 2 berhasil disimpan.\")\n","\n","# ============================================================\n","# 25.9 RINGKASAN PENYIMPANAN LOOP 2\n","# ============================================================\n","\n","print(\"\\n=== SEMUA HASIL LOOP 2 BERHASIL DISIMPAN ===\")\n","print(\"Folder utama              :\", base_folder2)\n","print(\"Excel                     :\", excel_folder2)\n","print(\"Plot training + testing   :\", plot_train_test_folder2)\n","print(\"Plot final training       :\", plot_final_training_folder2)\n","print(\"Plot forecast 2025        :\", plot_forecast_folder2)\n","print(\"Plot historis + forecast  :\", plot_hist_forecast_folder2)\n","\n","print(\"\\nFile Excel:\")\n","print(excel_path2)"],"metadata":{"id":"WyA-Rq7mz2sH"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 26. LOOP 3 - RAPIIKAN DATA\n","# ============================================================\n","harga_2010_2024_sisa2 = pd.read_excel(\"/content/drive/My Drive/hasil_loop2/Excel/hasil_loop2.xlsx\", sheet_name=\"data_sisa\")\n","# copy data agar aman\n","harga_df3 = harga_2010_2024_sisa2.copy()\n","pc_df3 = pc_all.copy()\n","\n","# ubah kolom tanggal ke format datetime\n","harga_df3[\"Tanggal\"] = pd.to_datetime(harga_df3[\"Tanggal\"])\n","pc_df3[\"Tanggal\"] = pd.to_datetime(pc_df3[\"Tanggal\"])\n","\n","# urutkan berdasarkan tanggal\n","harga_df3 = harga_df3.sort_values(\"Tanggal\").reset_index(drop=True)\n","pc_df3 = pc_df3.sort_values(\"Tanggal\").reset_index(drop=True)\n","\n","# cek nama kolom\n","print(\"Kolom harga loop 3:\")\n","print(harga_df3.columns)\n","\n","print(\"\\nKolom PC loop 3:\")\n","print(pc_df3.columns)\n","\n","# pilih kolom PC\n","pc_cols = [\"PC1\", \"PC2\", \"PC3\"]\n","\n","# pastikan PC numerik\n","for col in pc_cols:\n","    pc_df3[col] = pd.to_numeric(pc_df3[col], errors=\"coerce\")\n","\n","# semua kolom saham sisa loop 3\n","stock_cols3 = [col for col in harga_df3.columns if col != \"Tanggal\"]\n","\n","# pastikan harga saham numerik\n","for col in stock_cols3:\n","    harga_df3[col] = pd.to_numeric(harga_df3[col], errors=\"coerce\")\n","\n","# gabungkan data saham + PC\n","df_all3 = pd.merge(\n","    harga_df3,\n","    pc_df3[[\"Tanggal\"] + pc_cols],\n","    on=\"Tanggal\",\n","    how=\"inner\"\n",")\n","\n","# hapus missing value penting\n","df_all3 = df_all3.dropna(subset=[\"Tanggal\"] + pc_cols).reset_index(drop=True)\n","\n","# lihat data akhir\n","print(\"\\nData gabungan loop 3:\")\n","print(df_all3.head())\n","print(df_all3.tail())\n","print(df_all3.shape)\n","print(\"Jumlah saham loop 3:\", len(stock_cols3))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"T4Z9kfjIFi57","executionInfo":{"status":"ok","timestamp":1777778721538,"user_tz":-420,"elapsed":412,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"71c2db0b-8913-48c7-c824-5a5fc21b74aa"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Kolom harga loop 3:\n","Index(['Tanggal', 'ADHI', 'ASRI', 'BBKP', 'BHIT', 'BKSL', 'BNBR', 'BUMI',\n","       'DOID', 'ELTY', 'INTA', 'LPKR', 'MAIN', 'MIRA', 'MLPL', 'MPPA', 'SCMA',\n","       'SMCB', 'SSIA', 'TINS', 'TPIA', 'UNSP'],\n","      dtype='object')\n","\n","Kolom PC loop 3:\n","Index(['Tanggal', 'PC1', 'PC2', 'PC3'], dtype='object')\n","\n","Data gabungan loop 3:\n","     Tanggal        ADHI        ASRI        BBKP        BHIT        BKSL  \\\n","0 2010-02-01  235.498322  125.282562  186.251755  147.406372  432.978058   \n","1 2010-03-01  265.690399  151.076035  195.682190  190.201767  432.978058   \n","2 2010-04-01  356.266724  198.057022  287.629272  192.579300  432.978058   \n","3 2010-05-01  295.882477  156.603226  282.739105  166.426544  432.978058   \n","4 2010-06-01  374.381927  168.578781  332.342499  123.631157  432.978058   \n","\n","   BNBR         BUMI         DOID         ELTY  ...        MPPA       SCMA  \\\n","0  3800  2154.811035  1455.991455  2184.722168  ...  434.230164  17.010847   \n","1  3800  2154.811035   992.299927  2383.333496  ...  538.445374  18.011488   \n","2  3800  2274.522949   973.752197  2333.680664  ...  532.328552  23.014679   \n","3  3800  1939.329834   741.906555  1400.208374  ...  527.306519  22.514360   \n","4  3800  1800.464355   918.109253  1440.000000  ...  565.98138