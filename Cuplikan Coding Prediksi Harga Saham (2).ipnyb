.colab-df-convert:hover {\n","      background-color: #434B5C;\n","      box-shadow: 0px 1px 3px 1px rgba(0, 0, 0, 0.15);\n","      filter: drop-shadow(0px 1px 2px rgba(0, 0, 0, 0.3));\n","      fill: #FFFFFF;\n","    }\n","  </style>\n","\n","    <script>\n","      const buttonEl =\n","        document.querySelector('#df-29f0096a-cf78-4601-87b0-a5b19ead8f62 button.colab-df-convert');\n","      buttonEl.style.display =\n","        google.colab.kernel.accessAllowed ? 'block' : 'none';\n","\n","      async function convertToInteractive(key) {\n","        const element = document.querySelector('#df-29f0096a-cf78-4601-87b0-a5b19ead8f62');\n","        const dataTable =\n","          await google.colab.kernel.invokeFunction('convertToInteractive',\n","                                                    [key], {});\n","        if (!dataTable) return;\n","\n","        const docLinkHtml = 'Like what you see? Visit the ' +\n","          '<a target=\"_blank\" href=https://colab.research.google.com/notebooks/data_table.ipynb>data table notebook</a>'\n","          + ' to learn more about interactive tables.';\n","        element.innerHTML = '';\n","        dataTable['output_type'] = 'display_data';\n","        await google.colab.output.renderOutput(dataTable, element);\n","        const docLink = document.createElement('div');\n","        docLink.innerHTML = docLinkHtml;\n","        element.appendChild(docLink);\n","      }\n","    </script>\n","  </div>\n","\n","\n","    </div>\n","  </div>\n"],"application/vnd.google.colaboratory.intrinsic+json":{"type":"dataframe","variable_name":"pc_all","summary":"{\n  \"name\": \"pc_all\",\n  \"rows\": 191,\n  \"fields\": [\n    {\n      \"column\": \"Tanggal\",\n      \"properties\": {\n        \"dtype\": \"date\",\n        \"min\": \"2010-02-01 00:00:00\",\n        \"max\": \"2025-12-01 00:00:00\",\n        \"num_unique_values\": 191,\n        \"samples\": [\n          \"2022-10-01 00:00:00\",\n          \"2016-05-01 00:00:00\",\n          \"2023-04-01 00:00:00\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"PC1\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 1.2933122513722295,\n        \"min\": -2.457436634539065,\n        \"max\": 3.094261685946108,\n        \"num_unique_values\": 191,\n        \"samples\": [\n          0.2043198077050337,\n          0.7419344035469954,\n          0.08183909545262229\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"PC2\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 1.0185457384253112,\n        \"min\": -4.151536719526979,\n        \"max\": 2.991939590707219,\n        \"num_unique_values\": 191,\n        \"samples\": [\n          0.4196649929035898,\n          1.588268048550026,\n          -0.003377550131135412\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"PC3\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.9105338738781962,\n        \"min\": -4.924985219021716,\n        \"max\": 1.987459377059055,\n        \"num_unique_values\": 191,\n        \"samples\": [\n          -1.014518024994328,\n          -0.1087853956011356,\n          1.549074312862829\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{},"execution_count":2}],"source":["# ============================================================\n","# 1. LOAD DATA EXCEL\n","# ============================================================\n","\n","from google.colab import drive\n","import pandas as pd\n","\n","# mount drive\n","drive.mount('/content/drive')\n","\n","# load data\n","harga_2025 = pd.read_excel(\"/content/drive/My Drive/Data Harga 2010-2025.xlsx\")\n","harga_2010_2024 = harga_2025[harga_2025['Tanggal'].dt.year <= 2024]\n","pc_all = pd.read_excel(\"/content/drive/My Drive/Data PC All.xlsx\")\n","\n","# preview\n","harga_2025.head()\n","harga_2010_2024.head()\n","pc_all.head()"]},{"cell_type":"code","source":["# ============================================================\n","# 1. IMPORT LIBRARY\n","# ============================================================\n","\n","import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","\n","from sklearn.preprocessing import MinMaxScaler\n","from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score\n","\n","from tensorflow.keras.models import Sequential\n","from tensorflow.keras.layers import LSTM, Dense, Dropout\n","from tensorflow.keras.callbacks import EarlyStopping\n","from tensorflow.keras.optimizers import Adam\n","\n","import tensorflow as tf\n","import random\n","\n","# supaya hasil lebih stabil / reproducible\n","seed = 123\n","np.random.seed(seed)\n","tf.random.set_seed(seed)\n","random.seed(seed)"],"metadata":{"id":"u0IlD-wjNT3i"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 2. RAPIIKAN DATA\n","# ============================================================\n","\n","# copy data agar aman\n","harga_df = harga_2010_2024.copy()\n","pc_df = pc_all.copy()\n","\n","# ubah kolom tanggal ke format datetime\n","harga_df[\"Tanggal\"] = pd.to_datetime(harga_df[\"Tanggal\"])\n","pc_df[\"Tanggal\"] = pd.to_datetime(pc_df[\"Tanggal\"])\n","\n","# urutkan berdasarkan tanggal\n","harga_df = harga_df.sort_values(\"Tanggal\").reset_index(drop=True)\n","pc_df = pc_df.sort_values(\"Tanggal\").reset_index(drop=True)\n","\n","# cek nama kolom\n","print(\"Kolom harga:\")\n","print(harga_df.columns)\n","\n","print(\"\\nKolom PC:\")\n","print(pc_df.columns)\n","\n","# pilih kolom PC\n","pc_cols = [\"PC1\", \"PC2\", \"PC3\"]\n","\n","# pastikan PC numerik\n","for col in pc_cols:\n","    pc_df[col] = pd.to_numeric(pc_df[col], errors=\"coerce\")\n","\n","# semua kolom saham (selain Tanggal)\n","stock_cols = [col for col in harga_df.columns if col != \"Tanggal\"]\n","\n","# pastikan return saham numerik\n","for col in stock_cols:\n","    harga_df[col] = pd.to_numeric(harga_df[col], errors=\"coerce\")\n","\n","# gabungkan data saham + PC\n","df_all = pd.merge(harga_df, pc_df[[\"Tanggal\"] + pc_cols], on=\"Tanggal\", how=\"inner\")\n","\n","# hapus missing value penting\n","df_all = df_all.dropna(subset=[\"Tanggal\"] + pc_cols).reset_index(drop=True)\n","\n","# lihat data akhir\n","print(\"\\nData gabungan:\")\n","print(df_all.head())\n","print(df_all.tail())\n","print(df_all.shape)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jzOdFThVNVOP","executionInfo":{"status":"ok","timestamp":1777912886471,"user_tz":-420,"elapsed":94,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"7a16f361-c816-42bc-ef6d-ed335ff564c9"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Kolom harga:\n","Index(['Tanggal', 'AALI', 'ACES', 'ADHI', 'ADRO', 'AKRA', 'AMRT', 'ANTM',\n","       'ASII', 'ASRI', 'BBCA', 'BBKP', 'BBNI', 'BBRI', 'BBTN', 'BDMN', 'BFIN',\n","       'BHIT', 'BISI', 'BKSL', 'BMRI', 'BMTR', 'BNBR', 'BRPT', 'BSDE', 'BUMI',\n","       'BWPT', 'CPIN', 'CTRA', 'DEWA', 'DOID', 'ELSA', 'ELTY', 'EMTK', 'ENRG',\n","       'EXCL', 'GGRM', 'GJTL', 'HEXA', 'HMSP', 'ICBP', 'IMAS', 'INCO', 'INDF',\n","       'INDY', 'INKP', 'INTA', 'INTP', 'ISAT', 'ITMG', 'JPFA', 'JSMR', 'KIJA',\n","       'KLBF', 'LPKR', 'LPPF', 'LSIP', 'MAIN', 'MAPI', 'MEDC', 'MIRA', 'MLPL',\n","       'MNCN', 'MPPA', 'PGAS', 'PTBA', 'PWON', 'SCMA', 'SGRO', 'SMCB', 'SMGR',\n","       'SMRA', 'SSIA', 'TINS', 'TKIM', 'TLKM', 'TPIA', 'TRAM', 'UNSP', 'UNTR',\n","       'UNVR'],\n","      dtype='object')\n","\n","Kolom PC:\n","Index(['Tanggal', 'PC1', 'PC2', 'PC3'], dtype='object')\n","\n","Data gabungan:\n","     Tanggal          AALI        ACES        ADHI        ADRO       AKRA  \\\n","0 2010-02-01  13988.386719   95.156868  235.498322  367.103424  86.215431   \n","1 2010-03-01  14219.601562  114.747986  265.690399  393.181824  78.608177   \n","2 2010-04-01  12832.326172  119.645737  356.266724  441.326355  87.060661   \n","3 2010-05-01  11473.950195  121.692284  295.882477  401.205872  84.254051   \n","4 2010-06-01  11438.208008  126.616257  374.381927  402.747345  92.071449   \n","\n","        AMRT         ANTM         ASII        ASRI  ...         TKIM  \\\n","0  85.152252  1266.030029  1856.093506  125.282562  ...  1277.286011   \n","1  75.785507  1464.323730  2145.387695  151.076035  ...  1311.807007   \n","2  93.667496  1494.830933  2414.201172  198.057022  ...  1380.849731   \n","3  85.152252  1937.178345  2209.391113  156.603226  ...  1208.243408   \n","4  90.574425  1952.790161  2518.079102  168.578781  ...  1380.849731   \n","\n","         TLKM        TPIA        TRAM         UNSP         UNTR         UNVR  \\\n","0  827.744690  116.530861  475.822876  4840.554199  6797.420898  1437.021851   \n","1  802.812866  107.898949  471.064667  4698.185059  7273.042969  1518.244751   \n","2  782.867065  103.583008  456.789978  4745.641113  7728.846680  1730.673706   \n","3  772.894287   93.665451  452.031769  3654.144043  7273.042969  1949.351562   \n","4  767.907837   91.461571  432.998840  3511.774658  7564.358887  2160.074951   \n","\n","        PC1       PC2       PC3  \n","0  0.492976  0.603605  1.085846  \n","1  0.099063 -0.251742  1.740489  \n","2  0.460739  0.351861  1.269627  \n","3  0.769551  1.063974  0.398937  \n","4  0.844514  0.112261  1.324513  \n","\n","[5 rows x 84 columns]\n","       Tanggal         AALI        ACES   ADHI         ADRO         AKRA  \\\n","174 2024-08-01  5702.095215  667.976624  304.0  1831.865601  1382.413330   \n","175 2024-09-01  6220.467285  859.494385  270.0  1960.507935  1433.271362   \n","176 2024-10-01  6466.476074  840.809692  288.0  1862.739624  1248.333130   \n","177 2024-11-01  5917.660645  719.359436  254.0  1699.100220  1137.370239   \n","178 2024-12-01  5917.660645  738.044067  212.0  2071.861572  1035.654175   \n","\n","            AMRT         ANTM         ASII   ASRI  ...         TKIM  \\\n","174  2862.244629  1324.073730  4605.395996  193.0  ...  7366.964355   \n","175  3118.859619  1409.805176  4560.245117  220.0  ...  7516.294922   \n","176  3276.776611  1524.113647  4696.079102  208.0  ...  7366.964355   \n","177  2812.895508  1362.176636  4696.079102  156.0  ...  6321.651855   \n","178  2812.895508  1452.670776  4511.918945  134.0  ...  5948.326172   \n","\n","            TLKM         TPIA  TRAM   UNSP          UNTR         UNVR  \\\n","174  2836.581543  9963.737305  50.0   82.0  24125.552734  2083.083740   \n","175  2771.692627  8465.431641  50.0   85.0  24214.740234  2028.024292   \n","176  2614.104736  8740.121094  50.0  111.0  25100.667969  1803.197998   \n","177  2512.135986  6942.152832  50.0  119.0  24483.437500  1711.432251   \n","178  2512.135986  7491.531738  50.0   97.0  24483.437500  1767.731445   \n","\n","          PC1       PC2       PC3  \n","174 -0.891023 -1.456413  1.838586  \n","175 -0.870705 -0.496212  0.904828  \n","176 -0.499643  0.912572 -1.111856  \n","177 -0.787232  0.143390 -0.291711  \n","178 -0.727958  0.318956 -0.485595  \n","\n","[5 rows x 84 columns]\n","(179, 84)\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# 3. FUNGSI MEMBUAT SEQUENCE MULTIVARIATE LSTM\n","# ============================================================\n","\n","def create_multivariate_sequences(data_array, target_array, look_back):\n","    \"\"\"\n","    Mengubah data multivariat menjadi format supervised learning:\n","    X = sebanyak 'look_back' periode sebelumnya\n","    y = nilai target pada periode berikutnya\n","\n","    data_array   : array 2D (n_observasi, n_fitur)\n","    target_array : array 1D target\n","    \"\"\"\n","    X, y = [], []\n","\n","    for i in range(look_back, len(data_array)):\n","        X.append(data_array[i-look_back:i, :])\n","        y.append(target_array[i])\n","\n","    X = np.array(X)\n","    y = np.array(y)\n","\n","    return X, y"],"metadata":{"id":"Yod6FsztNZz-"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 4. FUNGSI MEMBUAT MODEL LSTM\n","# ============================================================\n","\n","def build_lstm_model(look_back, n_features=4):\n","    model = Sequential()\n","\n","    # layer LSTM pertama\n","    model.add(\n","        LSTM(\n","            64,\n","            activation=\"tanh\",\n","            return_sequences=False,\n","            input_shape=(look_back, n_features)\n","        )\n","    )\n","\n","    model.add(Dropout(0.2))\n","\n","    # output layer\n","    model.add(Dense(1))\n","\n","    model.compile(\n","        optimizer=Adam(learning_rate=0.001),\n","        loss=\"mse\"\n","    )\n","\n","    return model"],"metadata":{"id":"KQee9n0INbL3"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 5. FUNGSI MENGHITUNG METRIK\n","# ============================================================\n","\n","def calculate_metrics(y_actual, y_pred):\n","    mae = mean_absolute_error(y_actual, y_pred)\n","    rmse = np.sqrt(mean_squared_error(y_actual, y_pred))\n","\n","    mape = np.mean(\n","        np.where(\n","            y_actual != 0,\n","            np.abs((y_actual - y_pred) / y_actual),\n","            np.nan\n","        )\n","    ) * 100\n","\n","    smape = np.mean(\n","        2 * np.abs(y_pred - y_actual) /\n","        (np.abs(y_actual) + np.abs(y_pred) + 1e-8)\n","    ) * 100\n","\n","    r2 = r2_score(y_actual, y_pred)\n","\n","    return {\n","        \"MAE\": mae,\n","        \"RMSE\": rmse,\n","        \"MAPE\": mape,\n","        \"sMAPE\": smape,\n","        \"R2\": r2,\n","    }"],"metadata":{"id":"1hxHLDvYNcNX"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 6. TRAIN + TEST + RETRAIN FINAL + FORECAST 2025\n","#    UNTUK SETIAP SAHAM\n","# ============================================================\n","\n","look_back = 4\n","test_size = 12              # 12 bulan terakhir untuk testing (tahun 2024)\n","epochs = 200\n","batch_size = 1\n","\n","forecast_dict = {}\n","\n","# evaluasi model awal\n","eval_train_results = []\n","eval_test_results = []\n","\n","# evaluasi model final\n","eval_final_train_results = []\n","\n","history_dict = {}\n","model_dict = {}\n","scaler_X_dict = {}\n","scaler_y_dict = {}\n","\n","train_plot_dict = {}\n","test_plot_dict = {}\n","final_train_plot_dict = {}\n","\n","# tanggal forecast 2025\n","future_dates = pd.date_range(start=\"2025-01-01\", periods=12, freq=\"MS\")\n","\n","for col in stock_cols:\n","    print(\"=\"*70)\n","    print(f\"Proses saham: {col}\")\n","\n","    # --------------------------------------------------------\n","    # ambil data 1 saham + PC\n","    # --------------------------------------------------------\n","    series_df = df_all[[\"Tanggal\", col] + pc_cols].copy()\n","    series_df = series_df.dropna().reset_index(drop=True)\n","\n","    # cek minimal data\n","    if len(series_df) <= (look_back + test_size):\n","        print(f\"Data {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # --------------------------------------------------------\n","    # pisahkan data historis sampai 2024\n","    # --------------------------------------------------------\n","    hist_df = series_df[series_df[\"Tanggal\"] < \"2025-01-01\"].copy().reset_index(drop=True)\n","\n","    # target saham\n","    target_values = hist_df[[col]].values.astype(float)\n","\n","    # fitur multivariat = [return saham, PC1, PC2, PC3]\n","    feature_values = hist_df[[col] + pc_cols].values.astype(float)\n","\n","    # --------------------------------------------------------\n","    # split data:\n","    # train awal = 2010-2023\n","    # test       = 2024\n","    # --------------------------------------------------------\n","    train_target = target_values[:-test_size]\n","    test_target  = target_values[-test_size:]\n","\n","    train_features = feature_values[:-test_size]\n","    test_features  = feature_values[-test_size:]\n","\n","    # --------------------------------------------------------\n","    # scaling\n","    # scaler fitur fit hanya pada training\n","    # scaler target fit hanya pada training\n","    # --------------------------------------------------------\n","    scaler_X_train = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_train = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaler_X_train.fit(train_features)\n","    scaler_y_train.fit(train_target)\n","\n","    scaled_all_X = scaler_X_train.transform(feature_values)\n","    scaled_all_y = scaler_y_train.transform(target_values).flatten()\n","\n","    scaler_X_dict[f\"{col}_train\"] = scaler_X_train\n","    scaler_y_dict[f\"{col}_train\"] = scaler_y_train\n","\n","    # --------------------------------------------------------\n","    # buat sequence untuk evaluasi model awal\n","    # --------------------------------------------------------\n","    X_all, y_all = create_multivariate_sequences(\n","        data_array=scaled_all_X,\n","        target_array=scaled_all_y,\n","        look_back=look_back\n","    )\n","\n","    if len(X_all) <= test_size:\n","        print(f\"Sequence {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # sequence training dan testing\n","    X_train = X_all[:-test_size]\n","    y_train = y_all[:-test_size]\n","\n","    X_test = X_all[-test_size:]\n","    y_test = y_all[-test_size:]\n","\n","    print(\"Shape X_train:\", X_train.shape)\n","    print(\"Shape X_test :\", X_test.shape)\n","\n","    # --------------------------------------------------------\n","    # bangun model evaluasi\n","    # --------------------------------------------------------\n","    model = build_lstm_model(\n","        look_back=look_back,\n","        n_features=X_train.shape[2]\n","    )\n","\n","    early_stop = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    # --------------------------------------------------------\n","    # training model evaluasi\n","    # --------------------------------------------------------\n","    history = model.fit(\n","        X_train, y_train,\n","        validation_data=(X_test, y_test),\n","        epochs=epochs,\n","        batch_size=batch_size,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop]\n","    )\n","\n","    history_dict[f\"{col}_eval\"] = history\n","    model_dict[f\"{col}_eval\"] = model\n","\n","    # ========================================================\n","    # A. EVALUASI TRAINING (MODEL 2010-2023)\n","    # ========================================================\n","    y_pred_train_scaled = model.predict(X_train, verbose=0)\n","\n","    y_train_actual = scaler_y_train.inverse_transform(y_train.reshape(-1, 1)).flatten()\n","    y_pred_train_actual = scaler_y_train.inverse_transform(y_pred_train_scaled).flatten()\n","\n","    train_dates = hist_df[\"Tanggal\"].iloc[look_back:len(hist_df)-test_size].reset_index(drop=True)\n","\n","    train_plot_dict[col] = pd.DataFrame({\n","        \"Tanggal\": train_dates,\n","        \"Aktual\": y_train_actual,\n","        \"Prediksi\": y_pred_train_actual\n","    })\n","\n","    metrics_train = calculate_metrics(y_train_actual, y_pred_train_actual)\n","\n","    eval_train_results.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_train[\"MAE\"],\n","        \"RMSE\": metrics_train[\"RMSE\"],\n","        \"MAPE\": metrics_train[\"MAPE\"],\n","        \"sMAPE\": metrics_train[\"sMAPE\"],\n","        \"R2\": metrics_train[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # B. EVALUASI TESTING (2024)\n","    # ========================================================\n","    y_pred_test_scaled = model.predict(X_test, verbose=0)\n","\n","    y_test_actual = scaler_y_train.inverse_transform(y_test.reshape(-1, 1)).flatten()\n","    y_pred_test_actual = scaler_y_train.inverse_transform(y_pred_test_scaled).flatten()\n","\n","    test_dates = hist_df[\"Tanggal\"].iloc[-test_size:].reset_index(drop=True)\n","\n","    test_plot_dict[col] = pd.DataFrame({\n","        \"Tanggal\": test_dates,\n","        \"Aktual\": y_test_actual,\n","        \"Prediksi\": y_pred_test_actual\n","    })\n","\n","    metrics_test = calculate_metrics(y_test_actual, y_pred_test_actual)\n","\n","    eval_test_results.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_test[\"MAE\"],\n","        \"RMSE\": metrics_test[\"RMSE\"],\n","        \"MAPE\": metrics_test[\"MAPE\"],\n","        \"sMAPE\": metrics_test[\"sMAPE\"],\n","        \"R2\": metrics_test[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # C. RETRAIN MODEL FINAL DENGAN DATA 2010-2024\n","    # ========================================================\n","    scaler_X_full = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_full = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaled_full_X = scaler_X_full.fit_transform(feature_values)\n","    scaled_full_y = scaler_y_full.fit_transform(target_values).flatten()\n","\n","    scaler_X_dict[f\"{col}_full\"] = scaler_X_full\n","    scaler_y_dict[f\"{col}_full\"] = scaler_y_full\n","\n","    X_full, y_full = create_multivariate_sequences(\n","        data_array=scaled_full_X,\n","        target_array=scaled_full_y,\n","        look_back=look_back\n","    )\n","\n","    model_final = build_lstm_model(\n","        look_back=look_back,\n","        n_features=X_full.shape[2]\n","    )\n","\n","    early_stop_final = EarlyStopping(\n","        monitor=\"loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history_final = model_final.fit(\n","        X_full, y_full,\n","        epochs=epochs,\n","        batch_size=batch_size,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop_final]\n","    )\n","\n","    history_dict[f\"{col}_final\"] = history_final\n","    model_dict[f\"{col}_final\"] = model_final\n","\n","    # ========================================================\n","    # D. EVALUASI TRAINING MODEL FINAL (2010-2024)\n","    # ========================================================\n","    y_pred_full_scaled = model_final.predict(X_full, verbose=0)\n","\n","    y_full_actual = scaler_y_full.inverse_transform(y_full.reshape(-1, 1)).flatten()\n","    y_pred_full_actual = scaler_y_full.inverse_transform(y_pred_full_scaled).flatten()\n","\n","    full_train_dates = hist_df[\"Tanggal\"].iloc[look_back:].reset_index(drop=True)\n","\n","    final_train_plot_dict[col] = pd.DataFrame({\n","        \"Tanggal\": full_train_dates,\n","        \"Aktual\": y_full_actual,\n","        \"Prediksi\": y_pred_full_actual\n","    })\n","\n","    metrics_final_train = calculate_metrics(y_full_actual, y_pred_full_actual)\n","\n","    eval_final_train_results.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_final_train[\"MAE\"],\n","        \"RMSE\": metrics_final_train[\"RMSE\"],\n","        \"MAPE\": metrics_final_train[\"MAPE\"],\n","        \"sMAPE\": metrics_final_train[\"sMAPE\"],\n","        \"R2\": metrics_final_train[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # E. FORECAST 2025\n","    # ========================================================\n","    future_pc_df = pc_df[\n","        (pc_df[\"Tanggal\"] >= \"2025-01-01\") &\n","        (pc_df[\"Tanggal\"] <= \"2025-12-01\")\n","    ].copy().reset_index(drop=True)\n","\n","    if len(future_pc_df) < 12:\n","        print(f\"PC tahun 2025 untuk {col} tidak lengkap, forecast dilewati.\")\n","        continue\n","\n","    future_pc_values = future_pc_df[pc_cols].values.astype(float)\n","\n","    # ambil window terakhir dari data 2010-2024 yang sudah di-scale\n","    rolling_window = scaled_full_X[-look_back:, :].copy()\n","    future_preds_scaled = []\n","\n","    for step in range(12):\n","        x_input = rolling_window.reshape(1, look_back, scaled_full_X.shape[1])\n","\n","        # prediksi target saham\n","        next_pred_scaled = model_final.predict(x_input, verbose=0)[0, 0]\n","        future_preds_scaled.append(next_pred_scaled)\n","\n","        # ubah prediksi target ke skala asli dulu\n","        next_pred_actual = scaler_y_full.inverse_transform(\n","            np.array([[next_pred_scaled]])\n","        ).flatten()[0]\n","\n","        # gabungkan dengan PC periode 2025 pada bulan ke-step\n","        next_row_raw = np.array([\n","            next_pred_actual,\n","            future_pc_values[step, 0],\n","            future_pc_values[step, 1],\n","            future_pc_values[step, 2]\n","        ]).reshape(1, -1)\n","\n","        # scale lagi ke skala fitur\n","        next_row_scaled = scaler_X_full.transform(next_row_raw)\n","\n","        # update rolling window\n","        rolling_window = np.vstack([rolling_window[1:], next_row_scaled])\n","\n","    future_preds_scaled = np.array(future_preds_scaled).reshape(-1, 1)\n","    future_preds_actual = scaler_y_full.inverse_transform(future_preds_scaled).flatten()\n","\n","    forecast_dict[col] = future_preds_actual\n","\n","print(\"Selesai semua saham.\")"],"metadata":{"id":"90NtqT3HNda0","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1777774787755,"user_tz":-420,"elapsed":8700508,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"d9679162-bf05-4279-f870-50631042973e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","Proses saham: AALI\n","Shape X_train: (163, 4, 4)\n","Shape X_test : (12, 4, 4)\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/keras/src/layers/rnn/rnn.py:199: UserWarning: Do not pass an `input_shape`/`input_dim` argument to a layer. When using Sequential models, prefer using an `Input(shape)` object as the first layer in the model instead.\n","  super().__init__(**kwargs)\n","/usr/local/lib/python3.12/dist-packages/keras/src/layers/rnn/rnn.py:199: UserWarning: Do not pass an `input_shape`/`input_dim` argument to a layer. When using Sequential models, prefer using an `Input(shape)` object as the first layer in the model instead.\n","  super().__init__(**kwargs)\n"]},{"output_type":"stream","name":"stdout","text":["======================================================================\n","Proses saham: ACES\n","Shape X_train: (163, 4, 4)\n","Shape X_test : (12, 4, 4)\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/keras/src/layers/rnn/rnn.py:199: UserWarning: Do not pass an `input_shape`/`input_dim` argument to a layer. When using Sequential models, prefer using an `Input(shape)` object as the first layer in the model instead.\n","  super().__init__(**kwargs)\n","/usr/local/lib/python3.12/dist-packages/keras/src/layers/rnn/rnn.py:199: UserWarning: Do not pass an `input_shape`/`input_dim` argument to a layer. When using Sequential models, prefer using an `Input(shape)` object as the first layer in the model instead.\n","  super().__init__(**kwargs)\n"]},{"output_type":"stream","name":"stdout","text":["======================================================================\n","Proses saham: ADHI\n","Shape X_train: (163, 4, 4)\n","Shape X_test : (12, 4, 4)\n"]},{"output_type":"stream","name":"stderr","text"