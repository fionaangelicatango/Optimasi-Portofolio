LUASI MODEL\n","# ============================================================\n","\n","eval_lstm_train = pd.DataFrame(eval_train_results)\n","eval_lstm_test = pd.DataFrame(eval_test_results)\n","eval_lstm_final_train = pd.DataFrame(eval_final_train_results)\n","\n","print(\"=== EVALUASI TRAINING (MODEL 2010-2023) ===\")\n","print(eval_lstm_train)\n","\n","print(\"\\n=== EVALUASI TESTING 2024 ===\")\n","print(eval_lstm_test)\n","\n","print(\"\\n=== EVALUASI TRAINING FINAL (MODEL 2010-2024) ===\")\n","print(eval_lstm_final_train)"],"metadata":{"id":"BSweOF1xNe0q","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1777774787809,"user_tz":-420,"elapsed":37,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"f075f3e2-a749-41ae-b755-570ae3af8c41"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["=== EVALUASI TRAINING (MODEL 2010-2023) ===\n","   Kode_Saham          MAE         RMSE        MAPE      sMAPE        R2\n","0        AALI  1408.726973  1832.918805   11.535209  12.312365  0.667023\n","1        ACES    98.657224   129.724467   14.841797  14.267413  0.873897\n","2        ADHI   165.482473   229.254915   13.090183  13.982606  0.877254\n","3        ADRO   225.971829   264.040130   59.736263  42.655698  0.302582\n","4        AKRA    58.221556    73.803958   10.625532   9.973617  0.924168\n","..        ...          ...          ...         ...        ...       ...\n","75       TPIA   558.749328   646.790116  170.299682  67.856782  0.570303\n","76       TRAM   258.106697   441.044482   45.538636  59.362988  0.303722\n","77       UNSP   456.897929   867.337068   49.983849  56.568936  0.367538\n","78       UNTR  1164.476407  1572.780028    9.295998   8.727446  0.856119\n","79       UNVR   446.630188   587.744417    8.758344   9.057233  0.889199\n","\n","[80 rows x 6 columns]\n","\n","=== EVALUASI TESTING 2024 ===\n","   Kode_Saham          MAE         RMSE       MAPE      sMAPE        R2\n","0        AALI   274.244832   340.014221   4.709725   4.636512  0.201484\n","1        ACES    57.719055    73.094772   7.412901   7.611494 -0.822535\n","2        ADHI    35.421349    41.870960  14.283558  13.207539 -0.386558\n","3        ADRO   123.662984   153.383144   8.278174   7.977526  0.750509\n","4        AKRA    78.340535    88.335044   6.059705   5.973244  0.588003\n","..        ...          ...          ...        ...        ...       ...\n","75       TPIA  1545.148926  1826.766930  20.205679  19.902660 -0.168388\n","76       TRAM     4.415635     5.351892   8.831271   9.340731  0.000000\n","77       UNSP    36.082308    39.591461  40.911831  32.678183 -6.804089\n","78       UNTR   769.415527  1050.881143   3.504519   3.557417  0.788339\n","79       UNVR   200.072276   246.917351   8.740613   8.365141  0.553510\n","\n","[80 rows x 6 columns]\n","\n","=== EVALUASI TRAINING FINAL (MODEL 2010-2024) ===\n","   Kode_Saham          MAE         RMSE       MAPE      sMAPE        R2\n","0        AALI   840.614180  1111.182799   7.255296   7.417013  0.889347\n","1        ACES    74.294165   102.020176   9.440691   9.805282  0.916451\n","2        ADHI   201.156670   276.964260  15.997519  17.775798  0.831967\n","3        ADRO    98.369004   118.880925  24.910612  21.076652  0.919937\n","4        AKRA    91.782830   110.879305  16.006164  14.380521  0.880992\n","..        ...          ...          ...        ...        ...       ...\n","75       TPIA   245.039314   363.288795  48.860117  68.239566  0.966530\n","76       TRAM    94.177304   153.624368  58.556742  47.833275  0.912182\n","77       UNSP   116.267247   208.838643  27.455483  33.867891  0.961651\n","78       UNTR  1354.897863  1745.405286  11.018558  10.190834  0.862432\n","79       UNVR   443.663974   577.136871   9.260349   9.592761  0.899864\n","\n","[80 rows x 6 columns]\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# 8. AMBIL KODE SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","smape_threshold = 10\n","\n","passed_stocks = eval_lstm_test.loc[\n","    eval_lstm_test[\"sMAPE\"] < smape_threshold,\n","    \"Kode_Saham\"\n","].tolist()\n","\n","print(\"=== KODE SAHAM DENGAN sMAPE < 10 ===\")\n","print(passed_stocks)\n","print(\"Jumlah saham lolos:\", len(passed_stocks))"],"metadata":{"id":"hcJC7-_lNjHs","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1777775158726,"user_tz":-420,"elapsed":26,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"dbc69d3f-051b-496d-9d15-33154a5d31f9"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["=== KODE SAHAM DENGAN sMAPE < 10 ===\n","['AALI', 'ACES', 'ADRO', 'AKRA', 'AMRT', 'ANTM', 'ASII', 'BBCA', 'BBNI', 'BBRI', 'BBTN', 'BDMN', 'BFIN', 'BISI', 'BMRI', 'BMTR', 'BRPT', 'BSDE', 'BWPT', 'CPIN', 'CTRA', 'DEWA', 'ELSA', 'EMTK', 'ENRG', 'EXCL', 'GGRM', 'GJTL', 'HEXA', 'HMSP', 'ICBP', 'IMAS', 'INCO', 'INDF', 'INDY', 'INKP', 'INTP', 'ISAT', 'ITMG', 'JPFA', 'JSMR', 'KIJA', 'LPPF', 'LSIP', 'MAPI', 'MEDC', 'PGAS', 'PTBA', 'PWON', 'SGRO', 'SMRA', 'TKIM', 'TLKM', 'TRAM', 'UNTR', 'UNVR']\n","Jumlah saham lolos: 56\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# 9. PLOT GABUNGAN TRAINING 2010-2023 + TESTING 2024\n","#     HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","for col in passed_stocks:\n","    if col not in train_plot_dict:\n","        print(f\"{col} tidak ada di train_plot_dict, dilewati.\")\n","        continue\n","\n","    if col not in test_plot_dict:\n","        print(f\"{col} tidak ada di test_plot_dict, dilewati.\")\n","        continue\n","\n","    train_df = train_plot_dict[col].copy()\n","    test_df = test_plot_dict[col].copy()\n","\n","    plot_df = pd.concat([train_df, test_df], axis=0).reset_index(drop=True)\n","\n","    split_date = test_df[\"Tanggal\"].iloc[0]\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    plt.plot(\n","        plot_df[\"Tanggal\"],\n","        plot_df[\"Aktual\"],\n","        label=\"Aktual\"\n","    )\n","\n","    plt.plot(\n","        plot_df[\"Tanggal\"],\n","        plot_df[\"Prediksi\"],\n","        label=\"Prediksi\"\n","    )\n","\n","    plt.axvline(\n","        x=split_date,\n","        linestyle=\":\",\n","        color=\"black\",\n","        linewidth=2,\n","        label=\"Batas Training-Testing\"\n","    )\n","\n","    plt.title(f\"Aktual vs Prediksi - {col}\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()"],"metadata":{"id":"Yp_0h9YKaB4U","colab":{"base_uri":"https://localhost:8080/","height":1000,"output_embedded_package_id":"15ALPlKx-T_FiPIsZyE-NUMxFqj9lqXuB"},"executionInfo":{"status":"ok","timestamp":1777719075047,"user_tz":-420,"elapsed":20066,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"131ec67a-80be-4b0e-d013-6c857519ccf9"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":"Output hidden; open in https://colab.research.google.com to view."},"metadata":{}}]},{"cell_type":"code","source":["# ============================================================\n","# 10. HASIL FORECAST 2025 UNTUK SAHAM YANG LOLOS\n","# ============================================================\n","\n","forecast_2025_passed = pd.DataFrame({\"Tanggal\": future_dates})\n","\n","for col in passed_stocks:\n","    if col in forecast_dict:\n","        forecast_2025_passed[col] = forecast_dict[col]\n","\n","print(\"=== FORECAST 2025 UNTUK SAHAM DENGAN sMAPE < 10 ===\")\n","print(forecast_2025_passed.head())\n","print(forecast_2025_passed.shape)"],"metadata":{"id":"tdgHressNkXh","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1777719075399,"user_tz":-420,"elapsed":49,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"0637f7f4-0baf-4500-d2d4-fe38ee7725db"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["=== FORECAST 2025 UNTUK SAHAM DENGAN sMAPE < 10 ===\n","     Tanggal         AALI        ACES         ADRO         AKRA         AMRT  \\\n","0 2025-01-01  5956.917969  688.804993  2129.423584  1105.582642  2820.763916   \n","1 2025-02-01  6129.800293  660.974304  2288.855713  1183.991577  2851.238281   \n","2 2025-03-01  6269.381836  636.412842  2345.601807  1247.227051  2862.568848   \n","3 2025-04-01  6520.178223  612.473389  2368.404541  1293.677979  2874.371826   \n","4 2025-05-01  6722.963379  593.626953  2375.188965  1319.121460  2868.502441   \n","\n","          ANTM         ASII         BBCA         BBNI  ...         PGAS  \\\n","0  1409.266724  4588.702637  9117.704102  3814.408203  ...  1391.841064   \n","1  1426.992798  4671.102051  9269.051758  3855.414551  ...  1349.533325   \n","2  1431.208618  4757.720215  9399.448242  4138.164062  ...  1291.336792   \n","3  1472.390869  4810.060547  9481.046875  4305.870605  ...  1238.008545   \n","4  1484.019531  4838.139648  9469.378906  4390.254395  ...  1192.235718   \n","\n","          PTBA        PWON         SGRO        SMRA         TKIM         TLKM  \\\n","0  2451.125244  382.853973  1858.760010  482.598450  5958.870117  2587.131592   \n","1  2508.744629  390.527893  1790.848511  494.075287  6276.802246  2701.065674   \n","2  2543.427002  398.546448  1766.380859  503.947205  6690.782715  2794.078613   \n","3  2570.156494  404.595917  1744.492798  507.765808  7158.333984  2886.414795   \n","4  2569.312012  407.898956  1725.793823  510.243622  7501.367676  2936.928223   \n","\n","         TRAM          UNTR         UNVR  \n","0   87.693428  24713.630859  1776.879272  \n","1  121.180969  24880.136719  1763.617676  \n","2  160.628067  25023.455078  1717.713867  \n","3  201.269531  25196.580078  1673.893921  \n","4  240.755096  25245.755859  1684.036987  \n","\n","[5 rows x 57 columns]\n","(12, 57)\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# 11. PLOT AKTUAL VS PREDIKSI (TRAINING FINAL 2010-2024)\n","# ============================================================\n","\n","for col in stock_cols:\n","    if col not in final_train_plot_dict:\n","        continue\n","\n","    plot_df = final_train_plot_dict[col]\n","\n","    plt.figure(figsize=(10, 5))\n","    plt.plot(plot_df[\"Tanggal\"], plot_df[\"Aktual\"], label=\"Aktual\")\n","    plt.plot(plot_df[\"Tanggal\"], plot_df[\"Prediksi\"], label=\"Prediksi\")\n","    plt.title(f\"Aktual vs Prediksi - {col} (Model Final 2010-2024)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()"],"metadata":{"id":"fSzv8H6uvV3y","colab":{"base_uri":"https://localhost:8080/","height":1000,"output_embedded_package_id":"1utU_MmmzfQFRljjGq0_p84sN7VSdm4iS"},"executionInfo":{"status":"ok","timestamp":1777719106345,"user_tz":-420,"elapsed":30947,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"93b4eadb-470f-41b6-fedf-efa0a4f634c5"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":"Output hidden; open in https://colab.research.google.com to view."},"metadata":{}}]},{"cell_type":"code","source":["# ============================================================\n","# 12. PLOT FORECAST 2025 UNTUK SAHAM YANG LOLOS\n","# ============================================================\n","\n","for col in passed_stocks:\n","    if col not in forecast_2025_passed.columns:\n","        continue\n","\n","    plt.figure(figsize=(10, 5))\n","    plt.plot(forecast_2025_passed[\"Tanggal\"], forecast_2025_passed[col],\n","             marker=\"o\", label=\"Prediksi 2025\")\n","    plt.title(f\"Prediksi Harga Saham 2025 - {col}\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()"],"metadata":{"id":"7XFoqO-6Nlc3","colab":{"base_uri":"https://localhost:8080/","height":1000,"output_embedded_package_id":"1pa_owTPYHlWXB1ktLbyYvEiz9u5491M7"},"executionInfo":{"status":"ok","timestamp":1777719121963,"user_tz":-420,"elapsed":15579,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"9f19b166-7c46-4685-bfc0-3439a2777257"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":"Output hidden; open in https://colab.research.google.com to view."},"metadata":{}}]},{"cell_type":"code","source":["# ============================================================\n","# 13. PLOT DATA HISTORIS + DATA PREDIKSI 2025\n","#     HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","#     GARIS HISTORIS DAN PREDIKSI DISAMBUNG\n","# ============================================================\n","\n","for col in passed_stocks:\n","\n","    if col not in df_all.columns:\n","        print(f\"{col} tidak ada di df_all, dilewati.\")\n","        continue\n","\n","    if col not in forecast_dict:\n","        print(f\"{col} tidak ada di forecast_dict, dilewati.\")\n","        continue\n","\n","    # data historis saham 2010-2024\n","    hist_df = df_all[df_all[\"Tanggal\"] < \"2025-01-01\"][[\"Tanggal\", col]].copy()\n","    hist_df = hist_df.dropna().reset_index(drop=True)\n","\n","    # data prediksi saham 2025\n","    forecast_df = pd.DataFrame({\n","        \"Tanggal\": future_dates,\n","        col: forecast_dict[col]\n","    })\n","\n","    # ambil titik terakhir historis untuk menyambung garis\n","    last_hist = hist_df.iloc[[-1]].copy()\n","\n","    # gabungkan titik terakhir historis + forecast\n","    forecast_connected = pd.concat([last_hist, forecast_df], ignore_index=True)\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    # plot historis\n","    plt.plot(\n","        hist_df[\"Tanggal\"],\n","        hist_df[col],\n","        label=f\"Data Historis 2010-2024\"\n","    )\n","\n","    # plot prediksi 2025 (disambung dari titik terakhir historis)\n","    plt.plot(\n","        forecast_connected[\"Tanggal\"],\n","        forecast_connected[col],\n","        label=f\"Prediksi 2025\"\n","    )\n","\n","    # garis batas\n","    plt.axvline(\n","        x=pd.to_datetime(\"2024-12-01\"),\n","        linestyle=\":\",\n","        color=\"black\",\n","        linewidth=2,\n","        label=\"Batas Historis-Prediksi\"\n","    )\n","\n","    plt.title(f\"{col}\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()"],"metadata":{"id":"3UjJsbEONmqT","colab":{"base_uri":"https://localhost:8080/","height":1000,"output_embedded_package_id":"1rYCW15yDl6C0Q50t3SctneHBEV776J4n"},"executionInfo":{"status":"ok","timestamp":1777719141497,"user_tz":-420,"elapsed":19519,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"554575b5-ca6e-403b-9a3a-1822ca7b056f"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":"Output hidden; open in https://colab.research.google.com to view."},"metadata":{}}]},{"cell_type":"code","source":["# ============================================================\n","# 14. BUAT DATASET BARU: BUANG SAHAM YANG LOLOS\n","# ============================================================\n","\n","remaining_stocks = [col for col in harga_2010_2024.columns if col not in passed_stocks + [\"Tanggal\"]]\n","\n","harga_2010_2024_sisa = harga_2010_2024[[\"Tanggal\"] + remaining_stocks].copy()\n","\n","print(\"=== DATASET SISA ===\")\n","print(harga_2010_2024_sisa.head())\n","print(harga_2010_2024_sisa.shape)\n","print(\"Jumlah saham sisa:\", len(remaining_stocks))"],"metadata":{"id":"x5EyftaMNpSg","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1777775158734,"user_tz":-420,"elapsed":7,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"e7b143ab-03bf-41a0-a910-1563f9fdb3d5"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["=== DATASET SISA ===\n","     Tanggal        ADHI        ASRI        BBKP        BHIT        BKSL  \\\n","0 2010-01-01  244.556000  100.410294  181.536499   57.060532  432.978058   \n","1 2010-02-01  235.498322  125.282562  186.251755  147.406372  432.978058   \n","2 2010-03-01  265.690399  151.076035  195.682190  190.201767  432.978058   \n","3 2010-04-01  356.266724  198.057022  287.629272  192.579300  432.978058   \n","4 2010-05-01  295.882477  156.603226  282.739105  166.426544  432.978058   \n","\n","   BNBR         BUMI         DOID         ELTY  ...        MLPL        MNCN  \\\n","0  3800  2370.291992  1660.015747  2581.944580  ...  225.205231  187.449341   \n","1  3800  2154.811035  1455.991455  2184.722168  ...  137.746887  203.749268   \n","2  3800  2154.811035   992.299927  2383.333496  ...  150.865631  264.874054   \n","3  3800  2274.522949   973.752197  2333.680664  ...  108.841789  342.298798   \n","4  3800  1939.329834   741.906555  1400.208374  ...   85.834579  317.848877   \n","\n","         MPPA       SCMA         SMCB         SMGR       SSIA         TINS  \\\n","0  534.103210  14.509254  1240.297974  5284.552734  61.590378  1010.241882   \n","1  434.230164  17.010847  1346.826660  5020.324707  61.590378   976.188782   \n","2  538.445374  18.011488  1578.906738  4822.153809  76.735558  1078.347656   \n","3  532.328552  23.014679  1788.159424  5416.666016  82.793633  1225.911255   \n","4  527.306519  22.514360  1597.929932  5581.807617  78.754929  1010.241882   \n","\n","         TPIA         UNSP  \n","0   94.951088  5504.943848  \n","1  116.530861  4840.554199  \n","2  107.898949  4698.185059  \n","3  103.583008  4745.641113  \n","4   93.665451  3654.144043  \n","\n","[5 rows x 25 columns]\n","(180, 25)\n","Jumlah saham sisa: 24\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# SAVE HASIL LOOP 1 SEBELUM MASUK LOOP 2\n","# ============================================================\n","\n","import os\n","\n","# ============================================================\n","# 1. BUAT FOLDER UTAMA DAN SUBFOLDER\n","# ============================================================\n","\n","base_folder = \"/content/drive/My Drive/hasil_loop1\"\n","\n","excel_folder = os.path.join(base_folder, \"Excel\")\n","plot_train_test_folder = os.path.join(base_folder, \"Plot_Training_Testing_2010_2024\")\n","plot_final_training_folder = os.path.join(base_folder, \"Plot_Training_Final_2010_2024\")\n","plot_forecast_folder = os.path.join(base_folder, \"Plot_Forecast_2025\")\n","plot_hist_forecast_folder = os.path.join(base_folder, \"Plot_Historis_dan_Forecast_2025\")\n","\n","os.makedirs(excel_folder, exist_ok=True)\n","os.makedirs(plot_train_test_folder, exist_ok=True)\n","os.makedirs(plot_final_training_folder, exist_ok=True)\n","os.makedirs(plot_forecast_folder, exist_ok=True)\n","os.makedirs(plot_hist_forecast_folder, exist_ok=True)\n","\n","print(\"Semua folder hasil loop 1 berhasil dibuat.\")\n","print(\"Folder utama:\", base_folder)\n","\n","# ============================================================\n","# 2. BUAT DATAFRAME SAHAM LOLOS\n","# ============================================================\n","\n","passed_stocks_df = pd.DataFrame({\n","    \"Kode_Saham\": passed_stocks\n","})\n","\n","print(\"\\nJumlah saham lolos loop 1:\", len(passed_stocks))\n","print(passed_stocks_df)\n","\n","# ============================================================\n","# 3. SIMPAN EXCEL HASIL LOOP 1\n","# ============================================================\n","\n","excel_path = os.path.join(excel_folder, \"hasil_loop1.xlsx\")\n","\n","with pd.ExcelWriter(excel_path, engine=\"openpyxl\") as writer:\n","    eval_lstm_train.to_excel(\n","        writer,\n","        sheet_name=\"eval_train_2010_2023\",\n","        index=False\n","    )\n","\n","    eval_lstm_test.to_excel(\n","        writer,\n","        sheet_name=\"eval_test_2024\",\n","        index=False\n","    )\n","\n","    eval_lstm_final_train.to_excel(\n","        writer,\n","        sheet_name=\"eval_final_2010_2024\",\n","        index=False\n","    )\n","\n","    passed_stocks_df.to_excel(\n","        writer,\n","        sheet_name=\"saham_lolos\",\n","        index=False\n","    )\n","\n","    forecast_2025_passed.to_excel(\n","        writer,\n","        sheet_name=\"forecast_2025_lolos\",\n","        index=False\n","    )\n","\n","    harga_2010_2024_sisa.to_excel(\n","        writer,\n","        sheet_name=\"data_sisa\",\n","        index=False\n","    )\n","\n","print(\"\\nFile Excel hasil loop 1 berhasil disimpan di:\")\n","print(excel_path)\n","\n","# ============================================================\n","# 4. SIMPAN PLOT GABUNGAN TRAINING 2010-2023 + TESTING 2024\n","#    HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","for col in passed_stocks:\n","\n","    if col not in train_plot_dict:\n","        print(f\"{col} tidak ada di train_plot_dict, dilewati.\")\n","        continue\n","\n","    if col not in test_plot_dict:\n","        print(f\"{col} tidak ada di test_plot_dict, dilewati.\")\n","        continue\n","\n","    train_df = train_plot_dict[col].copy()\n","    test_df = test_plot_dict[col].copy()\n","\n","    plot_df = pd.concat([train_df, test_df], axis=0).reset_index(drop=True)\n","\n","    split_date = test_df[\"Tanggal\"].iloc[0]\n","\n","    safe_col = (\n","        str(col)\n","        .replace(\"/\", \"_\")\n","        .replace(\"\\\\\", \"_\")\n","        .replace(\" \", \"_\")\n","        .replace(\":\", \"_\")\n","        .replace(\"*\", \"_\")\n","        .replace(\"?\", \"_\")\n","        .replace('\"', \"_\")\n","        .replace(\"<\", \"_\")\n","        .replace(\">\", \"_\")\n","        .replace(\"|\", \"_\")\n","    )\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    plt.plot(\n","        plot_df[\"Tanggal\"],\n","        plot_df[\"Aktual\"],\n","        label=\"Aktual\"\n","    )\n","\n","    plt.plot(\n","        plot_df[\"Tanggal\"],\n","        plot_df[\"Prediksi\"],\n","        label=\"Prediksi\"\n","    )\n","\n","    plt.axvline(\n","        x=split_date,\n","        linestyle=\":\",\n","        color=\"black\",\n","        linewidth=2,\n","        label=\"Batas Training-Testing\"\n","    )\n","\n","    plt.title(f\"Aktual vs Prediksi - {col}\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","\n","    save_path = os.path.join(\n","        plot_train_test_folder,\n","        f\"training_testing_2010_2024_{safe_col}.png\"\n","    )\n","\n","    plt.savefig(save_path, dpi=300, bbox_inches=\"tight\")\n","    plt.close()\n","\n","print(\"\\nPlot gabungan training-testing loop 1 berhasil disimpan.\")\n","\n","# ============================================================\n","# 5. SIMPAN PLOT AKTUAL VS PREDIKSI MODEL FINAL 2010-2024\n","#    HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","for col in passed_stocks:\n","\n","    if col not in final_train_plot_dict:\n","        print(f\"{col} tidak ada di final_train_plot_dict, dilewati.\")\n","        continue\n","\n","    plot_df = final_train_plot_dict[col].copy()\n","\n","    safe_col = (\n","        str(col)\n","        .replace(\"/\", \"_\")\n","        .replace(\"\\\\\", \"_\")\n","        .replace(\" \", \"_\")\n","        .replace(\":\", \"_\")\n","        .replace(\"*\", \"_\")\n","        .replace(\"?\", \"_\")\n","        .replace('\"', \"_\")\n","        .replace(\"<\", \"_\")\n","        .replace(\">\", \"_\")\n","        .replace(\"|\", \"_\")\n","    )\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    plt.plot(\n","        plot_df[\"Tanggal\"],\n","        plot_df[\"Aktual\"],\n","        label=\"Aktual\"\n","    )\n","\n","    plt.plot(\n","        plot_df[\"Tanggal\"],\n","        plot_df[\"Prediksi\"],\n","        label=\"Prediksi\"\n","    )\n","\n","    plt.title(f\"Aktual vs Prediksi - {col} (Model Final 2010-2024)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","\n","    save_path = os.path.join(\n","        plot_final_training_folder,\n","        f\"final_training_2010_2024_{safe_col}.png\"\n","    )\n","\n","    plt.savefig(save_path, dpi=300, bbox_inches=\"tight\")\n","    plt.close()\n","\n","print(\"Plot training final loop 1 berhasil disimpan.\")\n","\n","# ============================================================\n","# 6. SIMPAN PLOT FORECAST 2025\n","#    HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","for col in passed_stocks:\n","\n","    if col not in forecast_2025_passed.columns:\n","        print(f\"{col} tidak ada di forecast_2025_passed, dilewati.\")\n","        continue\n","\n","    safe_col = (\n","        str(col)\n","        .replace(\"/\", \"_\")\n","        .replace(\"\\\\\", \"_\")\n","        .replace(\" \", \"_\")\n","        .replace(\":\", \"_\")\n","        .replace(\"*\", \"_\")\n","        .replace(\"?\", \"_\")\n","        .replace('\"', \"_\")\n","        .replace(\"<\", \"_\")\n","        .replace(\">\", \"_\")\n","        .replace(\"|\", \"_\")\n","    )\n","\n","    plt.figure(figsize=(10, 5))\n","\n","    plt.plot(\n","        forecast_2025_passed[\"Tanggal\"],\n","        forecast_2025_passed[col],\n","        marker=\"o\",\n","        label=\"Prediksi 2025\"\n","    )\n","\n","    plt.title(f\"Prediksi Harga Saham 2025 - {col}\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","\n","    save_path = os.path.join(\n","        plot_forecast_folder,\n","        f\"forecast_2025_{safe_col}.png\"\n","    )\n","\n","    plt.savefig(save_path, dpi=300, bbox_inches=\"tight\")\n","    plt.close()\n","\n","print(\"Plot forecast 2025 loop 1 berhasil disimpan.\")\n","\n","# ============================================================\n","# 7. SIMPAN PLOT HISTORIS 2010-2024 + FORECAST 2025\n","#    HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","for col in passed_stocks:\n","\n","    if col not in df_all.columns:\n","        print(f\"{col} tidak ada di df_all, dilewati.\")\n","        continue\n","\n","    if col not in forecast_dict:\n","        print(f\"{col} tidak ada di forecast_dict, dilewati.\")\n","        continue\n","\n","    safe_col = (\n","        str(col)\n","        .replace(\"/\", \"_\")\n","        .replace(\"\\\\\", \"_\")\n","        .replace(\" \", \"_\")\n","        .replace(\":\", \"_\")\n","        .replace(\"*\", \"_\")\n","        .replace(\"?\", \"_\")\n","        .replace('\"', \"_\")\n","        .replace(\"<\", \"_\")\n","        .replace(\">\", \"_\")\n","        .replace(\"|\", \"_\")\n","    )\n","\n","    # data historis 2010-2024\n","    hist_df = df_all[\n","        df_all[\"Tanggal\"] < \"2025-01-01\"\n","    ][[\"Tanggal\", col]].copy()\n","\n","    hist_df = hist_df.dropna().reset_index(drop=True)\n","\n","    # data forecast 2025\n","    forecast_df = pd.DataFrame({\n","        \"Tanggal\": future_dates,\n","        col: forecast_dict[col]\n","    })\n","\n","    # sambungkan titik terakhir historis ke forecast\n","    last_hist = hist_df.iloc[[-1]].copy()\n","\n","    forecast_connected = pd.concat(\n","        [last_hist, forecast_df],\n","        ignore_index=True\n","    )\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    plt.plot(\n","        hist_df[\"Tanggal\"],\n","        hist_df[col],\n","        label=\"Data Historis 2010-2024\"\n","    )\n","\n","    plt.plot(\n","        forecast_connected[\"Tanggal\"],\n","        forecast_connected[col],\n","        label=\"Prediksi 2025\"\n","    )\n","\n","    plt.axvline(\n","        x=pd.to_datetime(\"2024-12-01\"),\n","        linestyle=\":\",\n","        color=\"black\",\n","        linewidth=2,\n","        label=\"Batas Historis-Prediksi\"\n","    )\n","\n","    plt.title(f\"{col}\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","\n","    save_path = os.path.join(\n","        plot_hist_forecast_folder,\n","        f\"historis_forecast_2025_{safe_col}.png\"\n","    )\n","\n","    plt.savefig(save_path, dpi=300, bbox_inches=\"tight\")\n","    plt.close()\n","\n","print(\"Plot historis + forecast 2025 loop 1 berhasil disimpan.\")\n","\n","# ============================================================\n","# 8. RINGKASAN PENYIMPANAN LOOP 1\n","# ============================================================\n","\n","print(\"\\n=== SEMUA HASIL LOOP 1 BERHASIL DISIMPAN ===\")\n","print(\"Folder utama              :\", base_folder)\n","print(\"Excel                     :\", excel_folder)\n","print(\"Plot training + testing   :\", plot_train_test_folder)\n","print(\"Plot final training       :\", plot_final_training_folder)\n","print(\"Plot forecast 2025        :\", plot_forecast_folder)\n","print(\"Plot historis + forecast  :\", plot_hist_forecast_folder)\n","\n","print(\"\\nFile Excel:\")\n","print(excel_path)"],"metadata":{"id":"idq3OPlTwSYL"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 15. LOOP 2 - RAPIIKAN DATA\n","# ============================================================\n","harga_2010_2024_sisa = pd.read_excel(\"/content/drive/My Drive/hasil_loop1/Excel/hasil_loop1.xlsx\", sheet_name=\"data_sisa\")\n","# copy data agar aman\n","harga_df2 = harga_2010_2024_sisa.copy()\n","pc_df2 = pc_all.copy()\n","\n","# ubah kolom tanggal ke format datetime\n","harga_df2[\"Tanggal\"] = pd.to_datetime(harga_df2[\"Tanggal\"])\n","pc_df2[\"Tanggal\"] = pd.to_datetime(pc_df2[\"Tanggal\"])\n","\n","# urutkan berdasarkan tanggal\n","harga_df2 = harga_df2.sort_values(\"Tanggal\").reset_index(drop=True)\n","pc_df2 = pc_df2.sort_values(\"Tanggal\").reset_index(drop=True)\n","\n","# cek nama kolom\n","print(\"Kolom harga loop 2:\")\n","print(harga_df2.columns)\n","\n","print(\"\\nKolom PC loop 2:\")\n","print(pc_df2.columns)\n","\n","# pilih kolom PC\n","pc_cols = [\"PC1\", \"PC2\", \"PC3\"]\n","\n","# pastikan PC numerik\n","for col in pc_cols:\n","    pc_df2[col] = pd.to_numeric(pc_df2[col], errors=\"coerce\")\n","\n","# semua kolom saham sisa loop 2\n","stock_cols2 = [col for col in harga_df2.columns if col != \"Tanggal\"]\n","\n","# pastikan harga saham numerik\n","for col in stock_cols2:\n","    harga_df2[col] = pd.to_numeric(harga_df2[col], errors=\"coerce\")\n","\n","# gabungkan data saham + PC\n","df_all2 = pd.merge(\n","    harga_df2,\n","    pc_df2[[\"Tanggal\"] + pc_cols],\n","    on=\"Tanggal\",\n","    how=\"inner\"\n",")\n","\n","# hapus missing value penting\n","df_all2 = df_all2.dropna(subset=[\"Tanggal\"] + pc_cols).reset_index(drop=True)\n","\n","# lihat data akhir\n","print(\"\\nData gabungan loop 2:\")\n","print(df_all2.head())\n","print(df_all2.tail())\n","print(df_all2.shape)\n","print(\"Jumlah saham loop 2:\", len(stock_cols2))"],"metadata":{"id":"j7ZfvN0GNqh4","colab":{"b