= [col for col in harga_df7.columns if col != \"Tanggal\"]\n","\n","# pastikan harga saham numerik\n","for col in stock_cols7:\n","    harga_df7[col] = pd.to_numeric(harga_df7[col], errors=\"coerce\")\n","\n","# gabungkan data saham + PC\n","df_all7 = pd.merge(\n","    harga_df7,\n","    pc_df7[[\"Tanggal\"] + pc_cols],\n","    on=\"Tanggal\",\n","    how=\"inner\"\n",")\n","\n","# hapus missing value penting\n","df_all7 = df_all7.dropna(subset=[\"Tanggal\"] + pc_cols).reset_index(drop=True)\n","\n","# lihat data akhir\n","print(\"\\nData gabungan loop 7:\")\n","print(df_all7.head())\n","print(df_all7.tail())\n","print(df_all7.shape)\n","print(\"Jumlah saham loop 7:\", len(stock_cols7))"],"metadata":{"id":"qs3fUGDgEJ6D"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 71. LOOP 7 - TRAIN + TEST + RETRAIN FINAL + FORECAST 2025\n","#     UNTUK SETIAP SAHAM SISA\n","# ============================================================\n","\n","look_back7 = 10\n","test_size7 = 12\n","epochs7 = 200\n","batch_size7 = 1\n","\n","forecast_dict7 = {}\n","\n","# evaluasi model awal\n","eval_train_results7 = []\n","eval_test_results7 = []\n","\n","# evaluasi model final\n","eval_final_train_results7 = []\n","\n","history_dict7 = {}\n","model_dict7 = {}\n","scaler_X_dict7 = {}\n","scaler_y_dict7 = {}\n","\n","train_plot_dict7 = {}\n","test_plot_dict7 = {}\n","final_train_plot_dict7 = {}\n","\n","# tanggal forecast 2025\n","future_dates7 = pd.date_range(start=\"2025-01-01\", periods=12, freq=\"MS\")\n","\n","for col in stock_cols7:\n","    print(\"=\"*70)\n","    print(f\"Proses saham loop 7: {col}\")\n","\n","    # --------------------------------------------------------\n","    # ambil data 1 saham + PC\n","    # --------------------------------------------------------\n","    series_df7 = df_all7[[\"Tanggal\", col] + pc_cols].copy()\n","    series_df7 = series_df7.dropna().reset_index(drop=True)\n","\n","    # cek minimal data\n","    if len(series_df7) <= (look_back7 + test_size7):\n","        print(f\"Data {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # --------------------------------------------------------\n","    # pisahkan data historis sampai 2024\n","    # --------------------------------------------------------\n","    hist_df7 = series_df7[\n","        series_df7[\"Tanggal\"] < \"2025-01-01\"\n","    ].copy().reset_index(drop=True)\n","\n","    # target saham\n","    target_values7 = hist_df7[[col]].values.astype(float)\n","\n","    # fitur multivariat = [harga saham, PC1, PC2, PC3]\n","    feature_values7 = hist_df7[[col] + pc_cols].values.astype(float)\n","\n","    # --------------------------------------------------------\n","    # split data:\n","    # train awal = 2010-2023\n","    # test       = 2024\n","    # --------------------------------------------------------\n","    train_target7 = target_values7[:-test_size7]\n","    test_target7  = target_values7[-test_size7:]\n","\n","    train_features7 = feature_values7[:-test_size7]\n","    test_features7  = feature_values7[-test_size7:]\n","\n","    # --------------------------------------------------------\n","    # scaling\n","    # scaler fitur fit hanya pada training\n","    # scaler target fit hanya pada training\n","    # --------------------------------------------------------\n","    scaler_X_train7 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_train7 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaler_X_train7.fit(train_features7)\n","    scaler_y_train7.fit(train_target7)\n","\n","    scaled_all_X7 = scaler_X_train7.transform(feature_values7)\n","    scaled_all_y7 = scaler_y_train7.transform(target_values7).flatten()\n","\n","    scaler_X_dict7[f\"{col}_train\"] = scaler_X_train7\n","    scaler_y_dict7[f\"{col}_train\"] = scaler_y_train7\n","\n","    # --------------------------------------------------------\n","    # buat sequence untuk evaluasi model awal\n","    # --------------------------------------------------------\n","    X_all7, y_all7 = create_multivariate_sequences(\n","        data_array=scaled_all_X7,\n","        target_array=scaled_all_y7,\n","        look_back=look_back7\n","    )\n","\n","    if len(X_all7) <= test_size7:\n","        print(f\"Sequence {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # sequence training dan testing\n","    X_train7 = X_all7[:-test_size7]\n","    y_train7 = y_all7[:-test_size7]\n","\n","    X_test7 = X_all7[-test_size7:]\n","    y_test7 = y_all7[-test_size7:]\n","\n","    print(\"Shape X_train7:\", X_train7.shape)\n","    print(\"Shape X_test7 :\", X_test7.shape)\n","\n","    # --------------------------------------------------------\n","    # bangun model evaluasi\n","    # --------------------------------------------------------\n","    model7 = build_lstm_model(\n","        look_back=look_back7,\n","        n_features=X_train7.shape[2]\n","    )\n","\n","    early_stop7 = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    # --------------------------------------------------------\n","    # training model evaluasi\n","    # --------------------------------------------------------\n","    history7 = model7.fit(\n","        X_train7,\n","        y_train7,\n","        validation_data=(X_test7, y_test7),\n","        epochs=epochs7,\n","        batch_size=batch_size7,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop7]\n","    )\n","\n","    history_dict7[f\"{col}_eval\"] = history7\n","    model_dict7[f\"{col}_eval\"] = model7\n","\n","    # ========================================================\n","    # A. EVALUASI TRAINING (MODEL 2010-2023)\n","    # ========================================================\n","    y_pred_train_scaled7 = model7.predict(X_train7, verbose=0)\n","\n","    y_train_actual7 = scaler_y_train7.inverse_transform(\n","        y_train7.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_train_actual7 = scaler_y_train7.inverse_transform(\n","        y_pred_train_scaled7\n","    ).flatten()\n","\n","    train_dates7 = hist_df7[\"Tanggal\"].iloc[\n","        look_back7:len(hist_df7)-test_size7\n","    ].reset_index(drop=True)\n","\n","    train_plot_dict7[col] = pd.DataFrame({\n","        \"Tanggal\": train_dates7,\n","        \"Aktual\": y_train_actual7,\n","        \"Prediksi\": y_pred_train_actual7\n","    })\n","\n","    metrics_train7 = calculate_metrics(y_train_actual7, y_pred_train_actual7)\n","\n","    eval_train_results7.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_train7[\"MAE\"],\n","        \"RMSE\": metrics_train7[\"RMSE\"],\n","        \"MAPE\": metrics_train7[\"MAPE\"],\n","        \"sMAPE\": metrics_train7[\"sMAPE\"],\n","        \"R2\": metrics_train7[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # B. EVALUASI TESTING (2024)\n","    # ========================================================\n","    y_pred_test_scaled7 = model7.predict(X_test7, verbose=0)\n","\n","    y_test_actual7 = scaler_y_train7.inverse_transform(\n","        y_test7.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_test_actual7 = scaler_y_train7.inverse_transform(\n","        y_pred_test_scaled7\n","    ).flatten()\n","\n","    test_dates7 = hist_df7[\"Tanggal\"].iloc[-test_size7:].reset_index(drop=True)\n","\n","    test_plot_dict7[col] = pd.DataFrame({\n","        \"Tanggal\": test_dates7,\n","        \"Aktual\": y_test_actual7,\n","        \"Prediksi\": y_pred_test_actual7\n","    })\n","\n","    metrics_test7 = calculate_metrics(y_test_actual7, y_pred_test_actual7)\n","\n","    eval_test_results7.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_test7[\"MAE\"],\n","        \"RMSE\": metrics_test7[\"RMSE\"],\n","        \"MAPE\": metrics_test7[\"MAPE\"],\n","        \"sMAPE\": metrics_test7[\"sMAPE\"],\n","        \"R2\": metrics_test7[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # C. RETRAIN MODEL FINAL DENGAN DATA 2010-2024\n","    # ========================================================\n","    scaler_X_full7 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_full7 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaled_full_X7 = scaler_X_full7.fit_transform(feature_values7)\n","    scaled_full_y7 = scaler_y_full7.fit_transform(target_values7).flatten()\n","\n","    scaler_X_dict7[f\"{col}_full\"] = scaler_X_full7\n","    scaler_y_dict7[f\"{col}_full\"] = scaler_y_full7\n","\n","    X_full7, y_full7 = create_multivariate_sequences(\n","        data_array=scaled_full_X7,\n","        target_array=scaled_full_y7,\n","        look_back=look_back7\n","    )\n","\n","    model_final7 = build_lstm_model(\n","        look_back=look_back7,\n","        n_features=X_full7.shape[2]\n","    )\n","\n","    early_stop_final7 = EarlyStopping(\n","        monitor=\"loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history_final7 = model_final7.fit(\n","        X_full7,\n","        y_full7,\n","        epochs=epochs7,\n","        batch_size=batch_size7,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop_final7]\n","    )\n","\n","    history_dict7[f\"{col}_final\"] = history_final7\n","    model_dict7[f\"{col}_final\"] = model_final7\n","\n","    # ========================================================\n","    # D. EVALUASI TRAINING MODEL FINAL (2010-2024)\n","    # ========================================================\n","    y_pred_full_scaled7 = model_final7.predict(X_full7, verbose=0)\n","\n","    y_full_actual7 = scaler_y_full7.inverse_transform(\n","        y_full7.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_full_actual7 = scaler_y_full7.inverse_transform(\n","        y_pred_full_scaled7\n","    ).flatten()\n","\n","    full_train_dates7 = hist_df7[\"Tanggal\"].iloc[look_back7:].reset_index(drop=True)\n","\n","    final_train_plot_dict7[col] = pd.DataFrame({\n","        \"Tanggal\": full_train_dates7,\n","        \"Aktual\": y_full_actual7,\n","        \"Prediksi\": y_pred_full_actual7\n","    })\n","\n","    metrics_final_train7 = calculate_metrics(y_full_actual7, y_pred_full_actual7)\n","\n","    eval_final_train_results7.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_final_train7[\"MAE\"],\n","        \"RMSE\": metrics_final_train7[\"RMSE\"],\n","        \"MAPE\": metrics_final_train7[\"MAPE\"],\n","        \"sMAPE\": metrics_final_train7[\"sMAPE\"],\n","        \"R2\": metrics_final_train7[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # E. FORECAST 2025\n","    # ========================================================\n","    future_pc_df7 = pc_df7[\n","        (pc_df7[\"Tanggal\"] >= \"2025-01-01\") &\n","        (pc_df7[\"Tanggal\"] <= \"2025-12-01\")\n","    ].copy().reset_index(drop=True)\n","\n","    if len(future_pc_df7) < 12:\n","        print(f\"PC tahun 2025 untuk {col} tidak lengkap, forecast dilewati.\")\n","        continue\n","\n","    future_pc_values7 = future_pc_df7[pc_cols].values.astype(float)\n","\n","    # ambil window terakhir dari data 2010-2024 yang sudah di-scale\n","    rolling_window7 = scaled_full_X7[-look_back7:, :].copy()\n","    future_preds_scaled7 = []\n","\n","    for step in range(12):\n","        x_input7 = rolling_window7.reshape(1, look_back7, scaled_full_X7.shape[1])\n","\n","        # prediksi target saham\n","        next_pred_scaled7 = model_final7.predict(x_input7, verbose=0)[0, 0]\n","        future_preds_scaled7.append(next_pred_scaled7)\n","\n","        # ubah prediksi target ke skala asli dulu\n","        next_pred_actual7 = scaler_y_full7.inverse_transform(\n","            np.array([[next_pred_scaled7]])\n","        ).flatten(