set_index(drop=True)\n","pc_df6 = pc_df6.sort_values(\"Tanggal\").reset_index(drop=True)\n","\n","# cek nama kolom\n","print(\"Kolom harga loop 6:\")\n","print(harga_df6.columns)\n","\n","print(\"\\nKolom PC loop 6:\")\n","print(pc_df6.columns)\n","\n","# pilih kolom PC\n","pc_cols = [\"PC1\", \"PC2\", \"PC3\"]\n","\n","# pastikan PC numerik\n","for col in pc_cols:\n","    pc_df6[col] = pd.to_numeric(pc_df6[col], errors=\"coerce\")\n","\n","# semua kolom saham sisa loop 6\n","stock_cols6 = [col for col in harga_df6.columns if col != \"Tanggal\"]\n","\n","# pastikan harga saham numerik\n","for col in stock_cols6:\n","    harga_df6[col] = pd.to_numeric(harga_df6[col], errors=\"coerce\")\n","\n","# gabungkan data saham + PC\n","df_all6 = pd.merge(\n","    harga_df6,\n","    pc_df6[[\"Tanggal\"] + pc_cols],\n","    on=\"Tanggal\",\n","    how=\"inner\"\n",")\n","\n","# hapus missing value penting\n","df_all6 = df_all6.dropna(subset=[\"Tanggal\"] + pc_cols).reset_index(drop=True)\n","\n","# lihat data akhir\n","print(\"\\nData gabungan loop 6:\")\n","print(df_all6.head())\n","print(df_all6.tail())\n","print(df_all6.shape)\n","print(\"Jumlah saham loop 6:\", len(stock_cols6))"],"metadata":{"id":"dHuQ-VOhDmmZ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 60. LOOP 6 - TRAIN + TEST + RETRAIN FINAL + FORECAST 2025\n","#     UNTUK SETIAP SAHAM SISA\n","# ============================================================\n","\n","look_back6 = 9\n","test_size6 = 12\n","epochs6 = 200\n","batch_size6 = 1\n","\n","forecast_dict6 = {}\n","\n","# evaluasi model awal\n","eval_train_results6 = []\n","eval_test_results6 = []\n","\n","# evaluasi model final\n","eval_final_train_results6 = []\n","\n","history_dict6 = {}\n","model_dict6 = {}\n","scaler_X_dict6 = {}\n","scaler_y_dict6 = {}\n","\n","train_plot_dict6 = {}\n","test_plot_dict6 = {}\n","final_train_plot_dict6 = {}\n","\n","# tanggal forecast 2025\n","future_dates6 = pd.date_range(start=\"2025-01-01\", periods=12, freq=\"MS\")\n","\n","for col in stock_cols6:\n","    print(\"=\"*70)\n","    print(f\"Proses saham loop 6: {col}\")\n","\n","    # --------------------------------------------------------\n","    # ambil data 1 saham + PC\n","    # --------------------------------------------------------\n","    series_df6 = df_all6[[\"Tanggal\", col] + pc_cols].copy()\n","    series_df6 = series_df6.dropna().reset_index(drop=True)\n","\n","    # cek minimal data\n","    if len(series_df6) <= (look_back6 + test_size6):\n","        print(f\"Data {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # --------------------------------------------------------\n","    # pisahkan data historis sampai 2024\n","    # --------------------------------------------------------\n","    hist_df6 = series_df6[\n","        series_df6[\"Tanggal\"] < \"2025-01-01\"\n","    ].copy().reset_index(drop=True)\n","\n","    # target saham\n","    target_values6 = hist_df6[[col]].values.astype(float)\n","\n","    # fitur multivariat = [harga saham, PC1, PC2, PC3]\n","    feature_values6 = hist_df6[[col] + pc_cols].values.astype(float)\n","\n","    # --------------------------------------------------------\n","    # split data:\n","    # train awal = 2010-2023\n","    # test       = 2024\n","    # --------------------------------------------------------\n","    train_target6 = target_values6[:-test_size6]\n","    test_target6  = target_values6[-test_size6:]\n","\n","    train_features6 = feature_values6[:-test_size6]\n","    test_features6  = feature_values6[-test_size6:]\n","\n","    # --------------------------------------------------------\n","    # scaling\n","    # scaler fitur fit hanya pada training\n","    # scaler target fit hanya pada training\n","    # --------------------------------------------------------\n","    scaler_X_train6 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_train6 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaler_X_train6.fit(train_features6)\n","    scaler_y_train6.fit(train_target6)\n","\n","    scaled_all_X6 = scaler_X_train6.transform(feature_values6)\n","    scaled_all_y6 = scaler_y_train6.transform(target_values6).flatten()\n","\n","    scaler_X_dict6[f\"{col}_train\"] = scaler_X_train6\n","    scaler_y_dict6[f\"{col}_train\"] = scaler_y_train6\n","\n","    # --------------------------------------------------------\n","    # buat sequence untuk evaluasi model awal\n","    # --------------------------------------------------------\n","    X_all6, y_all6 = create_multivariate_sequences(\n","        data_array=scaled_all_X6,\n","        target_array=scaled_all_y6,\n","        look_back=look_back6\n","    )\n","\n","    if len(X_all6) <= test_size6:\n","        print(f\"Sequence {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # sequence training dan testing\n","    X_train6 = X_all6[:-test_size6]\n","    y_train6 = y_all6[:-test_size6]\n","\n","    X_test6 = X_all6[-test_size6:]\n","    y_test6 = y_all6[-test_size6:]\n","\n","    print(\"Shape X_train6:\", X_train6.shape)\n","    print(\"Shape X_test6 :\", X_test6.shape)\n","\n","    # --------------------------------------------------------\n","    # bangun model evaluasi\n","    # --------------------------------------------------------\n","    model6 = build_lstm_model(\n","        look_back=look_back6,\n","        n_features=X_train6.shape[2]\n","    )\n","\n","    early_stop6 = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    # --------------------------------------------------------\n","    # training model evaluasi\n","    # --------------------------------------------------------\n","    history6 = model6.fit(\n","        X_train6,\n","        y_train6,\n","        validation_data=(X_test6, y_test6),\n","        epochs=epochs6,\n","        batch_size=batch_size6,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop6]\n","    )\n","\n","    history_dict6[f\"{col}_eval\"] = history6\n","    model_dict6[f\"{col}_eval\"] = model6\n","\n","    # ========================================================\n","    # A. EVALUASI TRAINING (MODEL 2010-2023)\n","    # ========================================================\n","    y_pred_train_scaled6 = model6.predict(X_train6, verbose=0)\n","\n","    y_train_actual6 = scaler_y_train6.inverse_transform(\n","        y_train6.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_train_actual6 = scaler_y_train6.inverse_transform(\n","        y_pred_train_scaled6\n","    ).flatten()\n","\n","    train_dates6 = hist_df6[\"Tanggal\"].iloc[\n","        look_back6:len(hist_df6)-test_size6\n","    ].reset_index(drop=True)\n","\n","    train_plot_dict6[col] = pd.DataFrame({\n","        \"Tanggal\": train_dates6,\n","        \"Aktual\": y_train_actual6,\n","        \"Prediksi\": y_pred_train_actual6\n","    })\n","\n","    metrics_train6 = calculate_metrics(y_train_actual6, y_pred_train_actual6)\n","\n","    eval_train_results6.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_train6[\"MAE\"],\n","        \"RMSE\": metrics_train6[\"RMSE\"],\n","        \"MAPE\": metrics_train6[\"MAPE\"],\n","        \"sMAPE\": metrics_train6[\"sMAPE\"],\n","        \"R2\": metrics_train6[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # B. EVALUASI TESTING (2024)\n","    # ========================================================\n","    y_pred_test_scaled6 = model6.predict(X_test6, verbose=0)\n","\n","    y_test_actual6 = scaler_y_train6.inverse_transform(\n","        y_test6.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_test_actual6 = scaler_y_train6.inverse_transform(\n","        y_pred_test_scaled6\n","    ).flatten()\n","\n","    test_dates6 = hist_df6[\"Tanggal\"].iloc[-test_size6:].reset_index(drop=True)\n","\n","    test_plot_dict6[col] = pd.DataFrame({\n","        \"Tanggal\": test_dates6,\n","        \"Aktual\": y_test_actual6,\n","        \"Prediksi\": y_pred_test_actual6\n","    })\n","\n","    metrics_test6 = calculate_metrics(y_test_actual6, y_pred_test_actual6)\n","\n","    eval_test_results6.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_test6[\"MAE\"],\n","        \"RMSE\": metrics_test6[\"RMSE\"],\n","        \"MAPE\": metrics_test6[\"MAPE\"],\n","        \"sMAPE\": metrics_test6[\"sMAPE\"],\n","        \"R2\": metrics_test6[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # C. RETRAIN MODEL FINAL DENGAN DATA 2010-2024\n","    # ========================================================\n","    scaler_X_full6 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_full6 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaled_full_X6 = scaler_X_full6.fit_transform(feature_values6)\n","    scaled_full_y6 = scaler_y_full6.fit_transform(target_values6).flatten()\n","\n","    scaler_X_dict6[f\"{col}_full\"] = scaler_X_full6\n","    scaler_y_dict6[f\"{col}_full\"] = scaler_y_full6\n","\n","    X_full6, y_full6 = create_multivariate_sequences(\n","        data_array=scaled_full_X6,\n","        target_array=scaled_full_y6,\n","        look_back=look_back6\n","    )\n","\n","    model_final6 = build_lstm_model(\n","        look_back=look_back6,\n","        n_features=X_full6.shape[2]\n","    )\n","\n","    early_stop_final6 = EarlyStopping(\n","        monitor=\"loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history_final6 = model_final6.fit(\n","        X_full6,\n","        y_full6,\n","        epochs=epochs6,\n","        batch_size=batch_size6,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop_final6]\n","    )\n","\n","    history_dict6[f\"{col}_final\"] = history_final6\n","    model_dict6[f\"{col}_final\"] = model_fina