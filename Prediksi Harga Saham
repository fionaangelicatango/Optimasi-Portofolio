 i in range(look_back, len(data_array)):\n","        X.append(data_array[i-look_back:i, :])\n","        y.append(target_array[i])\n","\n","    X = np.array(X)\n","    y = np.array(y)\n","\n","    return X, y"],"metadata":{"id":"Yod6FsztNZz-"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 4. FUNGSI MEMBUAT MODEL LSTM\n","# ============================================================\n","\n","def build_lstm_model(look_back, n_features=4):\n","    model = Sequential()\n","\n","    # layer LSTM pertama\n","    model.add(\n","        LSTM(\n","            64,\n","            activation=\"tanh\",\n","            return_sequences=False,\n","            input_shape=(look_back, n_features)\n","        )\n","    )\n","\n","    model.add(Dropout(0.2))\n","\n","    # output layer\n","    model.add(Dense(1))\n","\n","    model.compile(\n","        optimizer=Adam(learning_rate=0.001),\n","        loss=\"mse\"\n","    )\n","\n","    return model"],"metadata":{"id":"KQee9n0INbL3"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 5. FUNGSI MENGHITUNG METRIK\n","# ============================================================\n","\n","def calculate_metrics(y_actual, y_pred):\n","    mae = mean_absolute_error(y_actual, y_pred)\n","    rmse = np.sqrt(mean_squared_error(y_actual, y_pred))\n","\n","    mape = np.mean(\n","        np.where(\n","            y_actual != 0,\n","            np.abs((y_actual - y_pred) / y_actual),\n","            np.nan\n","        )\n","    ) * 100\n","\n","    smape = np.mean(\n","        2 * np.abs(y_pred - y_actual) /\n","        (np.abs(y_actual) + np.abs(y_pred) + 1e-8)\n","    ) * 100\n","\n","    r2 = r2_score(y_actual, y_pred)\n","\n","    return {\n","        \"MAE\": mae,\n","        \"RMSE\": rmse,\n","        \"MAPE\": mape,\n","        \"sMAPE\": smape,\n","        \"R2\": r2,\n","    }"],"metadata":{"id":"1hxHLDvYNcNX"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# 6. TRAIN + TEST + RETRAIN FINAL + FORECAST 2025\n","#    UNTUK SETIAP SAHAM\n","# ============================================================\n","\n","look_back = 4\n","test_size = 12              # 12 bulan terakhir untuk testing (tahun 2024)\n","epochs = 200\n","batch_size = 1\n","\n","forecast_dict = {}\n","\n","# evaluasi model awal\n","eval_train_results = []\n","eval_test_results = []\n","\n","# evaluasi model final\n","eval_final_train_results = []\n","\n","history_dict = {}\n","model_dict = {}\n","scaler_X_dict = {}\n","scaler_y_dict = {}\n","\n","train_plot_dict = {}\n","test_plot_dict = {}\n","final_train_plot_dict = {}\n","\n","# tanggal forecast 2025\n","future_dates = pd.date_range(start=\"2025-01-01\", periods=12, freq=\"MS\")\n","\n","for col in stock_cols:\n","    print(\"=\"*70)\n","    print(f\"Proses saham: {col}\")\n","\n","    # --------------------------------------------------------\n","    # ambil data 1 saham + PC\n","    # --------------------------------------------------------\n","    series_df = df_all[[\"Tanggal\", col] + pc_cols].copy()\n","    series_df = series_df.dropna().reset_index(drop=True)\n","\n","    # cek minimal data\n","    if len(series_df) <= (look_back + test_size):\n","        print(f\"Data {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # --------------------------------------------------------\n","    # pisahkan data historis sampai 2024\n","    # --------------------------------------------------------\n","    hist_df = series_df[series_df[\"Tanggal\"] < \"2025-01-01\"].copy().reset_index(drop=True)\n","\n","    # target saham\n","    target_values = hist_df[[col]].values.astype(float)\n","\n","    # fitur multivariat = [return saham, PC1, PC2, PC3]\n","    feature_values = hist_df[[col] + pc_cols].values.astype(float)\n","\n","    # --------------------------------------------------------\n","    # split data:\n","    # train awal = 2010-2023\n","    # test       = 2024\n","    # --------------------------------------------------------\n","    train_target = target_values[:-test_size]\n","    test_target  = target_values[-test_size:]\n","\n","    train_features = feature_values[:-test_size]\n","    test_features  = feature_values[-test_size:]\n","\n","    # --------------------------------------------------------\n","    # scaling\n","    # scaler fitur fit hanya pada training\n","    # scaler target fit hanya pada training\n","    # --------------------------------------------------------\n","    scaler_X_train = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_train = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaler_X_train.fit(train_features)\n","    scaler_y_train.fit(train_target)\n","\n","    scaled_all_X = scaler_X_train.transform(feature_values)\n","    scaled_all_y = scaler_y_train.transform(target_values).flatten()\n","\n","    scaler_X_dict[f\"{col}_train\"] = scaler_X_train\n","    scaler_y_dict[f\"{col}_train\"] = scaler_y_train\n","\n","    # --------------------------------------------------------\n","    # buat sequence untuk evaluasi model awal\n","    # --------------------------------------------------------\n","    X_all, y_all = create_multivariate_sequences(\n","        data_array=scaled_all_X,\n","        target_array=scaled_all_y,\n","        look_back=look_back\n","    )\n","\n","    if len(X_all) <= test_size:\n","        print(f\"Sequence {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # sequence training dan testing\n","    X_train = X_all[:-test_size]\n","    y_train = y_all[:-test_size]\n","\n","    X_test = X_all[-test_size:]\n","    y_test = y_all[-test_size:]\n","\n","    print(\"Shape X_train:\", X_train.shape)\n","    print(\"Shape X_test :\", X_test.shape)\n","\n","    # --------------------------------------------------------\n","    # bangun model evaluasi\n","    # --------------------------------------------------------\n","    model = build_lstm_model(\n","        look_back=look_back,\n","        n_features=X_train.shape[2]\n","    )\n","\n","    early_stop = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    # --------------------------------------------------------\n","    # training model evaluasi\n","    # --------------------------------------------------------\n","    history = model.fit(\n","        X_train, y_train,\n","        validation_data=(X_test, y_test),\n","        epochs=epochs,\n","        batch_size=batch_size,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop]\n","    )\n","\n","    history_dict[f\"{col}_eval\"] = history\n","    model_dict[f\"{col}_eval\"] = model\n","\n","    # ========================================================\n","    # A. EVALUASI TRAINING (MODEL 2010-2023)\n","    # ========================================================\n","    y_pred_train_scaled = model.predict(X_train, verbose=0)\n","\n","    y_train_actual = scaler_y_train.inverse_transform(y_train.reshape(-1, 1)).flatten()\n","    y_pred_train_actual = scaler_y_train.inverse_transform(y_pred_train_scaled).flatten()\n","\n","    train_dates = hist_df[\"Tanggal\"].iloc[look_back:len(hist_df)-test_size].reset_index(drop=True)\n","\n","    train_plot_dict[col] = pd.DataFrame({\n","        \"Tanggal\": train_dates,\n","        \"Aktual\": y_train_actual,\n","        \"Prediksi\": y_pred_train_actual\n","    })\n","\n","    metrics_train = calculate_metrics(y_train_actual, y_pred_train_actual)\n","\n","    eval_train_results.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_train[\"MAE\"],\n","        \"RMSE\": metrics_train[\"RMSE\"],\n","        \"MAPE\": metrics_train[\"MAPE\"],\n","        \"sMAPE\": metrics_train[\"sMAPE\"],\n","        \"R2\": metrics_train[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # B. EVALUASI TESTING (2024)\n","    # ========================================================\n","    y_pred_test_scaled = model.predict(X_test, verbose=0)\n","\n","    y_test_actual = scaler_y_train.inverse_transform(y_test.reshape(-1, 1)).flatten()\n","    y_pred_test_actual = scaler_y_train.inverse_transform(y_pred_test_scaled).flatten()\n","\n","    test_dates = hist_df[\"Tanggal\"].iloc[-test_size:].reset_index(drop=True)\n","\n","    test_plot_dict[col] = pd.DataFrame({\n","        \"Tanggal\": test_dates,\n","        \"Aktual\": y_test_actual,\n","        \"Prediksi\": y_pred_test_actual\n","    })\n","\n","    metrics_test = calculate_metrics(y_test_actual, y_pred_test_actual)\n","\n","    eval_test_results.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_test[\"MAE\"],\n","        \"RMSE\": metrics_test[\"RMSE\"],\n","        \"MAPE\": metrics_test[\"MAPE\"],\n","        \"sMAPE\": metrics_test[\"sMAPE\"],\n","        \"R2\": metrics_test[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # C. RETRAIN MODEL FINAL DENGAN DATA 2010-2024\n","    # ========================================================\n","    scaler_X_full = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_full = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaled_full_X = scaler_X_full.fit_transform(feature_values)\n","    scaled_full_y = scaler_y_full.fit_transform(target_values).flatten()\n","\n","    scaler_X_dict[f\"{col}_full\"] = scaler_X_full\n","    scaler_y_dict[f\"{col}_full\"] = scaler_y_full\n","\n","    X_full, y_full = create_multivariate_sequences(\n","        data_array=scaled_full_X,\n","        target_array=scaled_full_y,\n","        look_back=look_back\n","    )\n","\n","    model_final = build_lstm_model(\n","        look_back=look_back,\n","        n_features=X_full.shape[2]\n","    )\n","\n","    early_stop_final = EarlyStopping(\n","        monitor=\"loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history_final = model_final.fit(\n","        X_full, y_full,\n","        epochs=epochs,\n","        batch_size=batch_size,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop_final]\n","    )\n","\n","    history_dict[f\"{col}_final\"] = history_final\n","    model_dict[f\"{col}_final\"] = model_final\n","\n","    # ========================================================\n","    # D. EVALUASI TRAINING MODEL FINAL (2010-2024)\n","    # ========================================================\n","    y_pred_full_scaled = model_final.predict(X_full, verbose=0)\n","\n","    y_full_actual = scaler_y_full.inverse_transform(y_full.reshape(-1, 1)).flatten()\n","    y_pred_full_actual = scaler_y_full.inverse_transform(y_pred_full_scaled).flatten()\n","\n","    full_train_dates = hist_df[\"Tanggal\"].iloc[look_back:].reset_index(drop=True)\n","\n","    final_train_plot_dict[col] = pd.DataFrame({\n","        \"Tanggal\": full_train_dates,\n","        \"Aktual\": y_full_actual,\n","        \"Prediksi\": y_pred_full_actual\n","    })\n","\n","    metrics_final_train = calculate_metrics(y_full_actual, y_pred_full_actual)\n","\n","    eval_final_train_results.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_final_train[\"MAE\"],\n","        \"RMSE\": metrics_final_train[\"RMSE\"],\n","        \"MAPE\": metrics_final_train[\"MAPE\"],\n","        \"sMAPE\": metrics_final_train[\"sMAPE\"],\n","        \"R2\": metrics_final_train[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # E. FORECAST 2025\n","    # ========================================================\n","    future_pc_df = pc_df[\n","        (pc_df[\"Tanggal\"] >= \"2025-01-01\") &\n","        (pc_df[\"Tanggal\"] <= \"2025-12-01\")\n","    ].copy().reset_index(drop=True)\n","\n","    if len(future_pc_df) < 12:\n","        print(f\"PC tahun 2025 untuk {col} tidak lengkap, forecast dilewati.\")\n","        continue\n","\n","    future_pc_values = future_pc_df[pc_cols].values.astype(float)\n","\n","    # ambil window terakhir dari data 2010-2024 yang sudah di-scale\n","    rolling_window = scaled_full_X[-look_back:, :].copy()\n","    future_preds_scaled = []\n","\n","    for step in range(12):\n","        x_input = rolling_window.reshape(1, look_back, scaled_full_X.shape[1])\n","\n","        # prediksi target saham\n","        next_pred_scaled = model_final.predict(x_input, verbose=0)[0, 0]\n","        future_preds_scaled.append(next_pred_scaled)\n","\n","        # ubah prediksi target ke skala asli dulu\n","        next_pred_actual = scaler_y_full.inverse_transform(\n","            np.array([[next_pred_scaled]])\n","        ).flatten()[0]\n","\n","        # gabungkan dengan PC periode 2025 pada bulan ke-step\n","        next_row_raw = np.array([\n","            next_pred_actual,\n","            future_pc_values[step, 0],\n","            future_pc_values[step, 1],\n","            future_pc_values[step, 2]\n","        ]).reshape(1, -1)\n","\n","        # scale lagi ke skala fitur\n","        next_row_scaled = scaler_X_full.transform(next_row_raw)\n","\n","        # update rolling window\n","        rolling_window = np.vstack([rolling_window[1:], next_row_scaled])\n","\n","    future_preds_scaled = np.array(future_preds_scaled).reshape(-1, 1)\n","    future_preds_actual = scaler_y_full.inverse_transform(future_preds_scaled).flatten()\n","\n","    forecast_dict[col] = future_preds_actual\n","\n","print(\"Selesai semua saham.\")"],"metadata":{"id":"90NtqT3HNda0","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1777774787755,"user_tz":-420,"elapsed":8700508,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"d9679162-bf05-4279-f87