","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","\n","    save_path8 = os.path.join(\n","        plot_hist_forecast_folder8,\n","        f\"historis_forecast_2025_{safe_col8}.png\"\n","    )\n","\n","    plt.savefig(save_path8, dpi=300, bbox_inches=\"tight\")\n","    plt.close()\n","\n","print(\"Plot historis + forecast 2025 loop 8 berhasil disimpan.\")\n","\n","# ============================================================\n","# 91.9 RINGKASAN PENYIMPANAN LOOP 8\n","# ============================================================\n","\n","print(\"\\n=== SEMUA HASIL LOOP 8 BERHASIL DISIMPAN ===\")\n","print(\"Folder utama              :\", base_folder8)\n","print(\"Excel                     :\", excel_folder8)\n","print(\"Plot training + testing   :\", plot_train_test_folder8)\n","print(\"Plot final training       :\", plot_final_training_folder8)\n","print(\"Plot forecast 2025        :\", plot_forecast_folder8)\n","print(\"Plot historis + forecast  :\", plot_hist_forecast_folder8)\n","\n","print(\"\\nFile Excel:\")\n","print(excel_path8)"],"metadata":{"id":"09bmjTk1FUcs"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# LOOP 9\n","# INPUT: harga_2010_2024_sisa8\n","# ============================================================\n","\n","\n","# ============================================================\n","# 92. LOOP 9 - RAPIIKAN DATA\n","# ============================================================\n","\n","# copy data agar aman\n","harga_df9 = harga_2010_2024_sisa8.copy()\n","pc_df9 = pc_all.copy()\n","\n","# ubah kolom tanggal ke format datetime\n","harga_df9[\"Tanggal\"] = pd.to_datetime(harga_df9[\"Tanggal\"])\n","pc_df9[\"Tanggal\"] = pd.to_datetime(pc_df9[\"Tanggal\"])\n","\n","# urutkan berdasarkan tanggal\n","harga_df9 = harga_df9.sort_values(\"Tanggal\").reset_index(drop=True)\n","pc_df9 = pc_df9.sort_values(\"Tanggal\").reset_index(drop=True)\n","\n","# cek nama kolom\n","print(\"Kolom harga loop 9:\")\n","print(harga_df9.columns)\n","\n","print(\"\\nKolom PC loop 9:\")\n","print(pc_df9.columns)\n","\n","# pilih kolom PC\n","pc_cols = [\"PC1\", \"PC2\", \"PC3\"]\n","\n","# pastikan PC numerik\n","for col in pc_cols:\n","    pc_df9[col] = pd.to_numeric(pc_df9[col], errors=\"coerce\")\n","\n","# semua kolom saham sisa loop 9\n","stock_cols9 = [col for col in harga_df9.columns if col != \"Tanggal\"]\n","\n","# pastikan harga saham numerik\n","for col in stock_cols9:\n","    harga_df9[col] = pd.to_numeric(harga_df9[col], errors=\"coerce\")\n","\n","# gabungkan data saham + PC\n","df_all9 = pd.merge(\n","    harga_df9,\n","    pc_df9[[\"Tanggal\"] + pc_cols],\n","    on=\"Tanggal\",\n","    how=\"inner\"\n",")\n","\n","# hapus missing value penting\n","df_all9 = df_all9.dropna(subset=[\"Tanggal\"] + pc_cols).reset_index(drop=True)\n","\n","# lihat data akhir\n","print(\"\\nData gabungan loop 9:\")\n","print(df_all9.head())\n","print(df_all9.tail())\n","print(df_all9.shape)\n","print(\"Jumlah saham loop 9:\", len(stock_cols9))\n","\n","\n","# ============================================================\n","# 93. LOOP 9 - TRAIN + TEST + RETRAIN FINAL + FORECAST 2025\n","#     UNTUK SETIAP SAHAM SISA\n","# ============================================================\n","\n","look_back9 = 12\n","test_size9 = 12\n","epochs9 = 200\n","batch_size9 = 1\n","\n","forecast_dict9 = {}\n","\n","# evaluasi model awal\n","eval_train_results9 = []\n","eval_test_results9 = []\n","\n","# evaluasi model final\n","eval_final_train_results9 = []\n","\n","history_dict9 = {}\n","model_dict9 = {}\n","scaler_X_dict9 = {}\n","scaler_y_dict9 = {}\n","\n","train_plot_dict9 = {}\n","test_plot_dict9 = {}\n","final_train_plot_dict9 = {}\n","\n","# tanggal forecast 2025\n","future_dates9 = pd.date_range(start=\"2025-01-01\", periods=12, freq=\"MS\")\n","\n","for col in stock_cols9:\n","    print(\"=\"*70)\n","    print(f\"Proses saham loop 9: {col}\")\n","\n","    # --------------------------------------------------------\n","    # ambil data 1 saham + PC\n","    # --------------------------------------------------------\n","    series_df9 = df_all9[[\"Tanggal\", col] + pc_cols].copy()\n","    series_df9 = series_df9.dropna().reset_index(drop=True)\n","\n","    # cek minimal data\n","    if len(series_df9) <= (look_back9 + test_size9):\n","        print(f\"Data {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # --------------------------------------------------------\n","    # pisahkan data historis sampai 2024\n","    # --------------------------------------------------------\n","    hist_df9 = series_df9[\n","        series_df9[\"Tanggal\"] < \"2025-01-01\"\n","    ].copy().reset_index(drop=True)\n","\n","    # target saham\n","    target_values9 = hist_df9[[col]].values.astype(float)\n","\n","    # fitur multivariat = [harga saham, PC1, PC2, PC3]\n","    feature_values9 = hist_df9[[col] + pc_cols].values.astype(float)\n","\n","    # --------------------------------------------------------\n","    # split data:\n","    # train awal = 2010-2023\n","    # test       = 2024\n","    # --------------------------------------------------------\n","    train_target9 = target_values9[:-test_size9]\n","    test_target9  = target_values9[-test_size9:]\n","\n","    train_features9 = feature_values9[:-test_size9]\n","    test_features9  = feature_values9[-test_size9:]\n","\n","    # --------------------------------------------------------\n","    # scaling\n","    # scaler fitur fit hanya pada training\n","    # scaler target fit hanya pada training\n","    # --------------------------------------------------------\n","    scaler_X_train9 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_train9 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaler_X_train9.fit(train_features9)\n","    scaler_y_train9.fit(train_target9)\n","\n","    scaled_all_X9 = scaler_X_train9.transform(feature_values9)\n","    scaled_all_y9 = scaler_y_train9.transform(target_values9).flatten()\n","\n","    scaler_X_dict9[f\"{col}_train\"] = scaler_X_train9\n","    scaler_y_dict9[f\"{col}_train\"] = scaler_y_train9\n","\n","    # --------------------------------------------------------\n","    # buat sequence untuk evaluasi model awal\n","    # --------------------------------------------------------\n","    X_all9, y_all9 = create_multivariate_sequences(\n","        data_array=scaled_all_X9,\n","        target_array=scaled_all_y9,\n","        look_back=look_back9\n","    )\n","\n","    if len(X_all9) <= test_size9:\n","        print(f\"Sequence {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # sequence training dan testing\n","    X_train9 = X_all9[:-test_size9]\n","    y_train9 = y_all9[:-test_size9]\n","\n","    X_test9 = X_all9[-test_size9:]\n","    y_test9 = y_all9[-test_size9:]\n","\n","    print(\"Shape X_train9:\", X_train9.shape)\n","    print(\"Shape X_test9 :\", X_test9.shape)\n","\n","    # --------------------------------------------------------\n","    # bangun model evaluasi\n","    # --------------------------------------------------------\n","    model9 = build_lstm_model(\n","        look_back=look_back9,\n","        n_features=X_train9.shape[2]\n","    )\n","\n","    early_stop9 = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    # --------------------------------------------------------\n","    # training model evaluasi\n","    # --------------------------------------------------------\n","    history9 = model9.fit(\n","        X_train9,\n","        y_train9,\n","        validation_data=(X_test9, y_test9),\n","        epochs=epochs9,\n","        batch_size=batch_size9,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop9]\n","    )\n","\n","    history_dict9[f\"{col}_eval\"] = history9\n","    model_dict9[f\"{col}_eval\"] = model9\n","\n","    # ========================================================\n","    # A. EVALUASI TRAINING (MODEL 2010-2023)\n","    # ========================================================\n","    y_pred_train_scaled9 = model9.predict(X_train9, verbose=0)\n","\n","    y_train_actual9 = scaler_y_train9.inverse_transform(\n","        y_train9.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_train_actual9 = scaler_y_train9.inverse_transform(\n","        y_pred_train_scaled9\n","    ).flatten()\n","\n","    train_dates9 = hist_df9[\"Tanggal\"].iloc[\n","        look_back9:len(hist_df9)-test_size9\n","    ].reset_index(drop=True)\n","\n","    train_plot_dict9[col] = pd.DataFrame({\n","        \"Tanggal\": train_dates9,\n","        \"Aktual\": y_train_actual9,\n","        \"Prediksi\": y_pred_train_actual9\n","    })\n","\n","    metrics_train9 = calculate_metrics(y_train_actual9, y_pred_train_actual9)\n","\n","    eval_train_results9.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_train9[\"MAE\"],\n","        \"RMSE\": metrics_train9[\"RMSE\"],\n","        \"MAPE\": metrics_train9[\"MAPE\"],\n","        \"sMAPE\": metrics_train9[\"sMAPE\"],\n","        \"R2\": metrics_train9[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # B. EVALUASI TESTING (2024)\n","    # ========================================================\n","    y_pred_test_scaled9 = model9.predict(X_test9, verbose=0)\n","\n","    y_test_actual9 = scaler_y_train9.inverse_transform(\n","        y_test9.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_test_actual9 = scaler_y_train9.inverse_transform(\n","        y_pred_test_scaled9\n","    ).flatten()\n","\n","    test_dates9 = hist_df9[\"Tanggal\"].iloc[-test_size9:].reset_index(drop=True)\n","\n","    test_plot_dict9[col] = pd.DataFrame({\n","        \"Tanggal\": test_dates9,\n","        \"Aktual\": y_test_actual9,\n","        \"Prediksi\": y_pred_test_actual9\n","    })\n","\n","    metrics_test9 = calculate_metrics(y_test_actual9, y_pred_test_actual9)\n","\n","    eval_test_results9.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_test9[\"MAE\"],\n","        \"RMSE\": metrics_test9[\"RMSE\"],\n","        \"MAPE\": metrics_test9[\"MAPE\"],\n","        \"sMAPE\": metrics_test9[\"sMAPE\"],\n","        \"R2\": metrics_test9[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # C. RETRAIN MODEL FINAL DENGAN DATA 2010-2024\n","    # ========================================================\n","    scaler_X_full9 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_full9 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaled_full_X9 = scaler_X_full9.fit_transform(feature_values9)\n","    scaled_full_y9 = scaler_y_full9.fit_transform(target_values9).flatten()\n","\n","    scaler_X_dict9[f\"{col}_full\"] = scaler_X_full9\n","    scaler_y_dict9[f\"{col}_full\"] = scaler_y_full9\n","\n","    X_full9, y_full9 = create_multivariate_sequences(\n","        data_array=scaled_full_X9,\n","        target_array=scaled_full_y9,\n","        look_back=look_back9\n","    )\n","\n","    model_final9 = build_lstm_model(\n","        look_back=look_back9,\n","        n_features=X_full9.shape[2]\n","    )\n","\n","    early_stop_final9 = EarlyStopping(\n","        monitor=\"loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history_final9 = model_final9.fit(\n","        X_full9,\n","        y_full9,\n","        epochs=epochs9,\n","        batch_size=batch_size9,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop_final9]\n","    )\n","\n","    history_dict9[f\"{col}_final\"] = history_final9\n","    model_dict9[f\"{col}_final\"] = model_final9\n","\n","    # ========================================================\n","    # D. EVALUASI TRAINING MODEL FINAL (2010-2024)\n","    # ========================================================\n","    y_pred_full_scaled9 = model_final9.predict(X_full9, verbose=0)\n","\n","    y_full_actual9 = scaler_y_full9.inverse_transform(\n","        y_full9.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_full_actual9 = scaler_y_full9.inverse_transform(\n","        y_pred_full_scaled9\n","    ).flatten()\n","\n","    full_train_dates9 = hist_df9[\"Tanggal\"].iloc[look_back9:].reset_index(drop=True)\n","\n","    final_train_plot_dict9[col] = pd.DataFrame({\n","        \"Tanggal\": full_train_dates9,\n","        \"Aktual\": y_full_actual9,\n","        \"Prediksi\": y_pred_full_actual9\n","    })\n","\n","    metrics_final_train9 = calculate_metrics(y_full_actual9, y_pred_full_actual9)\n","\n","    eval_final_train_results9.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_final_train9[\"MAE\"],\n","        \"RMSE\": metrics_final_train9[\"RMSE\"],\n","        \"MAPE\": metrics_final_train9[\"MAPE\"],\n","        \"sMAPE\": metrics_final_train9[\"sMAPE\"],\n","        \"R2\": metrics_final_train9[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # E. FORECAST 2025\n","    # ========================================================\n","    future_pc_df9 = pc_df9[\n","        (pc_df9[\"Tanggal\"] >= \"2025-01-01\") &\n","        (pc_df9[\"Tanggal\"] <= \"2025-12-01\")\n","    ].copy().reset_index(drop=True)\n","\n","    if len(future_pc_df9) < 12:\n","        print(f\"PC tahun 2025 untuk {col} tidak lengkap, forecast dilewati.\")\n","        continue\n","\n","    future_pc_values9 = future_pc_df9[pc_cols].values.astype(float)\n","\n","    # ambil window terakhir dari data 2010-2024 yang sudah di-scale\n","    rolling_window9 = scaled_full_X9[-look_back9:, :].copy()\n","    future_preds_scaled9 = []\n","\n","    for step in range(12):\n","        x_input9 = rolling_window9.reshape(1, look_back9, scaled_full_X9.shape[1])\n","\n","        # prediksi target saham\n","        next_pred_scaled9 = model_final9.predict(x_input9, verbose=0)[0, 0]\n","        future_preds_scaled9.append(next_pred_scaled9)\n","\n","        # ubah prediksi target ke skala asli dulu\n","        next_pred_actual9 = scaler_y_full9.inverse_transform(\n","            np.array([[next_pred_scaled9]])\n","        ).flatten()[0]\n","\n","        # gabungkan dengan PC periode 2025 pada bulan ke-step\n","        next_row_raw9 = np.array([\n","            next_pred_actual9,\n","            future_pc_values9[step, 0],\n","            future_pc_values9[step, 1],\n","            future_pc_values9[step, 2]\n","        ]).reshape(1, -1)\n","\n","        # scale lagi ke skala fitur\n","        next_row_scaled9 = scaler_X_full9.transform(next_row_raw9)\n","\n","        # update rolling window\n","        rolling_window9 = np.vstack([rolling_window9[1:], next_row_scaled9])\n","\n","    future_preds_scaled9 = np.array(future_preds_scaled9).reshape(-1, 1)\n","\n","    future_preds_actual9 = scaler_y_full9.inverse_transform(\n","        future_preds_scaled9\n","    ).flatten()\n","\n","    forecast_dict9[col] = future_preds_actual9\n","\n","print(\"Selesai semua saham loop 9.\")\n","\n","\n","# ============================================================\n","# 94. LOOP 9 - TABEL EVALUASI MODEL\n","# ============================================================\n","\n","eval_lstm_train9 = pd.DataFrame(eval_train_results9)\n","eval_lstm_test9 = pd.DataFrame(eval_test_results9)\n","eval_lstm_final_train9 = pd.DataFrame(eval_final_train_results9)\n","\n","print(\"=== LOOP 9 - EVALUASI TRAINING (MODEL 2010-2023) ===\")\n","print(eval_lstm_train9)\n","\n","print(\"\\n=== LOOP 9 - EVALUASI TESTING 2024 ===\")\n","print(eval_lstm_test9)\n","\n","print(\"\\n=== LOOP 9 - EVALUASI TRAINING FINAL (MODEL 2010-2024) ===\")\n","print(eval_lstm_final_train9)\n","\n","\n","# ============================================================\n","# 95. LOOP 9 - AMBIL KODE SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","smape_threshold9 = 10\n","\n","passed_stocks9 = eval_lstm_test9.loc[\n","    eval_lstm_test9[\"sMAPE\"] < smape_threshold9,\n","    \"Kode_Saham\"\n","].tolist()\n","\n","print(\"=== LOOP 9 - KODE SAHAM DENGAN sMAPE < 10 ===\")\n","print(passed_stocks9)\n","print(\"Jumlah saham lolos loop 9:\", len(passed_stocks9))\n","\n","\n","# ============================================================\n","# 96. LOOP 9 - PLOT GABUNGAN TRAINING 2010-2023 + TESTING 2024\n","#     HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","for col in passed_stocks9:\n","    if col not in train_plot_dict9:\n","        print(f\"{col} tidak ada di train_plot_dict9, dilewati.\")\n","        continue\n","\n","    if col not in test_plot_dict9:\n","        print(f\"{col} tidak ada di test_plot_dict9, dilewati.\")\n","        continue\n","\n","    train_df9 = train_plot_dict9[col].copy()\n","    test_df9 = test_plot_dict9[col].copy()\n","\n","    plot_df9 = pd.concat([train_df9, test_df9], axis=0).reset_index(drop=True)\n","\n","    split_date9 = test_df9[\"Tanggal\"].iloc[0]\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    plt.plot(\n","        plot_df9[\"Tanggal\"],\n","        plot_df9[\"Aktual\"],\n","        label=\"Aktual\"\n","    )\n","\n","    plt.plot(\n","        plot_df9[\"Tanggal\"],\n","        plot_df9[\"Prediksi\"],\n","        label=\"Prediksi\"\n","    )\n","\n","    plt.axvline(\n","        x=split_date9,\n","        linestyle=\":\",\n","        color=\"black\",\n","        linewidth=2,\n","        label=\"Batas Training-Testing\"\n","    )\n","\n","    plt.title(f\"Aktual vs Prediksi - {col} (Loop 9)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()\n","\n","\n","# ============================================================\n","# 97. LOOP 9 - HASIL FORECAST 2025 UNTUK SAHAM YANG LOLOS\n","# ============================================================\n","\n","forecast_2025_passed9 = pd.DataFrame({\"Tanggal\": future_dates9})\n","\n","for col in passed_stocks9:\n","    if col in forecast_dict9:\n","        forecast_2025_passed9[col] = forecast_dict9[col]\n","\n","print(\"=== LOOP 9 - FORECAST 2025 UNTUK SAHAM DENGAN sMAPE < 10 ===\")\n","print(forecast_2025_passed9.head())\n","print(forecast_2025_passed9.shape)\n","\n","\n","# ============================================================\n","# 98. LOOP 9 - PLOT AKTUAL VS PREDIKSI (TRAINING FINAL 2010-2024)\n","#     HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","for col in passed_stocks9:\n","    if col not in final_train_plot_dict9:\n","        continue\n","\n","    plot_df9 = final_train_plot_dict9[col].copy()\n","\n","    plt.figure(figsize=(10, 5))\n","\n","    plt.plot(\n","        plot_df9[\"Tanggal\"],\n","        plot_df9[\"Aktual\"],\n","        label=\"Aktual\"\n","    )\n","\n","    plt.plot(\n","        plot_df9[\"Tanggal\"],\n","        plot_df9[\"Prediksi\"],\n","        label=\"Prediksi\"\n","    )\n","\n","    plt.title(f\"Aktual vs Prediksi - {col} (Model Final 2010-2024, Loop 9)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()\n","\n","\n","# ============================================================\n","# 99. LOOP 9 - PLOT FORECAST 2025 UNTUK SAHAM YANG LOLOS\n","# ============================================================\n","\n","for col in passed_stocks9:\n","    if col not in forecast_2025_passed9.columns:\n","        continue\n","\n","    plt.figure(figsize=(10, 5))\n","\n","    plt.plot(\n","      