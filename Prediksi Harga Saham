n","    plt.savefig(save_path7, dpi=300, bbox_inches=\"tight\")\n","    plt.close()\n","\n","print(\"Plot historis + forecast 2025 loop 7 berhasil disimpan.\")\n","\n","# ============================================================\n","# 80.9 RINGKASAN PENYIMPANAN LOOP 7\n","# ============================================================\n","\n","print(\"\\n=== SEMUA HASIL LOOP 7 BERHASIL DISIMPAN ===\")\n","print(\"Folder utama              :\", base_folder7)\n","print(\"Excel                     :\", excel_folder7)\n","print(\"Plot training + testing   :\", plot_train_test_folder7)\n","print(\"Plot final training       :\", plot_final_training_folder7)\n","print(\"Plot forecast 2025        :\", plot_forecast_folder7)\n","print(\"Plot historis + forecast  :\", plot_hist_forecast_folder7)\n","\n","print(\"\\nFile Excel:\")\n","print(excel_path7)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"7CW-VGqTEZQT","executionInfo":{"status":"ok","timestamp":1777737876004,"user_tz":-420,"elapsed":216,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}},"outputId":"661b7095-2e0a-4385-9aa2-660ad9847aab"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Semua folder hasil loop 7 berhasil dibuat.\n","Folder utama: /content/drive/My Drive/hasil_loop7\n","\n","Jumlah saham lolos loop 7: 0\n","Empty DataFrame\n","Columns: [Kode_Saham]\n","Index: []\n","\n","File Excel hasil loop 7 berhasil disimpan di:\n","/content/drive/My Drive/hasil_loop7/Excel/hasil_loop7.xlsx\n","\n","Plot gabungan training-testing loop 7 berhasil disimpan.\n","Plot training final loop 7 berhasil disimpan.\n","Plot forecast 2025 loop 7 berhasil disimpan.\n","Plot historis + forecast 2025 loop 7 berhasil disimpan.\n","\n","=== SEMUA HASIL LOOP 7 BERHASIL DISIMPAN ===\n","Folder utama              : /content/drive/My Drive/hasil_loop7\n","Excel                     : /content/drive/My Drive/hasil_loop7/Excel\n","Plot training + testing   : /content/drive/My Drive/hasil_loop7/Plot_Training_Testing_2010_2024\n","Plot final training       : /content/drive/My Drive/hasil_loop7/Plot_Training_Final_2010_2024\n","Plot forecast 2025        : /content/drive/My Drive/hasil_loop7/Plot_Forecast_2025\n","Plot historis + forecast  : /content/drive/My Drive/hasil_loop7/Plot_Historis_dan_Forecast_2025\n","\n","File Excel:\n","/content/drive/My Drive/hasil_loop7/Excel/hasil_loop7.xlsx\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# LOOP 8\n","# INPUT: harga_2010_2024_sisa7\n","# ============================================================\n","\n","\n","# ============================================================\n","# 81. LOOP 8 - RAPIIKAN DATA\n","# ============================================================\n","\n","# copy data agar aman\n","harga_df8 = harga_2010_2024_sisa7.copy()\n","pc_df8 = pc_all.copy()\n","\n","# ubah kolom tanggal ke format datetime\n","harga_df8[\"Tanggal\"] = pd.to_datetime(harga_df8[\"Tanggal\"])\n","pc_df8[\"Tanggal\"] = pd.to_datetime(pc_df8[\"Tanggal\"])\n","\n","# urutkan berdasarkan tanggal\n","harga_df8 = harga_df8.sort_values(\"Tanggal\").reset_index(drop=True)\n","pc_df8 = pc_df8.sort_values(\"Tanggal\").reset_index(drop=True)\n","\n","# cek nama kolom\n","print(\"Kolom harga loop 8:\")\n","print(harga_df8.columns)\n","\n","print(\"\\nKolom PC loop 8:\")\n","print(pc_df8.columns)\n","\n","# pilih kolom PC\n","pc_cols = [\"PC1\", \"PC2\", \"PC3\"]\n","\n","# pastikan PC numerik\n","for col in pc_cols:\n","    pc_df8[col] = pd.to_numeric(pc_df8[col], errors=\"coerce\")\n","\n","# semua kolom saham sisa loop 8\n","stock_cols8 = [col for col in harga_df8.columns if col != \"Tanggal\"]\n","\n","# pastikan harga saham numerik\n","for col in stock_cols8:\n","    harga_df8[col] = pd.to_numeric(harga_df8[col], errors=\"coerce\")\n","\n","# gabungkan data saham + PC\n","df_all8 = pd.merge(\n","    harga_df8,\n","    pc_df8[[\"Tanggal\"] + pc_cols],\n","    on=\"Tanggal\",\n","    how=\"inner\"\n",")\n","\n","# hapus missing value penting\n","df_all8 = df_all8.dropna(subset=[\"Tanggal\"] + pc_cols).reset_index(drop=True)\n","\n","# lihat data akhir\n","print(\"\\nData gabungan loop 8:\")\n","print(df_all8.head())\n","print(df_all8.tail())\n","print(df_all8.shape)\n","print(\"Jumlah saham loop 8:\", len(stock_cols8))\n","\n","\n","# ============================================================\n","# 82. LOOP 8 - TRAIN + TEST + RETRAIN FINAL + FORECAST 2025\n","#     UNTUK SETIAP SAHAM SISA\n","# ============================================================\n","\n","look_back8 = 11\n","test_size8 = 12\n","epochs8 = 200\n","batch_size8 = 1\n","\n","forecast_dict8 = {}\n","\n","# evaluasi model awal\n","eval_train_results8 = []\n","eval_test_results8 = []\n","\n","# evaluasi model final\n","eval_final_train_results8 = []\n","\n","history_dict8 = {}\n","model_dict8 = {}\n","scaler_X_dict8 = {}\n","scaler_y_dict8 = {}\n","\n","train_plot_dict8 = {}\n","test_plot_dict8 = {}\n","final_train_plot_dict8 = {}\n","\n","# tanggal forecast 2025\n","future_dates8 = pd.date_range(start=\"2025-01-01\", periods=12, freq=\"MS\")\n","\n","for col in stock_cols8:\n","    print(\"=\"*70)\n","    print(f\"Proses saham loop 8: {col}\")\n","\n","    # --------------------------------------------------------\n","    # ambil data 1 saham + PC\n","    # --------------------------------------------------------\n","    series_df8 = df_all8[[\"Tanggal\", col] + pc_cols].copy()\n","    series_df8 = series_df8.dropna().reset_index(drop=True)\n","\n","    # cek minimal data\n","    if len(series_df8) <= (look_back8 + test_size8):\n","        print(f\"Data {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # --------------------------------------------------------\n","    # pisahkan data historis sampai 2024\n","    # --------------------------------------------------------\n","    hist_df8 = series_df8[\n","        series_df8[\"Tanggal\"] < \"2025-01-01\"\n","    ].copy().reset_index(drop=True)\n","\n","    # target saham\n","    target_values8 = hist_df8[[col]].values.astype(float)\n","\n","    # fitur multivariat = [harga saham, PC1, PC2, PC3]\n","    feature_values8 = hist_df8[[col] + pc_cols].values.astype(float)\n","\n","    # --------------------------------------------------------\n","    # split data:\n","    # train awal = 2010-2023\n","    # test       = 2024\n","    # --------------------------------------------------------\n","    train_target8 = target_values8[:-test_size8]\n","    test_target8  = target_values8[-test_size8:]\n","\n","    train_features8 = feature_values8[:-test_size8]\n","    test_features8  = feature_values8[-test_size8:]\n","\n","    # --------------------------------------------------------\n","    # scaling\n","    # scaler fitur fit hanya pada training\n","    # scaler target fit hanya pada training\n","    # --------------------------------------------------------\n","    scaler_X_train8 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_train8 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaler_X_train8.fit(train_features8)\n","    scaler_y_train8.fit(train_target8)\n","\n","    scaled_all_X8 = scaler_X_train8.transform(feature_values8)\n","    scaled_all_y8 = scaler_y_train8.transform(target_values8).flatten()\n","\n","    scaler_X_dict8[f\"{col}_train\"] = scaler_X_train8\n","    scaler_y_dict8[f\"{col}_train\"] = scaler_y_train8\n","\n","    # --------------------------------------------------------\n","    # buat sequence untuk evaluasi model awal\n","    # --------------------------------------------------------\n","    X_all8, y_all8 = create_multivariate_sequences(\n","        data_array=scaled_all_X8,\n","        target_array=scaled_all_y8,\n","        look_back=look_back8\n","    )\n","\n","    if len(X_all8) <= test_size8:\n","        print(f\"Sequence {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # sequence training dan testing\n","    X_train8 = X_all8[:-test_size8]\n","    y_train8 = y_all8[:-test_size8]\n","\n","    X_test8 = X_all8[-test_size8:]\n","    y_test8 = y_all8[-test_size8:]\n","\n","    print(\"Shape X_train8:\", X_train8.shape)\n","    print(\"Shape X_test8 :\", X_test8.shape)\n","\n","    # --------------------------------------------------------\n","    # bangun model evaluasi\n","    # --------------------------------------------------------\n","    model8 = build_lstm_model(\n","        look_back=look_back8,\n","        n_features=X_train8.shape[2]\n","    )\n","\n","    early_stop8 = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    # --------------------------------------------------------\n","    # training model evaluasi\n","    # --------------------------------------------------------\n","    history8 = model8.fit(\n","        X_train8,\n","        y_train8,\n","        validation_data=(X_test8, y_test8),\n","        epochs=epochs8,\n","        batch_size=batch_size8,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop8]\n","    )\n","\n","    history_dict8[f\"{col}_eval\"] = history8\n","    model_dict8[f\"{col}_eval\"] = model8\n","\n","    # ========================================================\n","    # A. EVALUASI TRAINING (MODEL 2010-2023)\n","    # ========================================================\n","    y_pred_train_scaled8 = model8.predict(X_train8, verbose=0)\n","\n","    y_train_actual8 = scaler_y_train8.inverse_transform(\n","        y_train8.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_train_actual8 = scaler_y_train8.inverse_transform(\n","        y_pred_train_scaled8\n","    ).flatten()\n","\n","    train_dates8 = hist_df8[\"Tanggal\"].iloc[\n","        look_back8:len(hist_df8)-test_size8\n","    ].reset_index(drop=True)\n","\n","    train_plot_dict8[col] = pd.DataFrame({\n","        \"Tanggal\": train_dates8,\n","        \"Aktual\": y_train_actual8,\n","        \"Prediksi\": y_pred_train_actual8\n","    })\n","\n","    metrics_train8 = calculate_metrics(y_train_actual8, y_pred_train_actual8)\n","\n","    eval_train_results8.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_train8[\"MAE\"],\n","        \"RMSE\": metrics_train8[\"RMSE\"],\n","        \"MAPE\": metrics_train8[\"MAPE\"],\n","        \"sMAPE\": metrics_train8[\"sMAPE\"],\n","        \"R2\": metrics_train8[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # B. EVALUASI TESTING (2024)\n","    # ========================================================\n","    y_pred_test_scaled8 = model8.predict(X_test8, verbose=0)\n","\n","    y_test_actual8 = scaler_y_train8.inverse_transform(\n","        y_test8.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_test_actual8 = scaler_y_train8.inverse_transform(\n","        y_pred_test_scaled8\n","    ).flatten()\n","\n","    test_dates8 = hist_df8[\"Tanggal\"].iloc[-test_size8:].reset_index(drop=True)\n","\n","    test_plot_dict8[col] = pd.DataFrame({\n","        \"Tanggal\": test_dates8,\n","        \"Aktual\": y_test_actual8,\n","        \"Prediksi\": y_pred_test_actual8\n","    })\n","\n","    metrics_test8 = calculate_metrics(y_test_actual8, y_pred_test_actual8)\n","\n","    eval_test_results8.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_test8[\"MAE\"],\n","        \"RMSE\": metrics_test8[\"RMSE\"],\n","        \"MAPE\": metrics_test8[\"MAPE\"],\n","        \"sMAPE\": metrics_test8[\"sMAPE\"],\n","        \"R2\": metrics_test8[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # C. RETRAIN MODEL FINAL DENGAN DATA 2010-2024\n","    # ========================================================\n","    scaler_X_full8 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_full8 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaled_full_X8 = scaler_X_full8.fit_transform(feature_values8)\n","    scaled_full_y8 = scaler_y_full8.fit_transform(target_values8).flatten()\n","\n","    scaler_X_dict8[f\"{col}_full\"] = scaler_X_full8\n","    scaler_y_dict8[f\"{col}_full\"] = scaler_y_full8\n","\n","    X_full8, y_full8 = create_multivariate_sequences(\n","        data_array=scaled_full_X8,\n","        target_array=scaled_full_y8,\n","        look_back=look_back8\n","    )\n","\n","    model_final8 = build_lstm_model(\n","        look_back=look_back8,\n","        n_features=X_full8.shape[2]\n","    )\n","\n","    early_stop_final8 = EarlyStopping(\n","        monitor=\"loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history_final8 = model_final8.fit(\n","        X_full8,\n","        y_full8,\n","        epochs=epochs8,\n","        batch_size=batch_size8,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop_final8]\n","    )\n","\n","    history_dict8[f\"{col}_final\"] = history_final8\n","    model_dict8[f\"{col}_final\"] = model_final8\n","\n","    # ========================================================\n","    # D. EVALUASI TRAINING MODEL FINAL (2010-2024)\n","    # ========================================================\n","    y_pred_full_scaled8 = model_final8.predict(X_full8, verbose=0)\n","\n","    y_full_actual8 = scaler_y_full8.inverse_transform(\n","        y_full8.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_full_actual8 = scaler_y_full8.inverse_transform(\n","        y_pred_full_scaled8\n","    ).flatten()\n","\n","    full_train_dates8 = hist_df8[\"Tanggal\"].iloc[look_back8:].reset_index(drop=True)\n","\n","    final_train_plot_dict8[col] = pd.DataFrame({\n","        \"Tanggal\": full_train_dates8,\n","        \"Aktual\": y_full_actual8,\n","        \"Prediksi\": y_pred_full_actual8\n","    })\n","\n","    metrics_final_train8 = calculate_metrics(y_full_actual8, y_pred_full_actual8)\n","\n","    eval_final_train_results8.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_final_train8[\"MAE\"],\n","        \"RMSE\": metrics_final_train8[\"RMSE\"],\n","        \"MAPE\": metrics_final_train8[\"MAPE\"],\n","        \"sMAPE\": metrics_final_train8[\"sMAPE\"],\n","        \"R2\": metrics_final_train8[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # E. FORECAST 2025\n","    # ========================================================\n","    future_pc_df8 = pc_df8[\n","        (pc_df8[\"Tanggal\"] >= \"2025-01-01\") &\n","        (pc_df8[\"Tanggal\"] <= \"2025-12-01\")\n","    ].copy().reset_index(drop=True)\n","\n","    if len(future_pc_df8) < 12:\n","        print(f\"PC tahun 2025 untuk {col} tidak lengkap, forecast dilewati.\")\n","        continue\n","\n","    future_pc_values8 = future_pc_df8[pc_cols].values.astype(float)\n","\n","    # ambil window terakhir dari data 2010-2024 yang sudah di-scale\n","    rolling_window8 = scaled_full_X8[-look_back8:, :].copy()\n","    future_preds_scaled8 = []\n","\n","    for step in range(12):\n","        x_input8 = rolling_window8.reshape(1, look_back8, scaled_full_X8.shape[1])\n","\n","        # prediksi target saham\n","        next_pred_scaled8 = model_final8.predict(x_input8, verbose=0)[0, 0]\n","        future_preds_scaled8.append(next_pred_scaled8)\n","\n","        # ubah prediksi target ke skala asli dulu\n","        next_pred_actual8 = scaler_y_full8.inverse_transform(\n","            np.array([[next_pred_scaled8]])\n","        ).flatten()[0]\n","\n","        # gabungkan dengan PC periode 2025 pada bulan ke-step\n","        next_row_raw8 = np.array([\n","            next_pred_actual8,\n","            future_pc_values8[step, 0],\n","            future_pc_values8[step, 1],\n","            future_pc_values8[step, 2]\n","        ]).reshape(1, -1)\n","\n","        # scale lagi ke skala fitur\n","        next_row_scaled8 = scaler_X_full8.transform(next_row_raw8)\n","\n","        # update rolling window\n","        rolling_window8 = np.vstack([rolling_window8[1:], next_row_scaled8])\n","\n","    future_preds_scaled8 = np.array(future_preds_scaled8).reshape(-1, 1)\n","\n","    future_preds_actual8 = scaler_y_full8.inverse_transform(\n","        future_preds_scaled8\n","    ).flatten()\n","\n","    forecast_dict8[col] = future_preds_actual8\n","\n","print(\"Selesai semua saham loop 8.\")\n","\n","\n","# ============================================================\n","# 83. LOOP 8 - TABEL EVALUASI MODEL\n","# ============================================================\n","\n","eval_lstm_train8 = pd.DataFrame(eval_train_results8)\n","eval_lstm_test8 = pd.DataFrame(eval_test_results8)\n","eval_lstm_final_train8 = pd.DataFrame(eval_final_train_results8)\n","\n","print(\"=== LOOP 8 - EVALUASI TRAINING (MODEL 2010-2023) ===\")\n","print(eval_lstm_train8)\n","\n","print(\"\\n=== LOOP 8 - EVALUASI TESTING 2024 ===\")\n","print(eval_lstm_test8)\n","\n","print(\"\\n=== LOOP 8 - EVALUASI TRAINING FINAL (MODEL 2010-2024) ===\")\n","print(eval_lstm_final_train8)\n","\n","\n","# ============================================================\n","# 84. LOOP 8 - AMBIL KODE SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","smape_threshold8 = 10\n","\n","passed_stocks8 = eval_lstm_test8.loc[\n","    eval_lstm_test8[\"sMAPE\"] < smape_threshold8,\n","    \"Kode_Saham\"\n","].tolist()\n","\n","print(\"=== LOOP 8 - KODE SAHAM DENGAN sMAPE < 10 ===\")\n","print(passed_stocks8)\n","print(\"Jumlah saham lolos loop 8:\", len(passed_stocks8))\n","\n","\n","# ============================================================\n","# 85. LOOP 8 - PLOT GABUNGAN TRAINING 2010-2023 + TESTING 2024\n","#     HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","for col in passed_stocks8:\n","    if col not in train_plot_dict8