s.astype(float)\n","\n","    # --------------------------------------------------------\n","    # split data:\n","    # train awal = 2010-2023\n","    # test       = 2024\n","    # --------------------------------------------------------\n","    train_target3 = target_values3[:-test_size3]\n","    test_target3  = target_values3[-test_size3:]\n","\n","    train_features3 = feature_values3[:-test_size3]\n","    test_features3  = feature_values3[-test_size3:]\n","\n","    # --------------------------------------------------------\n","    # scaling\n","    # scaler fitur fit hanya pada training\n","    # scaler target fit hanya pada training\n","    # --------------------------------------------------------\n","    scaler_X_train3 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_train3 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaler_X_train3.fit(train_features3)\n","    scaler_y_train3.fit(train_target3)\n","\n","    scaled_all_X3 = scaler_X_train3.transform(feature_values3)\n","    scaled_all_y3 = scaler_y_train3.transform(target_values3).flatten()\n","\n","    scaler_X_dict3[f\"{col}_train\"] = scaler_X_train3\n","    scaler_y_dict3[f\"{col}_train\"] = scaler_y_train3\n","\n","    # --------------------------------------------------------\n","    # buat sequence untuk evaluasi model awal\n","    # --------------------------------------------------------\n","    X_all3, y_all3 = create_multivariate_sequences(\n","        data_array=scaled_all_X3,\n","        target_array=scaled_all_y3,\n","        look_back=look_back3\n","    )\n","\n","    if len(X_all3) <= test_size3:\n","        print(f\"Sequence {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # sequence training dan testing\n","    X_train3 = X_all3[:-test_size3]\n","    y_train3 = y_all3[:-test_size3]\n","\n","    X_test3 = X_all3[-test_size3:]\n","    y_test3 = y_all3[-test_size3:]\n","\n","    print(\"Shape X_train3:\", X_train3.shape)\n","    print(\"Shape X_test3 :\", X_test3.shape)\n","\n","    # --------------------------------------------------------\n","    # bangun model evaluasi\n","    # --------------------------------------------------------\n","    model3 = build_lstm_model(\n","        look_back=look_back3,\n","        n_features=X_train3.shape[2]\n","    )\n","\n","    early_stop3 = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    # --------------------------------------------------------\n","    # training model evaluasi\n","    # --------------------------------------------------------\n","    history3 = model3.fit(\n","        X_train3,\n","        y_train3,\n","        validation_data=(X_test3, y_test3),\n","        epochs=epochs3,\n","        batch_size=batch_size3,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop3]\n","    )\n","\n","    history_dict3[f\"{col}_eval\"] = history3\n","    model_dict3[f\"{col}_eval\"] = model3\n","\n","    # ========================================================\n","    # A. EVALUASI TRAINING (MODEL 2010-2023)\n","    # ========================================================\n","    y_pred_train_scaled3 = model3.predict(X_train3, verbose=0)\n","\n","    y_train_actual3 = scaler_y_train3.inverse_transform(\n","        y_train3.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_train_actual3 = scaler_y_train3.inverse_transform(\n","        y_pred_train_scaled3\n","    ).flatten()\n","\n","    train_dates3 = hist_df3[\"Tanggal\"].iloc[\n","        look_back3:len(hist_df3)-test_size3\n","    ].reset_index(drop=True)\n","\n","    train_plot_dict3[col] = pd.DataFrame({\n","        \"Tanggal\": train_dates3,\n","        \"Aktual\": y_train_actual3,\n","        \"Prediksi\": y_pred_train_actual3\n","    })\n","\n","    metrics_train3 = calculate_metrics(y_train_actual3, y_pred_train_actual3)\n","\n","    eval_train_results3.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_train3[\"MAE\"],\n","        \"RMSE\": metrics_train3[\"RMSE\"],\n","        \"MAPE\": metrics_train3[\"MAPE\"],\n","        \"sMAPE\": metrics_train3[\"sMAPE\"],\n","        \"R2\": metrics_train3[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # B. EVALUASI TESTING (2024)\n","    # ========================================================\n","    y_pred_test_scaled3 = model3.predict(X_test3, verbose=0)\n","\n","    y_test_actual3 = scaler_y_train3.inverse_transform(\n","        y_test3.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_test_actual3 = scaler_y_train3.inverse_transform(\n","        y_pred_test_scaled3\n","    ).flatten()\n","\n","    test_dates3 = hist_df3[\"Tanggal\"].iloc[-test_size3:].reset_index(drop=True)\n","\n","    test_plot_dict3[col] = pd.DataFrame({\n","        \"Tanggal\": test_dates3,\n","        \"Aktual\": y_test_actual3,\n","        \"Prediksi\": y_pred_test_actual3\n","    })\n","\n","    metrics_test3 = calculate_metrics(y_test_actual3, y_pred_test_actual3)\n","\n","    eval_test_results3.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_test3[\"MAE\"],\n","        \"RMSE\": metrics_test3[\"RMSE\"],\n","        \"MAPE\": metrics_test3[\"MAPE\"],\n","        \"sMAPE\": metrics_test3[\"sMAPE\"],\n","        \"R2\": metrics_test3[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # C. RETRAIN MODEL FINAL DENGAN DATA 2010-2024\n","    # ========================================================\n","    scaler_X_full3 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_full3 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaled_full_X3 = scaler_X_full3.fit_transform(feature_values3)\n","    scaled_full_y3 = scaler_y_full3.fit_transform(target_values3).flatten()\n","\n","    scaler_X_dict3[f\"{col}_full\"] = scaler_X_full3\n","    scaler_y_dict3[f\"{col}_full\"] = scaler_y_full3\n","\n","    X_full3, y_full3 = create_multivariate_sequences(\n","        data_array=scaled_full_X3,\n","        target_array=scaled_full_y3,\n","        look_back=look_back3\n","    )\n","\n","    model_final3 = build_lstm_model(\n","        look_back=look_back3,\n","        n_features=X_full3.shape[2]\n","    )\n","\n","    early_stop_final3 = EarlyStopping(\n","        monitor=\"loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history_final3 = model_final3.fit(\n","        X_full3,\n","        y_full3,\n","        epochs=epochs3,\n","        batch_size=batch_size3,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop_final3]\n","    )\n","\n","    history_dict3[f\"{col}_final\"] = history_final3\n","    model_dict3[f\"{col}_final\"] = model_final3\n","\n","    # ========================================================\n","    # D. EVALUASI TRAINING MODEL FINAL (2010-2024)\n","    # ========================================================\n","    y_pred_full_scaled3 = model_final3.predict(X_full3, verbose=0)\n","\n","    y_full_actual3 = scaler_y_full3.inverse_transform(\n","        y_full3.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_full_actual3 = scaler_y_full3.inverse_transform(\n","        y_pred_full_scaled3\n","    ).flatten()\n","\n","    full_train_dates3 = hist_df3[\"Tanggal\"].iloc[look_back3:].reset_index(drop=True)\n","\n","    final_train_plot_dict3[col] = pd.DataFrame({\n","        \"Tanggal\": full_train_dates3,\n","        \"Aktual\": y_full_actual3,\n","        \"Prediksi\": y_pred_full_actual3\n","    })\n","\n","    metrics_final_train3 = calculate_metrics(y_full_actual3, y_pred_full_actual3)\n","\n","    eval_final_train_results3.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_final_train3[\"MAE\"],\n","        \"RMSE\": metrics_final_train3[\"RMSE\"],\n","        \"MAPE\": metrics_final_train3[\"MAPE\"],\n","        \"sMAPE\": metrics_final_train3[\"sMAPE\"],\n","        \"R2\": metrics_final_train3[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # E. FORECAST 2025\n","    # ========================================================\n","    future_pc_df3 = pc_df3[\n","        (pc_df3[\"Tanggal\"] >= \"2025-01-01\") &\n","        (pc_df3[\"Tanggal\"] <= \"2025-12-01\")\n","    ].copy().reset_index(drop=True)\n","\n","    if len(future_pc_df3) < 12:\n","        print(f\"PC tahun 2025 untuk {col} tidak lengkap, forecast dilewati.\")\n","        continue\n","\n","    future_pc_values3 = future_pc_df3[pc_cols].values.astype(float)\n","\n","    # ambil window terakhir dari data 2010-2024 yang sudah di-scale\n","    rolling_window3 = scaled_full_X3[-look_back3:, :].copy()\n","    future_preds_scaled3 = []\n","\n","    for step in range(12):\n","        x_input3 = rolling_window3.reshape(1, look_back3, scaled_full_X3.shape[1])\n","\n","        # prediksi target saham\n","        next_pred_scaled3 = model_final3.predict(x_input3, verbose=0)[0, 0]\n","        future_preds_scaled3.append(next_pred_scaled3)\n","\n","        # ubah prediksi target ke skala asli dulu\n","        next_pred_actual3 = scaler_y_full3.inverse_transform(\n","            np.array([[next_pred_scaled3]])\n","        ).flatten()[0]\n","\n","        # gabungkan dengan PC periode 2025 pada bulan ke-step\n","        next_row_raw3 = np.array([\n","            next_pred_actual3,\n","            future_pc_values3[step, 0],\n","            future_pc_values3[step, 1],\n","            future_pc_values3[step, 2]\n","        ]).reshape(1, -1)\n","\n","        # scale lagi ke skala fitur\n","        next_row_scaled3 = scaler_X_full3.transform(next_row_raw3)\n","\n","        # update rolling window\n","        rolling_window3 = np.vstack([rolling_window3[1:], next_row_scaled3])\n","\n","    future_preds_scaled3 = np.array(future_preds_scaled3).reshape(-1, 1)\n","\n","    future_preds_actual3 = scaler_y_full3.inverse_transform(\n","        future_preds_scaled3\n","    ).flatten()\n","\n","    forecast_dict3[col] = future_preds_actual3\n","\n","print(\"Selesai semua saham loop 3.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"zqVcXfV3OuX-","outputId":"62aa0830-1bca-4ee8-868e-ed19edb8b368","executionInfo":{"status":"error","timestamp":1777779665012,"user_tz":-420,"elapsed":935262,"user":{"displayName":"Fiona Angelica Tango","userId":"02545952810002722304"}}},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","Proses saham loop 3: ADHI\n","Shape X_train3: (161, 6, 4)\n","Shape X_test3 : (12, 6, 4)\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/keras/src/layers/rnn/rnn.py:199: UserWarning: Do not pass an `input_shape`/`input_dim` argument to a layer. When using Sequential models, prefer using an `Input(shape)` object as the first layer in the model instead.\n","  super().__init__(**kwargs)\n","/usr/local/lib/python3.12/dist-packages/keras/src/layers/rnn/rnn.py:199: UserWarning: Do not pass an `input_shape`/`input_dim` argument to a layer. When using Sequential models, prefer using an `Input(shape)` object as the first layer in the model instead.\n","  super().__init__(**kwargs)\n"]},{"output_type":"stream","name":"stdout","text":["======================================================================\n","Proses saham loop 3: ASRI\n","Shape X_train3: (161, 6, 4)\n","Shape X_test3 : (12, 6, 4)\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/keras/src/layers/rnn/rnn.py:199: UserWarning: Do not pass an `input_shape`/`input_dim` argument to a layer. When using Sequential models, prefer using an `Input(shape)` object as the first layer in the model instead.\n","  super().__init__(**kwargs)\n","/usr/local/lib/python3.12/dist-packages/keras/src/layers/rnn/