_values12)\n","    scaled_all_y12 = scaler_y_train12.transform(target_values12).flatten()\n","\n","    scaler_X_dict12[f\"{col}_train\"] = scaler_X_train12\n","    scaler_y_dict12[f\"{col}_train\"] = scaler_y_train12\n","\n","    X_all12, y_all12 = create_multivariate_sequences(\n","        data_array=scaled_all_X12,\n","        target_array=scaled_all_y12,\n","        look_back=look_back12\n","    )\n","\n","    if len(X_all12) <= test_size12:\n","        print(f\"Sequence {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    X_train12 = X_all12[:-test_size12]\n","    y_train12 = y_all12[:-test_size12]\n","\n","    X_test12 = X_all12[-test_size12:]\n","    y_test12 = y_all12[-test_size12:]\n","\n","    print(\"Shape X_train12:\", X_train12.shape)\n","    print(\"Shape X_test12 :\", X_test12.shape)\n","\n","    model12 = build_lstm_model(\n","        look_back=look_back12,\n","        n_features=X_train12.shape[2]\n","    )\n","\n","    early_stop12 = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history12 = model12.fit(\n","        X_train12,\n","        y_train12,\n","        validation_data=(X_test12, y_test12),\n","        epochs=epochs12,\n","        batch_size=batch_size12,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop12]\n","    )\n","\n","    history_dict12[f\"{col}_eval\"] = history12\n","    model_dict12[f\"{col}_eval\"] = model12\n","\n","    y_pred_train_scaled12 = model12.predict(X_train12, verbose=0)\n","\n","    y_train_actual12 = scaler_y_train12.inverse_transform(\n","        y_train12.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_train_actual12 = scaler_y_train12.inverse_transform(\n","        y_pred_train_scaled12\n","    ).flatten()\n","\n","    train_dates12 = hist_df12[\"Tanggal\"].iloc[\n","        look_back12:len(hist_df12)-test_size12\n","    ].reset_index(drop=True)\n","\n","    train_plot_dict1