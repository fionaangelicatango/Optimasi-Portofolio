tadata":{"id":"EbOWc0_pFklF"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# LOOP 10\n","# INPUT: harga_2010_2024_sisa9\n","# ============================================================\n","\n","harga_2010_2024_sisa9 = pd.read_excel(\"/content/drive/My Drive/hasil_loop9/Excel/hasil_loop9.xlsx\", sheet_name=\"data_sisa\")\n","# ============================================================\n","# 103. LOOP 10 - RAPIIKAN DATA\n","# ============================================================\n","\n","# copy data agar aman\n","harga_df10 = harga_2010_2024_sisa9.copy()\n","pc_df10 = pc_all.copy()\n","\n","# ubah kolom tanggal ke format datetime\n","harga_df10[\"Tanggal\"] = pd.to_datetime(harga_df10[\"Tanggal\"])\n","pc_df10[\"Tanggal\"] = pd.to_datetime(pc_df10[\"Tanggal\"])\n","\n","# urutkan berdasarkan tanggal\n","harga_df10 = harga_df10.sort_values(\"Tanggal\").reset_index(drop=True)\n","pc_df10 = pc_df10.sort_values(\"Tanggal\").reset_index(drop=True)\n","\n","# cek nama kolom\n","print(\"Kolom harga loop 10:\")\n","print(harga_df10.columns)\n","\n","print(\"\\nKolom PC loop 10:\")\n","print(pc_df10.columns)\n","\n","# pilih kolom PC\n","pc_cols = [\"PC1\", \"PC2\", \"PC3\"]\n","\n","# pastikan PC numerik\n","for col in pc_cols:\n","    pc_df10[col] = pd.to_numeric(pc_df10[col], errors=\"coerce\")\n","\n","# semua kolom saham sisa loop 10\n","stock_cols10 = [col for col in harga_df10.columns if col != \"Tanggal\"]\n","\n","# pastikan harga saham numerik\n","for col in stock_cols10:\n","    harga_df10[col] = pd.to_numeric(harga_df10[col], errors=\"coerce\")\n","\n","# gabungkan data saham + PC\n","df_all10 = pd.merge(\n","    harga_df10,\n","    pc_df10[[\"Tanggal\"] + pc_cols],\n","    on=\"Tanggal\",\n","    how=\"inner\"\n",")\n","\n","# hapus missing value penting\n","df_all10 = df_all10.dropna(subset=[\"Tanggal\"] + pc_cols).reset_index(drop=True)\n","\n","# lihat data akhir\n","print(\"\\nData gabungan loop 10:\")\n","print(df_all10.head())\n","print(df_all10.tail())\n","print(df_all10.shape)\n","print(\"Jumlah saham loop 10:\", len(stock_cols10))\n","\n","\n","# ============================================================\n","# 104. LOOP 10 - TRAIN + TEST + RETRAIN FINAL + FORECAST 2025\n","#      UNTUK SETIAP SAHAM SISA\n","# ============================================================\n","\n","look_back10 = 40\n","test_size10 = 12\n","epochs10 = 200\n","batch_size10 = 1\n","\n","forecast_dict10 = {}\n","\n","# evaluasi model awal\n","eval_train_results10 = []\n","eval_test_results10 = []\n","\n","# evaluasi model final\n","eval_final_train_results10 = []\n","\n","history_dict10 = {}\n","model_dict10 = {}\n","scaler_X_dict10 = {}\n","scaler_y_dict10 = {}\n","\n","train_plot_dict10 = {}\n","test_plot_dict10 = {}\n","final_train_plot_dict10 = {}\n","\n","# tanggal forecast 2025\n","future_dates10 = pd.date_range(start=\"2025-01-01\", periods=12, freq=\"MS\")\n","\n","for col in stock_cols10:\n","    print(\"=\"*70)\n","    print(f\"Proses saham loop 10: {col}\")\n","\n","    # --------------------------------------------------------\n","    # ambil data 1 saham + PC\n","    # --------------------------------------------------------\n","    series_df10 = df_all10[[\"Tanggal\", col] + pc_cols].copy()\n","    series_df10 = series_df10.dropna().reset_index(drop=True)\n","\n","    # cek minimal data\n","    if len(series_df10) <= (look_back10 + test_size10):\n","        print(f\"Data {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # --------------------------------------------------------\n","    # pisahkan data historis sampai 2024\n","    # --------------------------------------------------------\n","    hist_df10 = series_df10[\n","        series_df10[\"Tanggal\"] < \"2025-01-01\"\n","    ].copy().reset_index(drop=True)\n","\n","    # target saham\n","    target_values10 = hist_df10[[col]].values.astype(float)\n","\n","    # fitur multivariat = [harga saham, PC1, PC2, PC3]\n","    feature_values10 = hist_df10[[col] + pc_cols].values.astype(float)\n","\n","    # --------------------------------------------------------\n","    # split data:\n","    # train awal = 2010-2023\n","    # test       = 2024\n","    # --------------------------------------------------------\n","    train_target10 = target_values10[:-test_size10]\n","    test_target10  = target_values10[-test_size10:]\n","\n","    train_features10 = feature_values10[:-test_size10]\n","    test_features10  = feature_values10[-test_size10:]\n","\n","    # --------------------------------------------------------\n","    # scaling\n","    # scaler fitur fit hanya pada training\n","    # scaler target fit hanya pada training\n","    # --------------------------------------------------------\n","    scaler_X_train10 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_train10 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaler_X_train10.fit(train_features10)\n","    scaler_y_train10.fit(train_target10)\n","\n","    scaled_all_X10 = scaler_X_train10.transform(feature_values10)\n","    scaled_all_y10 = scaler_y_train10.transform(target_values10).flatten()\n","\n","    scaler_X_dict10[f\"{col}_train\"] = scaler_X_train10\n","    scaler_y_dict10[f\"{col}_train\"] = scaler_y_train10\n","\n","    # --------------------------------------------------------\n","    # buat sequence untuk evaluasi model awal\n","    # --------------------------------------------------------\n","    X_all10, y_all10 = create_multivariate_sequences(\n","        data_array=scaled_all_X10,\n","        target_array=scaled_all_y10,\n","        look_back=look_back10\n","    )\n","\n","    if len(X_all10) <= test_size10:\n","        print(f\"Sequence {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # sequence training dan testing\n","    X_train10 = X_all10[:-test_size10]\n","    y_train10 = y_all10[:-test_size10]\n","\n","    X_test10 = X_all10[-test_size10:]\n","    y_test10 = y_all10[-test_size10:]\n","\n","    print(\"Shape X_train10:\", X_train10.shape)\n","    print(\"Shape X_test10 :\", X_test10.shape)\n","\n","    # --------------------------------------------------------\n","    # bangun model evaluasi\n","    # --------------------------------------------------------\n","    model10 = build_lstm_model(\n","        look_back=look_back10,\n","        n_features=X_train10.shape[2]\n","    )\n","\n","    early_stop10 = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    # --------------------------------------------------------\n","    # training model evaluasi\n","    # --------------------------------------------------------\n","    history10 = model10.fit(\n","        X_train10,\n","        y_train10,\n","        validation_data=(X_test10, y_test10),\n","        epochs=epochs10,\n","        batch_size=batch_size10,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop10]\n","    )\n","\n","    history_dict10[f\"{col}_eval\"] = history10\n","    model_dict10[f\"{col}_eval\"] = model10\n","\n","    # ========================================================\n","    # A. EVALUASI TRAINING (MODEL 2010-2023)\n","    # ========================================================\n","    y_pred_train_scaled10 = model10.predict(X_train10, verbose=0)\n","\n","    y_train_actual10 = scaler_y_train10.inverse_transform(\n","        y_train10.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_train_actual10 = scaler_y_train10.inverse_transform(\n","        y_pred_train_scaled10\n","    ).flatten()\n","\n","    train_dates10 = hist_df10[\"Tanggal\"].iloc[\n","        look_back10:len(hist_df10)-test_size10\n","    ].reset_index(drop=True)\n","\n","    train_plot_dict10[col] = pd.DataFrame({\n","        \"Tanggal\": train_dates10,\n","        \"Aktual\": y_train_actual10,\n","        \"Prediksi\": y_pred_train_actual10\n","    })\n","\n","    metrics_train10 = calculate_metrics(y_train_actual10, y_pred_train_actual10)\n","\n","    eval_train_results10.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_train10[\"MAE\"],\n","        \"RMSE\": metrics_train10[\"RMSE\"],\n","        \"MAPE\": metrics_train10[\"MAPE\"],\n","        \"sMAPE\": metrics_train10[\"sMAPE\"],\n","        \"R2\": metrics_train10[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # B. EVALUASI TESTING (2024)\n","    # ========================================================\n","    y_pred_test_scaled10 = model10.predict(X_test10, verbose=0)\n","\n","    y_test_actual10 = scaler_y_train10.inverse_transform(\n","        y_test10.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_test_actual10 = scaler_y_train10.inverse_transform(\n","        y_pred_test_scaled10\n","    ).flatten()\n","\n","    test_dates10 = hist_df10[\"Tanggal\"].iloc[-test_size10:].reset_index(drop=True)\n","\n","    test_plot_dict10[col] = pd.DataFrame({\n","        \"Tanggal\": test_dates10,\n","        \"Aktual\": y_test_actual10,\n","        \"Prediksi\": y_pred_test_actual10\n","    })\n","\n","    metrics_test10 = calculate_metrics(y_test_actual10, y_pred_test_actual10)\n","\n","    eval_test_results10.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_test10[\"MAE\"],\n","        \"RMSE\": metrics_test10[\"RMSE\"],\n","        \"MAPE\": metrics_test10[\"MAPE\"],\n","        \"sMAPE\": metrics_test10[\"sMAPE\"],\n","        \"R2\": metrics_test10[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # C. RETRAIN MODEL FINAL DENGAN DATA 2010-2024\n","    # ========================================================\n","    scaler_X_full10 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_full10 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaled_full_X10 = scaler_X_full10.fit_transform(feature_values10)\n","    scaled_full_y10 = scaler_y_full10.fit_transform(target_values10).flatten()\n","\n","    scaler_X_dict10[f\"{col}_full\"] = scaler_X_full10\n","    scaler_y_dict10[f\"{col}_full\"] = scaler_y_full10\n","\n","    X_full10, y_full10 = create_multivariate_sequences(\n","        data_array=scaled_full_X10,\n","        target_array=scaled_full_y10,\n","        look_back=look_back10\n","    )\n","\n","    model_final10 = build_lstm_model(\n","        look_back=look_back10,\n","        n_features=X_full10.shape[2]\n","    )\n","\n","    early_stop_final10 = EarlyStopping(\n","        monitor=\"loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history_final10 = model_final10.fit(\n","        X_full10,\n","        y_full10,\n","        epochs=epochs10,\n","        batch_size=batch_size10,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop_final10]\n","    )\n","\n","    history_dict10[f\"{col}_final\"] = history_final10\n","    model_dict10[f\"{col}_final\"] = model_final10\n","\n","    # ========================================================\n","    # D. EVALUASI TRAINING MODEL FINAL (2010-2024)\n","    # ========================================================\n","    y_pred_full_scaled10 = model_final10.predict(X_full10, verbose=0)\n","\n","    y_full_actual10 = scaler_y_full10.inverse_transform(\n","        y_full10.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_full_actual10 = scaler_y_full10.inverse_transform(\n","        y_pred_full_scaled10\n","    ).flatten()\n","\n","    full_train_dates10 = hist_df10[\"Tanggal\"].iloc[look_back10:].reset_index(drop=True)\n","\n","    final_train_plot_dict10[col] = pd.DataFrame({\n","        \"Tanggal\": full_train_dates10,\n","        \"Aktual\": y_full_actual10,\n","        \"Prediksi\": y_pred_full_actual10\n","    })\n","\n","    metrics_final_train10 = calculate_metrics(y_full_actual10, y_pred_full_actual10)\n","\n","    eval_final_train_results10.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_final_train10[\"MAE\"],\n","        \"RMSE\": metrics_final_train10[\"RMSE\"],\n","        \"MAPE\": metrics_final_train10[\"MAPE\"],\n","        \"sMAPE\": metrics_final_train10[\"sMAPE\"],\n","        \"R2\": metrics_final_train10[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # E. FORECAST 2025\n","    # ========================================================\n","    future_pc_df10 = pc_df10[\n","        (pc_df10[\"Tanggal\"] >= \"2025-01-01\") &\n","        (pc_df10[\"Tanggal\"] <= \"2025-12-01\")\n","    ].copy().reset_index(drop=True)\n","\n","    if len(future_pc_df10) < 12:\n","        print(f\"PC tahun 2025 untuk {col} tidak lengkap, forecast dilewati.\")\n","        continue\n","\n","    future_pc_values10 = future_pc_df10[pc_cols].values.astype(float)\n","\n","    # ambil window terakhir dari data 2010-2024 yang sudah di-scale\n","    rolling_window10 = scaled_full_X10[-look_back10:, :].copy()\n","    future_preds_scaled10 = []\n","\n","    for step in range(12):\n","        x_input10 = rolling_window10.reshape(1, look_back10, scaled_full_X10.shape[1])\n","\n","        # prediksi target saham\n","        next_pred_scaled10 = model_final10.predict(x_input10, verbose=0)[0, 0]\n","        future_preds_scaled10.append(next_pred_scaled10)\n","\n","        # ubah prediksi target ke skala asli dulu\n","        next_pred_actual10 = scaler_y_full10.inverse_transform(\n","            np.array([[next_pred_scaled10]])\n","        ).flatten()[0]\n","\n","        # gabungkan dengan PC periode 2025 pada bulan ke-step\n","        next_row_raw10 = np.array([\n","            next_pred_actual10,\n","            future_pc_values10[step, 0],\n","            future_pc_values10[step, 1],\n","            future_pc_values10[step, 2]\n","        ]).reshape(1, -1)\n","\n","        # scale lagi ke skala fitur\n","        next_row_scaled10 = scaler_X_full10.transform(next_row_raw10)\n","\n","        # update rolling window\n","        rolling_window10 = np.vstack([rolling_window10[1:], next_row_scaled10])\n","\n","    future_preds_scaled10 = np.array(future_preds_scaled10).reshape(-1, 1)\n","\n","    future_preds_actual10 = scaler_y_full10.inverse_transform(\n","        future_preds_scaled10\n","    ).flatten()\n","\n","    forecast_dict10[col] = future_preds_actual10\n","\n","print(\"Selesai semua saham loop 10.\")\n","\n","\n","# ============================================================\n","# 105. LOOP 10 - TABEL EVALUASI MODEL\n","# ============================================================\n","\n","eval_lstm_train10 = pd.DataFrame(eval_train_results10)\n","eval_lstm_test10 = pd.DataFrame(eval_test_results10)\n","eval_lstm_final_train10 = pd.DataFrame(eval_final_train_results10)\n","\n","print(\"=== LOOP 10 - EVALUASI TRAINING (MODEL 2010-2023) ===\")\n","print(eval_lstm_train10)\n","\n","print(\"\\n=== LOOP 10 - EVALUASI TESTING 2024 ===\")\n","print(eval_lstm_test10)\n","\n","print(\"\\n=== LOOP 10 - EVALUASI TRAINING FINAL (MODEL 2010-2024) ===\")\n","print(eval_lstm_final_train10)\n","\n","\n","# ============================================================\n","# 106. LOOP 10 - AMBIL KODE SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","smape_threshold10 = 10\n","\n","passed_stocks10 = eval_lstm_test10.loc[\n","    eval_lstm_test10[\"sMAPE\"] < smape_threshold10,\n","    \"Kode_Saham\"\n","].tolist()\n","\n","print(\"=== LOOP 10 - KODE SAHAM DENGAN sMAPE < 10 ===\")\n","print(passed_stocks10)\n","print(\"Jumlah saham lolos loop 10:\", len(passed_stocks10))\n","\n","\n","# ============================================================\n","# 107. LOOP 10 - PLOT GABUNGAN TRAINING 2010-2023 + TESTING 2024\n","#      HANYA UNTUK SAHAM DENGAN sMAPE < 10\n","# ============================================================\n","\n","for col in passed_stocks10:\n","    if col not in train_plot_dict10:\n","        print(f\"{col} tidak ada di train_plot_dict10, dilewati.\")\n","        continue\n","\n","    if col not in test_plot_dict10:\n","        print(f\"{col} tidak ada di test_plot_dict10, dilewati.\")\n","        continue\n","\n","    train_df10 = train_plot_dict10[col].copy()\n","    test_df10 = test_plot_dict10[col].copy()\n","\n","    plot_df10 = pd.concat([train_df10, test_df10], axis=0).reset_index(drop=True)\n","\n","    split_date10 = test_df10[\"Tanggal\"].iloc[0]\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    plt.plot(\n","        plot_df10[\"Tanggal\"],\n","        plot_df10[\"Aktual\"],\n","        label=\"Aktual\"\n","    )\n","\n","    plt.plot(\n","        plot_df10[\"Tanggal\"],\n","        plot_df10[\"Prediksi\"],\n","        label=\"Prediksi\"\n","    )\n","\n","    plt.axvline(\n","        x=split_date10,\n","        linestyle=\":\",\n","        color=\"black\",\n","        linewidth=2,\n","        label=\"Batas Training-Testing\"\n","    )\n","\n","    plt.title(f\"Aktual vs Prediksi - {col} (Loop 10)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()\n","\n","\n","# ============================================================\n","# 108. LOOP 10 - HASIL FORECAST 2025 UNTUK SAHAM YANG LOLOS\n","# ============================================================\n","\n","forecast_2025_passed10 = pd.DataFrame({\"Tanggal\": future_dates10})\n","\n","for col in passed_stocks10:\n","    if col in forecast_dict10:\n","        forecast_2025_passed10[col] = forecast_dict10[col]\n","\n","print(\"=== LOOP 10 - FORECAST 2025 UNTUK SAHAM DENGAN sMAPE < 10 ===\")\n","print(forecast_2025_passed10.head())\n","print(forecast_2025_passed10.shape)\n","\n","\n","# ============================================================\n","# 109. LOOP 10 - PLOT 