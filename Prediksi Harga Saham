  X_all4, y_all4 = create_multivariate_sequences(\n","        data_array=scaled_all_X4,\n","        target_array=scaled_all_y4,\n","        look_back=look_back4\n","    )\n","\n","    if len(X_all4) <= test_size4:\n","        print(f\"Sequence {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # sequence training dan testing\n","    X_train4 = X_all4[:-test_size4]\n","    y_train4 = y_all4[:-test_size4]\n","\n","    X_test4 = X_all4[-test_size4:]\n","    y_test4 = y_all4[-test_size4:]\n","\n","    print(\"Shape X_train4:\", X_train4.shape)\n","    print(\"Shape X_test4 :\", X_test4.shape)\n","\n","    # --------------------------------------------------------\n","    # bangun model evaluasi\n","    # --------------------------------------------------------\n","    model4 = build_lstm_model(\n","        look_back=look_back4,\n","        n_features=X_train4.shape[2]\n","    )\n","\n","    early_stop4 = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    # --------------------------------------------------------\n","    # training model evaluasi\n","    # --------------------------------------------------------\n","    history4 = model4.fit(\n","        X_train4,\n","        y_train4,\n","        validation_data=(X_test4, y_test4),\n","        epochs=epochs4,\n","        batch_size=batch_size4,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop4]\n","    )\n","\n","    history_dict4[f\"{col}_eval\"] = history4\n","    model_dict4[f\"{col}_eval\"] = model4\n","\n","    # ========================================================\n","    # A. EVALUASI TRAINING (MODEL 2010-2023)\n","    # ========================================================\n","    y_pred_train_scaled4 = model4.predict(X_train4, verbose=0)\n","\n","    y_train_actual4 = scaler_y_train4.inverse_transform(\n","        y_train4.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_