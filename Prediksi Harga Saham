_full_y11 = scaler_y_full11.fit_transform(target_values11).flatten()\n","\n","    scaler_X_dict11[f\"{col}_full\"] = scaler_X_full11\n","    scaler_y_dict11[f\"{col}_full\"] = scaler_y_full11\n","\n","    X_full11, y_full11 = create_multivariate_sequences(\n","        data_array=scaled_full_X11,\n","        target_array=scaled_full_y11,\n","        look_back=look_back11\n","    )\n","\n","    model_final11 = build_lstm_model(\n","        look_back=look_back11,\n","        n_features=X_full11.shape[2]\n","    )\n","\n","    early_stop_final11 = EarlyStopping(\n","        monitor=\"loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history_final11 = model_final11.fit(\n","        X_full11,\n","        y_full11,\n","        epochs=epochs11,\n","        batch_size=batch_size11,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop_final11]\n","    )\n","\n","    history_dict11[f\"{col}_final\"] = history_final11\n","    model_dict11[f\"{col}_final\"] = model_final11\n","\n","    y_pred_full_scaled11 = model_final11.predict(X_full11, verbose=0)\n","\n","    y_full_actual11 = scaler_y_full11.inverse_transform(\n","        y_full11.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_full_actual11 = scaler_y_full11.inverse_transform(\n","        y_pred_full_scaled11\n","    ).flatten()\n","\n","    full_train_dates11 = hist_df11[\"Tanggal\"].iloc[look_back11:].reset_index(drop=True)\n","\n","    final_train_plot_dict11[col] = pd.DataFrame({\n","        \"Tanggal\": full_train_dates11,\n","        \"Aktual\": y_full_actual11,\n","        \"Prediksi\": y_pred_full_actual11\n","    })\n","\n","    metrics_final_train11 = calculate_metrics(y_full_actual11, y_pred_full_actual11)\n","\n","    eval_final_train_results11.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_final_train11[\"MAE\"],\n","        \"RMSE\": metrics_final_train11[\"RMSE\"],\n","        \"MAPE\": metrics_final_tra