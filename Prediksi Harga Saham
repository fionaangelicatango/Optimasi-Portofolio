  x=split_date,\n","        linestyle=\":\",\n","        color=\"black\",\n","        linewidth=2,\n","        label=\"Batas Training-Testing\"\n","    )\n","\n","    plt.title(f\"Aktual vs Prediksi - {col}\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()\n","\n","    # ============================================================\n","# 11. PLOT AKTUAL VS PREDIKSI (TRAINING FINAL 2010-2024)\n","#    UNTUK KESELURUHAN SAHAM\n","# ============================================================\n","\n","for col in stock_cols:\n","    if col not in final_train_plot_dict:\n","        print(f\"{col} tidak ada di final_train_plot_dict, dilewati.\")\n","        continue\n","\n","    plot_df = final_train_plot_dict[col].copy()\n","\n","    plt.figure(figsize=(10, 5))\n","\n","    plt.plot(\n","        plot_df[\"Tanggal\"],\n","        plot_df[\"Aktual\"],\n","        label=\"Aktual\"\n","    )\n","\n","    plt.plot(\n","        plot_df[\"Tanggal\"],\n","        plot_df[\"Prediksi\"],\n","        label=\"Prediksi\"\n","    )\n","\n","    plt.title(f\"Aktual vs Prediksi - {col} (Model Final 2010-2024)\")\n","    plt.xlabel(\"Tanggal\")\n","    plt.ylabel(\"Harga Saham\")\n","    plt.legend()\n","    plt.grid(True)\n","    plt.xticks(rotation=45)\n","    plt.tight_layout()\n","    plt.show()\n","\n","    # ============================================================\n","# 12. PLOT FORECAST 2025\n","#    UNTUK KESELURUHAN SAHAM\n","# ============================================================\n","\n","for col in stock_cols:\n","    if col not in forecast_2025_all.columns:\n","        print(f\"{col} tidak ada di forecast_2025_all, dilewati.\")\n","        continue\n","\n","    plt.figure(figsize=(10, 5))\n","\n","    plt.plot(\n","        forecast_2025_all[\"Tanggal\"],\n","        forecast_2025_all[col],\n","        marker=\"o\",\n","      