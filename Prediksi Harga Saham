 in stock_cols14:\n","    print(\"=\"*70)\n","    print(f\"Proses saham loop 14: {col}\")\n","\n","    series_df14 = df_all14[[\"Tanggal\", col] + pc_cols].copy()\n","    series_df14 = series_df14.dropna().reset_index(drop=True)\n","\n","    if len(series_df14) <= (look_back14 + test_size14):\n","        print(f\"Data {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    hist_df14 = series_df14[\n","        series_df14[\"Tanggal\"] < \"2025-01-01\"\n","    ].copy().reset_index(drop=True)\n","\n","    target_values14 = hist_df14[[col]].values.astype(float)\n","    feature_values14 = hist_df14[[col] + pc_cols].values.astype(float)\n","\n","    train_target14 = target_values14[:-test_size14]\n","    test_target14  = target_values14[-test_size14:]\n","\n","    train_features14 = feature_values14[:-test_size14]\n","    test_features14  = feature_values14[-test_size14:]\n","\n","    scaler_X_train14 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_train14 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaler_X_train14.fit(train_features14)\n","    scaler_y_train14.fit(train_target14)\n","\n","    scaled_all_X14 = scaler_X_train14.transform(feature_values14)\n","    scaled_all_y14 = scaler_y_train14.transform(target_values14).flatten()\n","\n","    X_all14, y_all14 = create_multivariate_sequences(\n","        data_array=scaled_all_X14,\n","        target_array=scaled_all_y14,\n","        look_back=look_back14\n","    )\n","\n","    if len(X_all14) <= test_size14:\n","        print(f\"Sequence {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    X_train14 = X_all14[:-test_size14]\n","    y_train14 = y_all14[:-test_size14]\n","\n","    X_test14 = X_all14[-test_size14:]\n","    y_test14 = y_all14[-test_size14:]\n","\n","    model14 = build_lstm_model(\n","        look_back=look_back14,\n","        n_features=X_train14.shape[2]\n","    )\n","\n","    early_stop14 = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history14 = model14.fit(\n","        X_train14,\n","        y_train14,\n","        validation_data=(X_test14, y_test14),\n","        epochs=epochs14,\n","        batch_size=batch_size14,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop14]\n","    )\n","\n","    history_dict14[f\"{col}_eval\"] = history14\n","    model_dict14[f\"{col}_eval\"] = model14\n","\n","    y_pred_train_scaled14 = model14.predict(X_train14, verbose=0)\n","\n","    y_train_actual14 = scaler_y_train14.inverse_transform(\n","        y_train14.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_train_actual14 = scaler_y_train14.inverse_transform(\n","        y_pred_train_scaled14\n","    ).flatten()\n","\n","    train_dates14 = hist_df14[\"Tanggal\"].iloc[\n","        look_back14:len(hist_df14)-test_size14\n","    ].reset_index(drop=True)\n","\n","    train_plot_dict14[col] = pd.DataFrame({\n","        \"Tanggal\": train_dates14,\n","        \"Aktual\": y_train_actual14,\n","        \"Prediksi\": y_pred_train_actual14\n","    })\n","\n","    metrics_train14 = calculate_metrics(y_train_actual14, y_pred_train_actual14)\n","\n","    eval_train_results14.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_train14[\"MAE\"],\n","        \"RMSE\": metrics_train14[\"RMSE\"],\n","        \"MAPE\": metrics_train14[\"MAPE\"],\n","        \"sMAPE\": metrics_train14[\"sMAPE\"],\n","        \"R2\": metrics_train14[\"R2\"]\n","    })\n","\n","    y_pred_test_scaled14 = model14.predict(X_test14, verbose=0)\n","\n","    y_test_actual14 = scaler_y_train14.inverse_transform(\n","        y_test14.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_test_actual14 = scaler_y_train14.inverse_transform(\n","        y_pred_test_scaled14\n","    ).flatten()\n","\n","    test_dates14 = hist_df14[\"Tanggal\"].iloc[-test_size14:].reset_index(drop=True)\n","\n","    test_plot_dict14[col] = pd.DataFrame({\n","        \"Tanggal\": test_dates14,\n","        \"Aktual\": y_test_actual14,\n","        \"Prediksi\": y_pred_test_actual14\n","    })\n","\n","    metrics_test14 = calculate_metrics(y_test_actual14, y_pred_test_actual14)\n","\n","    eval_test_results14.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_test14[\"MAE\"],\n","        \"RMSE\": metrics_test14[\"RMSE\"],\n","        \"MAPE\": metrics_test14[\"MAPE\"],\n","        \"sMAPE\": metrics_test14[\"sMAPE\"],\n","        \"R2\": metrics_test14[\"R2\"]\n","    })\n","\n","    scaler_X_full14 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_full14 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaled_full_X14 = scaler_X_full14.fit_transform(feature_values14)\n","    scaled_full_y14 = scaler_y_full14.fit_transform(target_values14).flatten()\n","\n","    X_full14, y_full14 = create_multivariate_sequences(\n","        data_array=scaled_full_X14,\n","        target_array=scaled_full_y14,\n","        look_back=look_back14\n","    )\n","\n","    model_final14 = build_lstm_model(\n","        look_back=look_back14,\n","        n_features=X_full14.shape[2]\n","    )\n","\n","    early_stop_final14 = EarlyStopping(\n","        monitor=\"loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history_final14 = model_final14.fit(\n","        X_full14,\n","        y_full14,\n","        epochs=epochs14,\n","        batch_size=batch_size14,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop_final14]\n","    )\n","\n","    history_dict14[f\"{col}_final\"] = history_final14\n","    model_dict14[f\"{col}_final\"] = model_final14\n","\n","    y_pred_full_scaled14 = model_final14.predict(X_full14, verbose=0)\n","\n","    y_full_actual14 = scaler_y_full14.inverse_transform(\n","        y_full14.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_full_actual14 = scaler_y_full14.inverse_transform(\n","        y_pred_full_scaled14\n","    ).flatten()\n","\n","    full_train_dates14 = hist_df14[\"Tanggal\"].iloc[look_back14:].reset_index(drop=True)\n","\n","    final_train_plot_dict14[col] = pd.DataFrame({\n","        \"Tanggal\": full_train_dates14,\n","        \"Aktual\": y_full_actual14,\n","        \"Prediksi\": y_pred_full_actual14\n","    })\n","\n","    metrics_final_train14 = calculate_metrics(y_full_actual14, y_pred_full_actual14)\n","\n","    eval_final_train_results14.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_final_train14[\"MAE\"],\n","        \"RMSE\": metrics_final_train14[\"RMSE\"],\n","        \"MAPE\": metrics_final_train14[\"MAPE\"],\n","        \"sMAPE\": metrics_final_train14[\"sMAPE\"],\n","        \"R2\": metrics_final_train14[\"R2\"]\n","    })\n","\n","    future_pc_df14 = pc_df14[\n","        (pc_df14[\"Tanggal\"] >= \"2025-01-01\") &\n","        (pc_df14[\"Tanggal\"] <= \"2025-12-01\")\n","    ].copy().reset_index(drop=True)\n","\n","    if len(future_pc_df14) < 12:\n","        print(f\"PC tahun 2025 untuk {col} tidak lengkap, forecast dilewati.\")\n","        continue\n","\n","    future_pc_values14 = future_pc_df14[pc_cols].values.astype(float)\n","\n","    rolling_window14 = scaled_full_X14[-look_back14:, :].copy()\n","    future_preds_scaled14 = []\n","\n","    for step in range(12):\n","        x_input14 = rolling_window14.reshape(1, look_back14, scaled_full_X14.shape[1])\n","\n","        next_pred_scaled14 = model_final14.predict(x_input14, verbose=0)[0, 0]\n","        future_preds_scaled14.append(next_pred_scaled14)\n","\n","        next_pred_actual14 = scaler_y_full14.inverse_transform(\n","            np.array([[next_pred_scaled14]])\n","        ).flatten()[0]\n","\n","        next_row_raw14 = np.array([\n","            next_pred_actual14,\n","            future_pc_values14[step, 0],\n","            future_pc_values14[step, 1],\n","            future_pc_values14[step, 2]\n","        ]).reshape(1, -1)\n","\n","        next_row_scaled14 = scaler_X_full14.transform(next_row_raw14)\n","        rolling_window14 = np.vstack([rolling_window14[1:], next_row_scaled14])\n","\n","    future_preds_scaled14 = np.array(future_preds_scaled14).reshape(-1, 1)\n","\n","    future_preds_actual14 = scaler_y_full14.inverse_transform(\n","        future_preds_scaled14\n","    ).flatten()\n","\n","    forecast_dict14[col] = future_preds_actual14\n","\n","print(\"Selesai semua saham loop 14.\")\n","\n","eval_lstm_train14 = pd.DataFrame(eval_train_results14)\n","eval_lstm_test14 = pd.DataFrame(eval_test_results14)\n","eval_lstm_final_train14 = pd.DataFrame(eval_final_train_results14)\n","\n","smape_threshold14 = 10\n","\n","passed_stocks14 = eval_lstm_test14.loc[\n","    eval_lstm_test14[\"sMAPE\"] < smape_threshold14,\n","    \"Kode_Saham\"\n","].tolist()\n","\n","forecast_2025_passed14 = pd.DataFrame({\"Tanggal\": future_dates14})\n","\n","for col in passed_stocks14:\n","    if col in forecast_dict14:\n","        forecast_2025_passed14[col] = forecast_dict14[col]\n","\n","remaining_stocks14 = [\n","    col for col in harga_2010_2024_sisa13.columns\n","    if col not in passed_stocks14 + [\"Tanggal\"]\n","]\n","\n","harga_2010_2024_sisa14 = harga_2010_2024_sisa13[\n","    [\"Tanggal\"] + remaining_stocks14\n","].copy()\n","\n","import os\n","\n","base_folder14 = \"/content/drive/My Drive/hasil_loop14\"\n","\n","excel_folder14 = os.path.join(base_folder14, \"Excel\")\n","plot_train_test_folder14 = os.path.join(base_folder14, \"Plot_Training_Testing_2010_2024\")\n","plot_final_training_folder14 = os.path.join(base_folder14, \"Plot_Training_Final_2010_2024\")\n","plot_forecast_folder14 = os.path.join(base_folder14, \"Plot_Forecast_2025\")\n","plot_hist_forecast_folder14 = os.path.join(base_folder14, \"Plot_Historis_dan_Forecast_2025\")\n","\n","os.makedirs(excel_folder14, exist_ok=True)\n","os.makedirs(plot_train_test_folder14, exist_ok=True)\n","os.makedirs(plot_final_training_folder14, exist_ok=True)\n","os.makedirs(plot_forec