 loop 5: 19\n"]}]},{"cell_type":"code","source":["# ============================================================\n","# 49. LOOP 5 - TRAIN + TEST + RETRAIN FINAL + FORECAST 2025\n","#     UNTUK SETIAP SAHAM SISA\n","# ============================================================\n","\n","look_back5 = 8\n","test_size5 = 12\n","epochs5 = 200\n","batch_size5 = 1\n","\n","forecast_dict5 = {}\n","\n","# evaluasi model awal\n","eval_train_results5 = []\n","eval_test_results5 = []\n","\n","# evaluasi model final\n","eval_final_train_results5 = []\n","\n","history_dict5 = {}\n","model_dict5 = {}\n","scaler_X_dict5 = {}\n","scaler_y_dict5 = {}\n","\n","train_plot_dict5 = {}\n","test_plot_dict5 = {}\n","final_train_plot_dict5 = {}\n","\n","# tanggal forecast 2025\n","future_dates5 = pd.date_range(start=\"2025-01-01\", periods=12, freq=\"MS\")\n","\n","for col in stock_cols5:\n","    print(\"=\"*70)\n","    print(f\"Proses saham loop 5: {col}\")\n","\n","    # --------------------------------------------------------\n","    # ambil data 1 saham + PC\n","    # --------------------------------------------------------\n","    series_df5 = df_all5[[\"Tanggal\", col] + pc_cols].copy()\n","    series_df5 = series_df5.dropna().reset_index(drop=True)\n","\n","    # cek minimal data\n","    if len(series_df5) <= (look_back5 + test_size5):\n","        print(f\"Data {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # --------------------------------------------------------\n","    # pisahkan data historis sampai 2024\n","    # --------------------------------------------------------\n","    hist_df5 = series_df5[\n","        series_df5[\"Tanggal\"] < \"2025-01-01\"\n","    ].copy().reset_index(drop=True)\n","\n","    # target saham\n","    target_values5 = hist_df5[[col]].values.astype(float)\n","\n","    # fitur multivariat = [harga saham, PC1, PC2, PC3]\n","    feature_values5 = hist_df5[[col] + pc_cols].values.astype(float)\n","\n","    # --------------------------------------------------------\n","    # split data:\n","    # train awal = 2010-2023\n","    # test       = 2024\n","    # --------------------------------------------------------\n","    train_target5 = target_values5[:-test_size5]\n","    test_target5  = target_values5[-test_size5:]\n","\n","    train_features5 = feature_values5[:-test_size5]\n","    test_features5  = feature_values5[-test_size5:]\n","\n","    # --------------------------------------------------------\n","    # scaling\n","    # scaler fitur fit hanya pada training\n","    # scaler target fit hanya pada training\n","    # --------------------------------------------------------\n","    scaler_X_train5 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_train5 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaler_X_train5.fit(train_features5)\n","    scaler_y_train5.fit(train_target5)\n","\n","    scaled_all_X5 = scaler_X_train5.transform(feature_values5)\n","    scaled_all_y5 = scaler_y_train5.transform(target_values5).flatten()\n","\n","    scaler_X_dict5[f\"{col}_train\"] = scaler_X_train5\n","    scaler_y_dict5[f\"{col}_train\"] = scaler_y_train5\n","\n","    # --------------------------------------------------------\n","    # buat sequence untuk evaluasi model awal\n","    # --------------------------------------------------------\n","    X_all5, y_all5 = create_multivariate_sequences(\n","        data_array=scaled_all_X5,\n","        target_array=scaled_all_y5,\n","        look_back=look_back5\n","    )\n","\n","    if len(X_all5) <= test_size5:\n","        print(f\"Sequence {col} tidak cukup, dilewati.\")\n","        continue\n","\n","    # sequence training dan testing\n","    X_train5 = X_all5[:-test_size5]\n","    y_train5 = y_all5[:-test_size5]\n","\n","    X_test5 = X_all5[-test_size5:]\n","    y_test5 = y_all5[-test_size5:]\n","\n","    print(\"Shape X_train5:\", X_train5.shape)\n","    print(\"Shape X_test5 :\", X_test5.shape)\n","\n","    # --------------------------------------------------------\n","    # bangun model evaluasi\n","    # --------------------------------------------------------\n","    model5 = build_lstm_model(\n","        look_back=look_back5,\n","        n_features=X_train5.shape[2]\n","    )\n","\n","    early_stop5 = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    # --------------------------------------------------------\n","    # training model evaluasi\n","    # --------------------------------------------------------\n","    history5 = model5.fit(\n","        X_train5,\n","        y_train5,\n","        validation_data=(X_test5, y_test5),\n","        epochs=epochs5,\n","        batch_size=batch_size5,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop5]\n","    )\n","\n","    history_dict5[f\"{col}_eval\"] = history5\n","    model_dict5[f\"{col}_eval\"] = model5\n","\n","    # ========================================================\n","    # A. EVALUASI TRAINING (MODEL 2010-2023)\n","    # ========================================================\n","    y_pred_train_scaled5 = model5.predict(X_train5, verbose=0)\n","\n","    y_train_actual5 = scaler_y_train5.inverse_transform(\n","        y_train5.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_train_actual5 = scaler_y_train5.inverse_transform(\n","        y_pred_train_scaled5\n","    ).flatten()\n","\n","    train_dates5 = hist_df5[\"Tanggal\"].iloc[\n","        look_back5:len(hist_df5)-test_size5\n","    ].reset_index(drop=True)\n","\n","    train_plot_dict5[col] = pd.DataFrame({\n","        \"Tanggal\": train_dates5,\n","        \"Aktual\": y_train_actual5,\n","        \"Prediksi\": y_pred_train_actual5\n","    })\n","\n","    metrics_train5 = calculate_metrics(y_train_actual5, y_pred_train_actual5)\n","\n","    eval_train_results5.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_train5[\"MAE\"],\n","        \"RMSE\": metrics_train5[\"RMSE\"],\n","        \"MAPE\": metrics_train5[\"MAPE\"],\n","        \"sMAPE\": metrics_train5[\"sMAPE\"],\n","        \"R2\": metrics_train5[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # B. EVALUASI TESTING (2024)\n","    # ========================================================\n","    y_pred_test_scaled5 = model5.predict(X_test5, verbose=0)\n","\n","    y_test_actual5 = scaler_y_train5.inverse_transform(\n","        y_test5.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_test_actual5 = scaler_y_train5.inverse_transform(\n","        y_pred_test_scaled5\n","    ).flatten()\n","\n","    test_dates5 = hist_df5[\"Tanggal\"].iloc[-test_size5:].reset_index(drop=True)\n","\n","    test_plot_dict5[col] = pd.DataFrame({\n","        \"Tanggal\": test_dates5,\n","        \"Aktual\": y_test_actual5,\n","        \"Prediksi\": y_pred_test_actual5\n","    })\n","\n","    metrics_test5 = calculate_metrics(y_test_actual5, y_pred_test_actual5)\n","\n","    eval_test_results5.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_test5[\"MAE\"],\n","        \"RMSE\": metrics_test5[\"RMSE\"],\n","        \"MAPE\": metrics_test5[\"MAPE\"],\n","        \"sMAPE\": metrics_test5[\"sMAPE\"],\n","        \"R2\": metrics_test5[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # C. RETRAIN MODEL FINAL DENGAN DATA 2010-2024\n","    # ========================================================\n","    scaler_X_full5 = MinMaxScaler(feature_range=(0, 1))\n","    scaler_y_full5 = MinMaxScaler(feature_range=(0, 1))\n","\n","    scaled_full_X5 = scaler_X_full5.fit_transform(feature_values5)\n","    scaled_full_y5 = scaler_y_full5.fit_transform(target_values5).flatten()\n","\n","    scaler_X_dict5[f\"{col}_full\"] = scaler_X_full5\n","    scaler_y_dict5[f\"{col}_full\"] = scaler_y_full5\n","\n","    X_full5, y_full5 = create_multivariate_sequences(\n","        data_array=scaled_full_X5,\n","        target_array=scaled_full_y5,\n","        look_back=look_back5\n","    )\n","\n","    model_final5 = build_lstm_model(\n","        look_back=look_back5,\n","        n_features=X_full5.shape[2]\n","    )\n","\n","    early_stop_final5 = EarlyStopping(\n","        monitor=\"loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    history_final5 = model_final5.fit(\n","        X_full5,\n","        y_full5,\n","        epochs=epochs5,\n","        batch_size=batch_size5,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop_final5]\n","    )\n","\n","    history_dict5[f\"{col}_final\"] = history_final5\n","    model_dict5[f\"{col}_final\"] = model_final5\n","\n","    # ========================================================\n","    # D. EVALUASI TRAINING MODEL FINAL (2010-2024)\n","    # ========================================================\n","    y_pred_full_scaled5 = model_final5.predict(X_full5, verbose=0)\n","\n","    y_full_actual5 = scaler_y_full5.inverse_transform(\n","        y_full5.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_full_actual5 = scaler_y_full5.inverse_transform(\n","        y_pred_full_scaled5\n","    ).flatten()\n","\n","    full_train_dates5 = hist_df5[\"Tanggal\"].iloc[look_back5:].reset_index(drop=True)\n","\n","    final_train_plot_dict5[col] = pd.DataFrame({\n","        \"Tanggal\": full_train_dates5,\n","        \"Aktual\": y_full_actual5,\n","        \"Prediksi\": y_pred_full_actual5\n","    })\n","\n","    metrics_final_train5 = calculate_metrics(y_full_actual5, y_pred_full_actual5)\n","\n","    eval_final_train_results5.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_final_train5[\"MAE\"],\n","        \"RMSE\": metrics_final_train5[\"RMSE\"],\n","        \"MAPE\": metrics_final_train5[\"MAPE\"],\n","        \"sMAPE\": metrics_final_train5[\"sMAPE\"],\n","        \"R2\": metrics_final_train5[\"R2\"]\n","    })\n","\n","    # ========================================================\n","    # E. FORECAST 2025\n","    # ========================================================\n","    future_pc_df5 = pc_df5[\n","        (pc_df5[\"Tanggal\"] >= \"2025-01-01\") &\n","        (pc_df5[\"Tanggal\"] <= \"2025-12-01\")\n","    ].copy().reset_index(drop=True)\n","\n","    if len(future_pc_df5) < 12:\n","        print(f\"PC tahun 2025 untuk {col} tidak lengkap, forecast dilewati.\")\n","        continue\n","\n","    future_pc_values5 = future_pc_df5[pc_cols].values.astype(float)\n","\n","    # ambil window terakhir dari data 2010-2024 yang sudah di-scale\n","    rolling_window5 = scaled_full_X5[-look_back5:, :].copy()\n","    future_preds_scaled5 = []\n","\n","    for step in range(12):\n","        x_input5 = rolling_window5.reshape(1, look_back5, scaled_full_X5.shape[1])\n","\n","        # prediksi target saham\n","        next_pred_scaled5 = model_final5.predict(x_input5, verbose=0)[0, 0]\n","        future_preds_scaled5.append(next_pred_scaled5)\n","\n","        # ubah prediksi target ke skala asli dulu\n","        next_pred_actual5 = scaler_y_full5.inverse_transform(\n","            np.array([[next_pred_scaled5]])\n","        ).flatten()[0]\n","\n","        # gabungkan dengan PC periode 2025 pada bulan ke-step\n","        next_row_raw5 = np.array([\n","            next_pred_actual5,\n","            future_pc_values5[step, 0],\n","            future_pc_values5[step, 1],\n","            future_pc_values5[step, 2]\n","        ]).reshape(1, -1)\n","\n","        # scale lagi ke skala fitur\n","        next_row_scaled5 = scaler_X_full5.transform(next_row_raw5)\n","\n","        # update rolling window\n","        rolling_window5 = np.vstack([rolling_window5[1:], next_row_scaled5])\n","\n","    future_preds_scaled5 = np.array(future_preds_scaled5).reshape(-1, 1)\n","\n","    future_preds_actual5 = scaler_y_full5.inverse_transform(\n","        future_preds_scaled5\n","    ).flatte