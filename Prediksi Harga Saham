eatures=X_train2.shape[2]\n","    )\n","\n","    early_stop2 = EarlyStopping(\n","        monitor=\"val_loss\",\n","        patience=20,\n","        restore_best_weights=True\n","    )\n","\n","    # --------------------------------------------------------\n","    # training model evaluasi\n","    # --------------------------------------------------------\n","    history2 = model2.fit(\n","        X_train2,\n","        y_train2,\n","        validation_data=(X_test2, y_test2),\n","        epochs=epochs2,\n","        batch_size=batch_size2,\n","        verbose=0,\n","        shuffle=False,\n","        callbacks=[early_stop2]\n","    )\n","\n","    history_dict2[f\"{col}_eval\"] = history2\n","    model_dict2[f\"{col}_eval\"] = model2\n","\n","    # ========================================================\n","    # A. EVALUASI TRAINING (MODEL 2010-2023)\n","    # ========================================================\n","    y_pred_train_scaled2 = model2.predict(X_train2, verbose=0)\n","\n","    y_train_actual2 = scaler_y_train2.inverse_transform(\n","        y_train2.reshape(-1, 1)\n","    ).flatten()\n","\n","    y_pred_train_actual2 = scaler_y_train2.inverse_transform(\n","        y_pred_train_scaled2\n","    ).flatten()\n","\n","    train_dates2 = hist_df2[\"Tanggal\"].iloc[\n","        look_back2:len(hist_df2)-test_size2\n","    ].reset_index(drop=True)\n","\n","    train_plot_dict2[col] = pd.DataFrame({\n","        \"Tanggal\": train_dates2,\n","        \"Aktual\": y_train_actual2,\n","        \"Prediksi\": y_pred_train_actual2\n","    })\n","\n","    metrics_train2 = calculate_metrics(y_train_actual2, y_pred_train_actual2)\n","\n","    eval_train_results2.append({\n","        \"Kode_Saham\": col,\n","        \"MAE\": metrics_train2[\"MAE\"],\n","        \"RMSE\": metrics_train2[\"RMSE\"],\n","        \"MAPE\": metrics_train2[\"MAPE\"],\n","        \"sMAPE\": metrics_train2[\"sMAPE\"],\n","        \"R2\": metrics_train2[\"R2\"]\n","    })\n","\n","    # =======